{
  "HIP": {
    "ExposeInternalApis": true,
    "Crypto": {
      "Provider": "ECDsa",
      "PrivateKeyStorePath": "/home/jarvis_bot/.openclaw/keys/private",
      "PublicKeyStorePath": "/home/jarvis_bot/.openclaw/keys/public"
    },
    "Plugins": {
      "Enabled": [
        "core.policy.strict",
        "core.reputation.feedback",
        "core.identity.oidc",
        "core.metrics.system",
        "core.identity.insights",
        "core.chat.insights"
      ],
      "AutoDiscover": false
    },
    "Chat": {
      "Mode": "oauth"
    },
    "Audit": {
      "RetentionDays": 30,
      "ExportMaxRows": 2000
    },
    "ReputationFeedback": {
      "DuplicateWindowMinutes": 10,
      "MaxPerReporterPerMinute": 20,
      "LegitWeight": 1.0,
      "SuspiciousWeight": 1.0,
      "MaliciousWeight": 1.0
    },
    "IdentityOidc": {
      "AllowedIssuers": [],
      "RequireVerifiedEmailForHighAssurance": true
    },
    "AdminAuth": {
      "EnableOidcJwt": false,
      "Authority": "",
      "Audience": "hip-admin-api",
      "RoleClaimSources": [ "role", "roles", "groups" ]
    }
  }
}