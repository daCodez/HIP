{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hip.local/schemas/policy.schema.json",
  "title": "HIP Security Policy",
  "type": "object",
  "required": ["id", "name", "category", "enabled", "priority", "severity", "when", "then", "stop"],
  "properties": {
    "id": { "type": "string", "minLength": 3, "maxLength": 64 },
    "name": { "type": "string", "minLength": 3, "maxLength": 120 },
    "category": {
      "type": "string",
      "enum": ["Login", "Device", "Session", "Messaging", "Token", "Reputation", "Authorization", "System", "Data", "Risk"]
    },
    "enabled": { "type": "boolean" },
    "priority": { "type": "integer", "minimum": 1, "maximum": 2000 },
    "severity": { "type": "string", "enum": ["Info", "Warning", "Medium", "High", "Critical"] },
    "when": {
      "type": "object",
      "properties": {
        "all": { "type": "array", "items": { "$ref": "#/$defs/condition" } },
        "any": { "type": "array", "items": { "$ref": "#/$defs/condition" } },
        "not": { "$ref": "#/$defs/condition" }
      },
      "additionalProperties": false
    },
    "then": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/action" }
    },
    "stop": { "type": "boolean" }
  },
  "additionalProperties": false,
  "$defs": {
    "condition": {
      "type": "object",
      "required": ["field", "op", "value"],
      "properties": {
        "field": { "type": "string", "minLength": 2, "maxLength": 128 },
        "op": {
          "type": "string",
          "enum": ["eq", "neq", "gt", "gte", "lt", "lte", "in", "not_in", "contains", "exists"]
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "challenge.mfa", "challenge.device", "session.kill", "account.lock", "account.quarantine", "account.restrict",
            "message.block", "message.warn", "rateLimit.apply", "token.revoke", "token.deny",
            "approval.require", "audit.write", "alert.user", "alert.admin", "event.raise", "reputation.delta"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
