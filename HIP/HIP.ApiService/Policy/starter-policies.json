[
  { "id": "POL-001", "name": "Require MFA", "category": "Login", "enabled": true, "priority": 500, "severity": "Medium", "when": { "all": [ { "field": "event.type", "op": "eq", "value": "UserLoginAttempt" }, { "field": "auth.mfa", "op": "eq", "value": false } ] }, "then": [ { "action": "challenge.mfa" }, { "action": "event.raise", "severity": "Medium", "code": "MFA_REQUIRED" } ], "stop": false },
  { "id": "POL-003", "name": "Replay attempt block", "category": "Token", "enabled": true, "priority": 1000, "severity": "Critical", "when": { "all": [ { "field": "security.replayDetected", "op": "eq", "value": true } ] }, "then": [ { "action": "session.kill" }, { "action": "event.raise", "severity": "Critical", "code": "REPLAY_DETECTED" } ], "stop": true },
  { "id": "POL-007", "name": "Phishing domain block", "category": "Messaging", "enabled": true, "priority": 800, "severity": "Critical", "when": { "all": [ { "field": "messaging.domainFlagged", "op": "eq", "value": true } ] }, "then": [ { "action": "message.block" }, { "action": "event.raise", "severity": "Critical", "code": "PHISHING_DOMAIN" } ], "stop": true },
  { "id": "POL-012", "name": "Brute force lock", "category": "Login", "enabled": true, "priority": 800, "severity": "Critical", "when": { "all": [ { "field": "auth.loginAttempts_5m", "op": "gt", "value": 5 } ] }, "then": [ { "action": "account.lock", "durationMinutes": 15 }, { "action": "alert.user" } ], "stop": true },
  { "id": "POL-023", "name": "Account takeover combined signal", "category": "Login", "enabled": true, "priority": 800, "severity": "Critical", "when": { "all": [ { "field": "auth.newDevice", "op": "eq", "value": true }, { "field": "geo.newLocation", "op": "eq", "value": true }, { "field": "auth.mfa", "op": "eq", "value": false } ] }, "then": [ { "action": "account.lock", "durationMinutes": 30 }, { "action": "event.raise", "severity": "Critical", "code": "ATO_COMBINED" } ], "stop": true },
  { "id": "POL-026", "name": "Composite risk score threshold", "category": "Risk", "enabled": true, "priority": 700, "severity": "Critical", "when": { "all": [ { "field": "risk.score", "op": "gte", "value": 80 } ] }, "then": [ { "action": "event.raise", "severity": "Critical", "code": "RISK_TOO_HIGH" } ], "stop": false }
]
