{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "admin": {
        "ClusterId": "admin",
        "Match": { "Path": "/admin/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/admin" },
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/admin" },
          { "RequestHeader": "X-Forwarded-Proto", "Set": "https" }
        ]
      },
      "api": {
        "ClusterId": "api",
        "Match": { "Path": "/api/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api" },
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/api" },
          { "RequestHeader": "X-Forwarded-Proto", "Set": "https" }
        ]
      },
      "swagger": {
        "ClusterId": "api",
        "Match": { "Path": "/swagger/{**catch-all}" },
        "Transforms": [
          { "RequestHeader": "X-Forwarded-Proto", "Set": "https" }
        ]
      },
      "aspire": {
        "ClusterId": "aspire",
        "Match": { "Path": "/aspire/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/aspire" },
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/aspire" },
          { "RequestHeader": "X-Forwarded-Proto", "Set": "https" }
        ]
      },
      "web": {
        "ClusterId": "web",
        "Match": { "Path": "/{**catch-all}" },
        "Transforms": [
          { "RequestHeader": "X-Forwarded-Proto", "Set": "https" }
        ]
      }
    },
    "Clusters": {
      "web": {
        "Destinations": {
          "d1": { "Address": "http://127.0.0.1:45727/" }
        }
      },
      "admin": {
        "Destinations": {
          "d1": { "Address": "http://127.0.0.1:45728/" }
        }
      },
      "api": {
        "Destinations": {
          "d1": { "Address": "http://127.0.0.1:5101/" }
        }
      },
      "aspire": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "d1": { "Address": "https://127.0.0.1:17193/" }
        }
      }
    }
  }
}
