{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "HipAdmin": {
    "Auth": {
      "EnableOidc": false,
      "EnforceLogin": false,
      "Provider": "Authentik",
      "Authority": "",
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/signin-oidc",
      "SignedOutCallbackPath": "/signout-callback-oidc",
      "Scopes": [ "openid", "profile", "email" ],
      "RoleClaimType": "role"
    }
  }
}
