@page "/security-status"
@inject HipAdminApiClient Api
@inject ToastService Toast
@implements IDisposable

<PageTitle>Security Status</PageTitle>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between mb-3">
            <h5>Security Status</h5>
            <div class="d-flex gap-2 align-items-center">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" @bind="_autoRefresh" />
                    <label class="form-check-label">Auto refresh</label>
                </div>
                <button class="btn btn-primary btn-sm" @onclick="Load">Refresh</button>
            </div>
        </div>

        @foreach (var check in _checks)
        {
            <div class="d-flex justify-content-between border-bottom py-2">
                <div>
                    <div class="fw-semibold">@check.Name</div>
                    <small class="text-muted">@check.LastChecked.ToLocalTime()</small>
                </div>
                <BadgeStatus Text="@check.Status" />
            </div>
        }
    </div>
</div>

@code {
    private List<SecurityCheck> _checks = [];
    private bool _autoRefresh;
    private PeriodicTimer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await Load();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
        _ = RunAutoRefresh();
    }

    private async Task RunAutoRefresh()
    {
        if (_timer is null) return;
        while (await _timer.WaitForNextTickAsync())
        {
            if (_autoRefresh)
            {
                await Load();
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task Load()
    {
        var result = await Api.GetSecurityChecksAsync();
        _checks = result.Data ?? [];
        Toast.Show("Security", "Security checks refreshed", "success");
    }

    public void Dispose() => _timer?.Dispose();
}
