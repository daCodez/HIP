@page "/"
@implements IDisposable
@inject HipAdminApiClient Api
@inject AdminContextService AdminContext

<PageTitle>Dashboard</PageTitle>

@if (_degradedSources.Count > 0)
{
    <div class="alert alert-warning py-2 small">
        <strong>Degraded mode:</strong> @string.Join(" | ", _degradedSources)
        <span class="ms-2 text-muted">Retry/refresh in @(_refreshCountdown)s.</span>
    </div>
}
else
{
    <div class="alert alert-secondary py-2 small">
        <strong>Live monitoring:</strong>
        <span class="ms-1 text-muted">Next refresh in @(_refreshCountdown)s.</span>
    </div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<section class="widget widget-table table-widget-frame mb-3 security-score-card">
    <div class="widget-header">
        <h3><i class="fa fa-shield"></i> Security Health</h3>
        @if (AdminContext.MockModeEnabled)
        {
            <span class="widget-label">Demo Data</span>
        }
        else if (_metricsDegraded)
        {
            <span class="widget-label degraded">Degraded</span>
        }
        else
        {
            <span class="widget-label live">Live Data</span>
        }
    </div>
    <div class="widget-content">
        <div class="score-row">
            <div>
                <div class="score-value">@SecurityScore / 100</div>
                <div class="score-status @ScoreClass">@ScoreEmoji @ScoreLabel</div>
            </div>
            <div class="score-factors small text-muted">
                Based on failed logins, replay attempts, policy triggers, token misuse, and reputation risk.
            </div>
        </div>

        <div class="status-strip mt-3">
            <div>✔ Logins today: <strong>@LoginsToday</strong></div>
            <div>⚠ Blocked attempts: <strong>@BlockedAttempts</strong></div>
            <div>🛡 Policies triggered: <strong>@PoliciesTriggered</strong></div>
            <div>🚨 Critical alerts: <strong>@CriticalAlerts</strong></div>
        </div>
    </div>
</section>

<section class="dashboard-security-grid">
    <div class="widget">
        <div class="widget-header">
            <h3>Recent Security Events</h3>
            @if (!AdminContext.MockModeEnabled)
            {
                <span class="widget-label @( _activityDegraded ? "degraded" : "live")">@(_activityDegraded ? "Degraded" : "Live")</span>
            }
        </div>
        <div class="widget-content">
            @foreach (var e in RecentEvents)
            {
                <div class="event-row">
                    <span class="event-time">@e.Time</span>
                    <span class="event-icon">@e.Icon</span>
                    <span>@e.Text</span>
                </div>
            }
        </div>
    </div>

    <div class="widget">
        <div class="widget-header">
            <h3>Threat Monitor (24h)</h3>
            @if (ThreatTrendUsesDemoData)
            {
                <span class="widget-label">Demo Trend</span>
            }
        </div>
        <div class="widget-content">
            <div class="metric-line">Blocked logins: <strong>@BlockedAttempts</strong></div>
            <div class="metric-line">Replay attempts: <strong>@ReplayAttempts</strong></div>
            <div class="metric-line">Spam events: <strong>@SpamEvents</strong></div>
            <div class="metric-line">Policy violations: <strong>@PoliciesTriggered</strong></div>

            <div class="mini-bars mt-3">
                @foreach (var d in BlockedByDay)
                {
                    <div class="mini-bar-row">
                        <span>@d.Day</span>
                        <div class="mini-bar"><span style="width:@(Math.Max(6, d.Count * 22))px"></span></div>
                        <strong>@d.Count</strong>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="widget">
        <div class="widget-header">
            <h3>Reputation Watch</h3>
            @if (!AdminContext.MockModeEnabled)
            {
                <span class="widget-label @( _reputationDegraded ? "degraded" : "live")">@(_reputationDegraded ? "Degraded" : "Live")</span>
            }
        </div>
        <div class="widget-content">
            @foreach (var u in ReputationWatch)
            {
                <a href="/admin/reputation" class="rep-row">
                    <span>@u.IdentityId</span>
                    <span>Score: <strong>@u.Score</strong> @ScoreIcon(u.Score)</span>
                </a>
            }
        </div>
    </div>

    <div class="widget">
        <div class="widget-header">
            <h3>Activity (24h)</h3>
            @if (ActivityGraphUsesDemoData)
            {
                <span class="widget-label">Demo Graph</span>
            }
        </div>
        <div class="widget-content">
            <div class="activity-line"><span>Logins</span><div class="activity-bar"><span style="width:88%"></span></div></div>
            <div class="activity-line"><span>Security Events</span><div class="activity-bar"><span style="width:30%"></span></div></div>
            <div class="activity-line"><span>Policy Triggers</span><div class="activity-bar"><span style="width:22%"></span></div></div>
            <div class="activity-line"><span>Blocked Attempts</span><div class="activity-bar"><span style="width:16%"></span></div></div>
        </div>
    </div>
</section>

<section class="dashboard-security-grid mt-3">
    <div class="widget">
        <div class="widget-header">
            <h3>Security Insights</h3>
            @if (InsightsUseDemoData)
            {
                <span class="widget-label">Demo Insight</span>
            }
        </div>
        <div class="widget-content small">
            <div>System operating normally.</div>
            <div>@BlockedAttempts login attempts were blocked today.</div>
            <div>@(ReplayAttempts == 0 ? "No replay attacks detected." : $"{ReplayAttempts} replay attempts detected.")</div>
            <div>User reputation levels are stable.</div>
        </div>
    </div>

    <div class="widget">
        <div class="widget-header"><h3>Quick Actions</h3></div>
        <div class="widget-content quick-actions">
            <a class="btn btn-outline-secondary" href="/admin/audit-logs">View Audit Logs</a>
            <a class="btn btn-outline-secondary" href="/admin/users-devices">Investigate User</a>
            <a class="btn btn-outline-secondary" href="/admin/policy-rules">Review Security Policies</a>
            <a class="btn btn-outline-secondary" href="/admin/security-status">Export Security Report</a>
        </div>
    </div>
</section>

@code {
    private List<DashboardMetric> _metrics = [];
    private List<ActivityItem> _activity = [];
    private List<ReputationWatchItem> _reputationWatch = [];
    private string? _error;

    private bool _metricsDegraded;
    private bool _activityDegraded;
    private bool _reputationDegraded;
    private readonly List<string> _degradedSources = [];
    private System.Threading.Timer? _refreshTimer;
    private const int RefreshIntervalSeconds = 30;
    private int _refreshCountdown = RefreshIntervalSeconds;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();

        _refreshTimer = new System.Threading.Timer(
            async _ => await InvokeAsync(TickRefreshAsync),
            null,
            TimeSpan.FromSeconds(1),
            TimeSpan.FromSeconds(1));
    }

    private async Task LoadDashboardAsync()
    {
        var metrics = await Api.GetDashboardMetricsAsync();
        var activity = await Api.GetActivityAsync();
        var reputation = await Api.GetTopRiskIdentitiesAsync();

        _metricsDegraded = !metrics.Success;
        _activityDegraded = !activity.Success;
        _reputationDegraded = !reputation.Success;

        if (metrics.Success && metrics.Data is not null)
        {
            _metrics = metrics.Data;
        }

        if (activity.Success && activity.Data is not null)
        {
            _activity = activity.Data;
        }

        if (reputation.Success && reputation.Data is not null)
        {
            _reputationWatch = reputation.Data;
        }

        _degradedSources.Clear();
        if (_metricsDegraded && !string.IsNullOrWhiteSpace(metrics.Error)) _degradedSources.Add(metrics.Error!);
        if (_activityDegraded && !string.IsNullOrWhiteSpace(activity.Error)) _degradedSources.Add(activity.Error!);
        if (_reputationDegraded && !string.IsNullOrWhiteSpace(reputation.Error)) _degradedSources.Add(reputation.Error!);

        _error = !_metricsDegraded && !_activityDegraded
            ? null
            : (_degradedSources.FirstOrDefault() ?? "One or more data sources failed.");
    }

    private async Task TickRefreshAsync()
    {
        _refreshCountdown--;

        if (_refreshCountdown > 0)
        {
            StateHasChanged();
            return;
        }

        _refreshCountdown = RefreshIntervalSeconds;
        await LoadDashboardAsync();
        StateHasChanged();
    }

    private int SecurityScore => GetMetricByTitle("Security Score", 92);
    private int LoginsToday => GetMetricInt("login", 48);
    private int BlockedAttempts => GetMetricByTitle("Blocked Attempts", CountActivity("block", 3));
    private int PoliciesTriggered => CountActivity("policy", Math.Max(0, BlockedAttempts));
    private int CriticalAlerts => CountActivity("critical", 0);
    private int ReplayAttempts => GetMetricByTitle("Replay Detections", CountActivity("replay", 0));
    private int SpamEvents => GetMetricByTitle("Expired Messages", CountActivity("expired", 1));

    private string ScoreLabel => SecurityScore switch
    {
        >= 90 => "Secure",
        >= 70 => "Attention",
        >= 50 => "Risk",
        _ => "Critical"
    };

    private string ScoreEmoji => SecurityScore switch
    {
        >= 90 => "🟢",
        >= 70 => "🟡",
        >= 50 => "🟠",
        _ => "🔴"
    };

    private string ScoreClass => SecurityScore switch
    {
        >= 90 => "score-secure",
        >= 70 => "score-attention",
        >= 50 => "score-risk",
        _ => "score-critical"
    };

    private bool ThreatTrendUsesDemoData => true;
    private bool ActivityGraphUsesDemoData => true;
    private bool InsightsUseDemoData => true;

    private List<(string Day, int Count)> BlockedByDay =>
    [
        ("Mon", 1),
        ("Tue", 0),
        ("Wed", 3),
        ("Thu", 2)
    ];

    private List<(string Time, string Icon, string Text)> RecentEvents
    {
        get
        {
            if (_activity.Count == 0)
            {
                return
                [
                    ("00:31", "✔", "User login succeeded"),
                    ("00:22", "✔", "Admin login succeeded"),
                    ("00:13", "⚠", "Security policy triggered"),
                    ("23:55", "❌", "Login attempt blocked"),
                    ("23:19", "🚨", "Token replay detected")
                ];
            }

            return _activity.Take(5).Select(x =>
            {
                var text = x.Action;
                var icon = text.Contains("block", StringComparison.OrdinalIgnoreCase) ? "❌"
                    : text.Contains("policy", StringComparison.OrdinalIgnoreCase) ? "⚠"
                    : text.Contains("replay", StringComparison.OrdinalIgnoreCase) ? "🚨"
                    : "✔";
                return (x.Timestamp.ToLocalTime().ToString("HH:mm"), icon, text);
            }).ToList();
        }
    }

    private List<ReputationWatchItem> ReputationWatch => _reputationWatch.Count > 0
        ? _reputationWatch
        :
        [
            new ReputationWatchItem { IdentityId = "support@hip.local", Score = 52, Blocked = 1, Review = 3 },
            new ReputationWatchItem { IdentityId = "admin@hip.local", Score = 81, Blocked = 0, Review = 1 },
            new ReputationWatchItem { IdentityId = "guest@hip.local", Score = 34, Blocked = 3, Review = 2 }
        ];

    private int GetMetricInt(string keyword, int fallback)
    {
        var raw = _metrics.FirstOrDefault(m => m.Title.Contains(keyword, StringComparison.OrdinalIgnoreCase))?.Value;
        if (string.IsNullOrWhiteSpace(raw)) return fallback;

        var digits = new string(raw.Where(char.IsDigit).ToArray());
        return int.TryParse(digits, out var n) ? n : fallback;
    }

    private int GetMetricByTitle(string title, int fallback)
    {
        var raw = _metrics.FirstOrDefault(m => string.Equals(m.Title, title, StringComparison.OrdinalIgnoreCase))?.Value;
        if (string.IsNullOrWhiteSpace(raw)) return fallback;

        var digits = new string(raw.Where(char.IsDigit).ToArray());
        return int.TryParse(digits, out var n) ? n : fallback;
    }

    private static string ScoreIcon(int score) => score switch
    {
        >= 80 => "✔",
        >= 50 => "⚠",
        _ => "🚨"
    };

    private int CountActivity(string keyword, int fallback)
    {
        if (_activity.Count == 0) return fallback;
        var count = _activity.Count(x => x.Action.Contains(keyword, StringComparison.OrdinalIgnoreCase));
        return count;
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
