@page "/"
@attribute [Authorize]
@inject HipAdminApiClient Api
@implements IDisposable

<PageTitle>Security Overview</PageTitle>

<PageHeader Title="Security Overview"
            Subtitle="Protection Summary · live API-backed snapshot"
            LastUpdatedUtc="@_lastUpdatedUtc"
            Breadcrumbs="@_breadcrumbs">
    <Actions>
        <div class="d-flex align-items-center gap-2 me-2 small">
            <span class="badge @(IsLive ? "text-bg-success" : "text-bg-secondary")">@(IsLive ? "Live" : "Idle")</span>
            <div class="form-check form-switch m-0">
                <input id="overview-auto-refresh" class="form-check-input" type="checkbox" @bind="_autoRefresh" />
                <label class="form-check-label" for="overview-auto-refresh">Auto</label>
            </div>
        </div>
        <button type="button" class="btn btn-outline-secondary" @onclick="ReloadAsync">Refresh</button>
    </Actions>
</PageHeader>

@if (_state == StateViewMode.Error)
{
    <AlertBanner Kind="AlertBannerKind.Error" Title="Security Overview unavailable" Message="@_error" />
}

@if (_state != StateViewMode.Error)
{
    <section class="card p-3 mb-3 border-2 @GlobalStatusClass" aria-label="Global security status">
        <div class="d-flex justify-content-between flex-wrap gap-2 align-items-center">
            <div>
                <h2 class="h5 mb-1">@GlobalStatusIcon @GlobalStatusLabel</h2>
                <p class="mb-0 text-muted">@_statusBannerMessage</p>
                <div class="small text-muted mt-1">source: /api/admin/security-status + /api/v1/admin/audit</div>
            </div>
            <div class="small">
                <div><strong>Active protections:</strong> @(_activePoliciesAvailable ? _activePolicies : "No live data yet")</div>
                <div><strong>Threats blocked:</strong> @(_statusAvailable ? _blockedAttempts : "No live data yet")</div>
                <div><strong>Critical threats:</strong> @(_incidentsAvailable ? CriticalThreatCount : "No live data yet")</div>
                <div><strong>Last event:</strong> @(_incidentsAvailable ? LastEventAgo : "No live data yet")</div>
            </div>
        </div>
    </section>
}

<FilterBar SearchText="@_searchText"
           SearchTextChanged="OnSearchTextChanged"
           SearchPlaceholder="Search security activity"
           Fields="@_filters"
           OnChanged="OnFiltersChanged">
    <Actions>
        <button type="button" class="btn btn-primary" @onclick="ReloadAsync">Apply</button>
    </Actions>
</FilterBar>

<StateView Mode="@_state" EmptyMessage="No security activity has been recorded yet." FilteredMessage="No activity matches the current filter set." ErrorMessage="@_error" OnRetry="ReloadAsync">
    <div class="hip-overview-metrics">
        @foreach (var metric in _topKpis)
        {
            <MetricCard Title="@metric.Title"
                        Value="@metric.Value"
                        TrendLabel="@metric.Delta"
                        TrendDirection="@metric.Trend"
                        Status="@GetKpiStatus(metric.Title)"
                        AssistiveText="Current day snapshot"
                        Tooltip="@GetKpiTooltip(metric.Title)" />
        }
    </div>

    <section class="dashboard-security-grid">
        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>Security Trends</h3></div>
            <div class="widget-content">
                @if (!_statusAvailable)
                {
                    <div class="text-muted">No live data yet</div>
                }
                else
                {
                    <div class="activity-line"><span>Blocked attempts</span><div class="activity-bar"><span style="width:@BlockedAttemptsBar"></span></div></div>
                    <div class="activity-line"><span>Replay detections</span><div class="activity-bar"><span style="width:@ReplayBar"></span></div></div>
                    <div class="activity-line"><span>Expired messages</span><div class="activity-bar"><span style="width:@ExpiredBar"></span></div></div>
                }
                <div class="text-muted small mt-2">source: /api/admin/security-status</div>
            </div>
        </section>

        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>Attack Visualization</h3></div>
            <div class="widget-content small">
                <div class="text-muted">Unavailable (no backend endpoint mapped for geo/origin attack map).</div>
                <div class="text-muted small mt-2">source: unavailable</div>
            </div>
        </section>

        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>Risk Heatmap</h3></div>
            <div class="widget-content small">
                <div class="text-muted">Unavailable (no backend endpoint mapped for risk heatmap).</div>
                <div class="text-muted small mt-2">source: unavailable</div>
            </div>
        </section>

        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>Device Trust Panel</h3></div>
            <div class="widget-content small">
                @if (!_usersDevicesAvailable)
                {
                    <div class="text-muted">No live data yet</div>
                }
                else
                {
                    <div>Trusted/compliant devices: <strong>@_trustedDevices</strong></div>
                    <div>Devices flagged for review: <strong>@_flaggedDevices</strong></div>
                    <div>Total tracked devices: <strong>@_totalDevices</strong></div>
                }
                <div class="text-muted small mt-2">source: /api/v1/admin/users-devices</div>
            </div>
        </section>

        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>User Trust Radar</h3></div>
            <div class="widget-content small">
                <div class="text-muted">Unavailable (no backend endpoint mapped for trust radar scoring).</div>
                <div class="text-muted small mt-2">source: unavailable</div>
            </div>
        </section>

        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>Overall Risk Level</h3></div>
            <div class="widget-content">
                <div class="text-muted">Unavailable (risk score endpoint not available).</div>
                <div class="text-muted small mt-2">source: unavailable</div>
            </div>
        </section>

        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>Protection Checks</h3></div>
            <div class="widget-content small">
                @if (!_statusAvailable)
                {
                    <div class="text-muted">No live data yet</div>
                }
                else
                {
                    <div>Replay protection: <StatusBadge Severity="@(_replayDetections > 0 ? SeverityLevel.Medium : SeverityLevel.Low)" /> (@_replayDetections)</div>
                    <div>Token expiry enforcement: <StatusBadge Severity="@(_expiredMessages > 0 ? SeverityLevel.Medium : SeverityLevel.Low)" /> (@_expiredMessages)</div>
                    <div>Policy blocking: <StatusBadge Severity="@(_blockedAttempts > 0 ? SeverityLevel.High : SeverityLevel.Low)" /> (@_blockedAttempts)</div>
                }
                <div class="text-muted small mt-2">source: /api/admin/security-status</div>
            </div>
        </section>

        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>Simulator Quick Actions</h3></div>
            <div class="widget-content quick-actions">
                <a class="btn btn-outline-secondary" href="/admin/simulator">Open Simulator</a>
                <a class="btn btn-outline-secondary" href="/admin/simulator">Run Campaign</a>
            </div>
        </section>

        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>Incident Alerts</h3></div>
            <div class="widget-content small">
                @if (!_incidentsAvailable)
                {
                    <div class="text-muted">No live data yet</div>
                }
                else
                {
                    @if (ActiveAlerts.Count == 0)
                    {
                        <div class="text-muted">No urgent incidents right now.</div>
                    }
                    else
                    {
                        @foreach (var item in ActiveAlerts)
                        {
                            <div class="py-1 border-bottom">
                                <div class="fw-semibold">⚠ @HumanizeEvent(item.EventType)</div>
                                <div class="text-muted">@item.Actor · @FormatRelativeTime(item.Timestamp)</div>
                            </div>
                        }
                    }
                }
                <div class="text-muted small mt-2">source: /api/v1/admin/audit (fallback /api/admin/audit)</div>
            </div>
        </section>

        <section class="widget widget-table table-widget-frame">
            <div class="widget-header"><h3>Real-Time Event Feed</h3></div>
            <div class="widget-content small">
                @if (!_incidentsAvailable)
                {
                    <div class="text-muted">No live data yet</div>
                }
                else if (_incidents.Count == 0)
                {
                    <div class="text-muted">No recent security activity yet.</div>
                }
                else
                {
                    @foreach (var item in _incidents.Take(5))
                    {
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <div>
                                <div class="fw-semibold">@HumanizeEvent(item.EventType)</div>
                                <div class="text-muted">@item.Actor</div>
                            </div>
                            <div class="text-muted">@FormatRelativeTime(item.Timestamp)</div>
                        </div>
                    }
                }
                <div class="text-muted small mt-2">source: /api/v1/admin/audit (fallback /api/admin/audit)</div>
            </div>
        </section>
    </section>

    <DataTable TItem="AuditLogEntry"
               Title="Security Activity"
               Caption="Story-friendly timeline for what happened, who was affected, and the outcome"
               Items="@_filteredIncidents"
               Columns="@_incidentColumns"
               EmptyMessage="No security activity for this filter."
               ShowSearch="false"
               ShowPagination="true" />
</StateView>

@code {
    private IReadOnlyList<BreadcrumbItem> _breadcrumbs = [new("Security Overview", "/")];
    private readonly List<DashboardMetric> _topKpis = [];
    private readonly List<AuditLogEntry> _incidents = [];
    private List<AuditLogEntry> _filteredIncidents = [];
    private DateTimeOffset? _lastUpdatedUtc;
    private StateViewMode _state = StateViewMode.Loading;
    private string _error = "Please try again.";
    private string _searchText = string.Empty;

    private string _statusBannerMessage = "No live data yet.";

    private int _blockedAttempts;
    private int _replayDetections;
    private int _expiredMessages;
    private int _activePolicies;
    private bool _statusAvailable;
    private bool _incidentsAvailable;
    private bool _usersDevicesAvailable;
    private bool _activePoliciesAvailable;
    private int _totalDevices;
    private int _trustedDevices;
    private int _flaggedDevices;

    private bool _autoRefresh = true;
    private PeriodicTimer? _timer;
    private bool IsLive => _autoRefresh && _lastUpdatedUtc is not null && DateTimeOffset.UtcNow - _lastUpdatedUtc.Value < TimeSpan.FromSeconds(40);

    private readonly List<FilterField> _filters =
    [
        new()
        {
            Key = "severity",
            Label = "Severity",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "All severities" },
                new FilterFieldOption { Value = "critical", Label = "Critical" },
                new FilterFieldOption { Value = "warning", Label = "Warning" },
                new FilterFieldOption { Value = "info", Label = "Info" }
            ]
        },
        new()
        {
            Key = "result",
            Label = "Result",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "Any result" },
                new FilterFieldOption { Value = "denied", Label = "Denied" },
                new FilterFieldOption { Value = "review", Label = "Review" },
                new FilterFieldOption { Value = "success", Label = "Success" }
            ]
        }
    ];

    private readonly IReadOnlyList<DataTableColumn<AuditLogEntry>> _incidentColumns =
    [
        new() { Header = "When", CellTemplate = row => @<div><div>@FormatRelativeTime(row.Timestamp)</div><div class="small text-muted">@FormatAbsoluteTime(row.Timestamp)</div></div>, SortSelector = x => x.Timestamp },
        new() { Header = "Who", ValueSelector = x => x.Actor, SortSelector = x => x.Actor },
        new() { Header = "What happened", ValueSelector = x => HumanizeEvent(x.EventType), SortSelector = x => x.EventType },
        new() { Header = "Severity", CellTemplate = row => @<StatusBadge Severity="@AdminUiSemantics.ParseSeverity(row.Severity, row.Result)" />, SortSelector = x => x.Severity },
        new() { Header = "Outcome", CellTemplate = row => @<StatusBadge Status="@MapResultToWorkflow(row.Result)" />, SortSelector = x => x.Result },
        new() { Header = "Story note", ValueSelector = x => x.Detail, SortSelector = x => x.Detail }
    ];

    private IReadOnlyList<AuditLogEntry> ActiveAlerts => _incidents
        .Where(x => x.Result.Equals("Denied", StringComparison.OrdinalIgnoreCase)
                 || x.Result.Equals("Review", StringComparison.OrdinalIgnoreCase)
                 || x.Severity.Equals("critical", StringComparison.OrdinalIgnoreCase))
        .Take(4)
        .ToList();

    private int ActiveAlertCount => ActiveAlerts.Count;

    private int CriticalThreatCount => _incidents.Count(x => x.Severity.Equals("critical", StringComparison.OrdinalIgnoreCase)
                                                         || x.EventType.Contains("takeover", StringComparison.OrdinalIgnoreCase)
                                                         || x.EventType.Contains("impossible_travel", StringComparison.OrdinalIgnoreCase));
    private string LastEventAgo => _incidents.Count == 0 ? "No events yet" : FormatRelativeTime(_incidents.Max(x => x.Timestamp));

    private string GlobalStatusIcon => !_statusAvailable ? "⚪" : (_blockedAttempts + _replayDetections + _expiredMessages) == 0 ? "🟢" : "🟡";
    private string GlobalStatusLabel => !_statusAvailable ? "Status Unavailable" : (_blockedAttempts + _replayDetections + _expiredMessages) == 0 ? "System Secure" : "Security Alerts Active";
    private string GlobalStatusClass => !_statusAvailable ? "border-secondary" : (_blockedAttempts + _replayDetections + _expiredMessages) == 0 ? "border-success" : "border-warning";

    private string BlockedAttemptsBar => BarFromLiveCounts(_blockedAttempts, _replayDetections, _expiredMessages);
    private string ReplayBar => BarFromLiveCounts(_replayDetections, _blockedAttempts, _expiredMessages);
    private string ExpiredBar => BarFromLiveCounts(_expiredMessages, _blockedAttempts, _replayDetections);

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
        _ = RunAutoRefreshAsync();
    }

    private async Task RunAutoRefreshAsync()
    {
        if (_timer is null)
        {
            return;
        }

        while (await _timer.WaitForNextTickAsync())
        {
            if (!_autoRefresh)
            {
                continue;
            }

            await ReloadAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadAsync()
    {
        _state = StateViewMode.Loading;
        _error = "Please try again.";

        var metricsTask = Api.GetDashboardMetricsAsync();
        var incidentsTask = Api.GetAuditLogsAsync();
        var policyRulesTask = Api.GetPolicyRulesAsync();
        var usersDevicesTask = Api.GetUsersDevicesAsync();

        await Task.WhenAll(metricsTask, incidentsTask, policyRulesTask, usersDevicesTask);

        var metrics = metricsTask.Result;
        var incidents = incidentsTask.Result;
        var policyRules = policyRulesTask.Result;
        var usersDevices = usersDevicesTask.Result;

        _topKpis.Clear();
        _incidents.Clear();

        _statusAvailable = metrics.Success && metrics.Data is { Count: > 0 };
        _incidentsAvailable = incidents.Success;
        _activePoliciesAvailable = policyRules.Success && policyRules.Data is not null;
        _usersDevicesAvailable = usersDevices.Success && usersDevices.Data is not null;

        _activePolicies = _activePoliciesAvailable && policyRules.Data is { Count: > 0 }
            ? policyRules.Data.Count(x => x.Enabled)
            : 0;

        if (_statusAvailable)
        {
            HydrateStatusMetrics(metrics.Data!);
        }
        else
        {
            _blockedAttempts = 0;
            _replayDetections = 0;
            _expiredMessages = 0;
        }

        if (_incidentsAvailable && incidents.Data is { Count: > 0 })
        {
            _incidents.AddRange(incidents.Data.Take(25));
        }

        if (_usersDevicesAvailable && usersDevices.Data is { Count: > 0 })
        {
            _totalDevices = usersDevices.Data.Count;
            _trustedDevices = usersDevices.Data.Count(x => x.DeviceStatus.Equals("Compliant", StringComparison.OrdinalIgnoreCase)
                                                       || x.DeviceStatus.Equals("Trusted", StringComparison.OrdinalIgnoreCase));
            _flaggedDevices = usersDevices.Data.Count(x => x.DeviceStatus.Equals("Pending", StringComparison.OrdinalIgnoreCase)
                                                       || x.DeviceStatus.Equals("Blocked", StringComparison.OrdinalIgnoreCase)
                                                       || x.DeviceStatus.Equals("Review", StringComparison.OrdinalIgnoreCase));
        }
        else
        {
            _totalDevices = 0;
            _trustedDevices = 0;
            _flaggedDevices = 0;
        }

        BuildKpis();
        BuildStatusBanner();

        ApplyFilters(new FilterBarChangeSet
        {
            SearchText = _searchText,
            Values = _filters.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase)
        });

        _lastUpdatedUtc = DateTimeOffset.UtcNow;

        if (!_statusAvailable && !_incidentsAvailable && !_activePoliciesAvailable && !_usersDevicesAvailable)
        {
            _state = StateViewMode.Error;
            _error = string.Join(" ", new[] { metrics.Error, incidents.Error, policyRules.Error, usersDevices.Error }.Where(x => !string.IsNullOrWhiteSpace(x)));
            return;
        }

        _state = _incidents.Count == 0
            ? StateViewMode.EmptyTrue
            : _filteredIncidents.Count == 0
                ? StateViewMode.EmptyFiltered
                : StateViewMode.Success;
    }

    private void HydrateStatusMetrics(IReadOnlyCollection<DashboardMetric> metrics)
    {
        var blockedMetric = metrics.FirstOrDefault(x => x.Title.Contains("Blocked", StringComparison.OrdinalIgnoreCase));
        var replayMetric = metrics.FirstOrDefault(x => x.Title.Contains("Replay", StringComparison.OrdinalIgnoreCase));
        var expiredMetric = metrics.FirstOrDefault(x => x.Title.Contains("Expired", StringComparison.OrdinalIgnoreCase));

        _blockedAttempts = ParseInt(blockedMetric?.Value);
        _replayDetections = ParseInt(replayMetric?.Value);
        _expiredMessages = ParseInt(expiredMetric?.Value);
    }

    private void BuildKpis()
    {
        _topKpis.AddRange(
        [
            new DashboardMetric { Title = "Active Protections", Value = _activePoliciesAvailable ? _activePolicies.ToString() : "No live data yet", Delta = "/api/v1/admin/policy", Trend = _activePolicies > 0 ? "up" : "down" },
            new DashboardMetric { Title = "Threats Blocked", Value = _statusAvailable ? _blockedAttempts.ToString() : "No live data yet", Delta = "/api/admin/security-status", Trend = _blockedAttempts == 0 ? "up" : "down" },
            new DashboardMetric { Title = "Replay / Expired", Value = _statusAvailable ? $"{_replayDetections} / {_expiredMessages}" : "No live data yet", Delta = "/api/admin/security-status", Trend = (_replayDetections + _expiredMessages) == 0 ? "up" : "down" },
            new DashboardMetric { Title = "Active Alerts", Value = _incidentsAvailable ? ActiveAlertCount.ToString() : "No live data yet", Delta = "/api/v1/admin/audit", Trend = ActiveAlertCount == 0 ? "up" : "down" }
        ]);
    }

    private void BuildStatusBanner()
    {
        if (!_statusAvailable)
        {
            _statusBannerMessage = "No live security status yet.";
            return;
        }

        var totalSignals = _blockedAttempts + _replayDetections + _expiredMessages;
        if (totalSignals == 0)
        {
            _statusBannerMessage = "All reported protections are quiet right now.";
            return;
        }

        _statusBannerMessage = "Live security signals detected. Review active alerts and event feed.";
    }

    private Task OnSearchTextChanged(string text)
    {
        _searchText = text;
        return Task.CompletedTask;
    }

    private Task OnFiltersChanged(FilterBarChangeSet changeSet)
    {
        ApplyFilters(changeSet);
        _state = _incidents.Count == 0
            ? StateViewMode.EmptyTrue
            : _filteredIncidents.Count == 0
                ? StateViewMode.EmptyFiltered
                : StateViewMode.Success;
        return Task.CompletedTask;
    }

    private void ApplyFilters(FilterBarChangeSet changeSet)
    {
        var severity = changeSet.Values.TryGetValue("severity", out var severityValue) ? severityValue : "all";
        var result = changeSet.Values.TryGetValue("result", out var resultValue) ? resultValue : "all";

        _filteredIncidents = _incidents
            .Where(x => string.IsNullOrWhiteSpace(changeSet.SearchText)
                        || x.Actor.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.EventType.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.Detail.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase))
            .Where(x => severity is null || severity == "all" || x.Severity.Equals(severity, StringComparison.OrdinalIgnoreCase))
            .Where(x => result is null || result == "all" || x.Result.Equals(result, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => x.Timestamp)
            .ToList();
    }

    private static int ParseInt(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return 0;
        }

        var digits = new string(value.Where(char.IsDigit).ToArray());
        return int.TryParse(digits, out var parsed) ? parsed : 0;
    }

    private static string BarFromLiveCounts(int primary, params int[] other)
    {
        var max = Math.Max(1, new[] { primary }.Concat(other).Max());
        var width = Math.Clamp((int)Math.Round((primary / (double)max) * 100), 10, 100);
        return $"{width}%";
    }

    private static string FormatRelativeTime(DateTime timestamp)
    {
        var utc = timestamp.Kind == DateTimeKind.Utc ? timestamp : timestamp.ToUniversalTime();
        var delta = DateTime.UtcNow - utc;

        if (delta.TotalMinutes < 1) return "just now";
        if (delta.TotalHours < 1)
        {
            var minutes = Math.Max(1, (int)delta.TotalMinutes);
            return minutes == 1 ? "1 minute ago" : $"{minutes} minutes ago";
        }

        if (delta.TotalDays < 1)
        {
            var hours = Math.Max(1, (int)delta.TotalHours);
            return hours == 1 ? "1 hour ago" : $"{hours} hours ago";
        }

        if (delta.TotalDays < 7)
        {
            var days = Math.Max(1, (int)delta.TotalDays);
            return days == 1 ? "1 day ago" : $"{days} days ago";
        }
        return utc.ToLocalTime().ToString("MMM d");
    }

    private static string FormatAbsoluteTime(DateTime timestamp)
    {
        var utc = timestamp.Kind == DateTimeKind.Utc ? timestamp : timestamp.ToUniversalTime();
        return utc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz");
    }

    private WorkflowStatus GetKpiStatus(string title)
        => title switch
        {
            "Active Protections" => _activePoliciesAvailable ? WorkflowStatus.Resolved : WorkflowStatus.New,
            "Threats Blocked" => !_statusAvailable ? WorkflowStatus.New : (_blockedAttempts == 0 ? WorkflowStatus.Resolved : WorkflowStatus.Mitigated),
            "Replay / Expired" => !_statusAvailable ? WorkflowStatus.New : ((_replayDetections + _expiredMessages) == 0 ? WorkflowStatus.Resolved : WorkflowStatus.Investigating),
            "Active Alerts" => !_incidentsAvailable ? WorkflowStatus.New : (ActiveAlertCount == 0 ? WorkflowStatus.Resolved : WorkflowStatus.Investigating),
            _ => WorkflowStatus.InProgress
        };

    private static string GetKpiTooltip(string title)
        => title switch
        {
            "Active Protections" => "Enabled policy protections from /api/v1/admin/policy.",
            "Threats Blocked" => "Policy-blocked attempts from /api/admin/security-status.",
            "Replay / Expired" => "Replay and expiry counters from /api/admin/security-status.",
            "Active Alerts" => "Denied/review/critical entries from /api/v1/admin/audit.",
            _ => "Security snapshot metric."
        };

    private static WorkflowStatus MapResultToWorkflow(string? result)
        => result?.ToLowerInvariant() switch
        {
            "denied" => WorkflowStatus.Failed,
            "review" => WorkflowStatus.InProgress,
            "success" => WorkflowStatus.Resolved,
            _ => WorkflowStatus.New
        };

    private static string HumanizeEvent(string eventType)
        => eventType.ToUpperInvariant() switch
        {
            "SESSION_IP_CHANGE" => "Session IP changed (possible session hijack attempt)",
            "REPLAY_ATTEMPT_DETECTED" => "Someone tried to reuse an old login token",
            _ => eventType.Replace('_', ' ').Replace('.', ' ')
        };

    public void Dispose() => _timer?.Dispose();
}
