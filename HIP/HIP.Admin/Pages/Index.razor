@page "/"
@inject HipAdminApiClient Api

<PageTitle>Dashboard</PageTitle>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<section class="kpi-grid mb-3">
    @foreach (var metric in _metrics)
    {
        <StatCard Title="@metric.Title" Value="@metric.Value" Delta="@metric.Delta" Trend="@metric.Trend" />
    }
</section>

<section class="row g-3 mb-3">
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="panel-title">Policy Pack <NewBadge AddedUtc="@NewFeatureAddedUtc" /></h5>
                @if (_policyPack is not null)
                {
                    <div class="small text-muted mb-1">@_policyPack.Name</div>
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="badge text-bg-secondary">v@_policyPack.Version</span>
                        <span class="small">Enabled rules: <strong>@_policyPack.EnabledRules</strong></span>
                    </div>
                    <div class="small text-muted">Last updated: @_policyPack.LastUpdatedUtc.ToLocalTime()</div>
                }
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="panel-title">CPU / Memory Usage <NewBadge AddedUtc="@NewFeatureAddedUtc" /></h5>
                @if (_usage is not null)
                {
                    <div class="d-flex justify-content-between mb-1"><span>CPU</span><strong>@_usage.CpuPercent.ToString("0.0")%</strong></div>
                    <div class="progress mb-2" style="height:8px;"><div class="progress-bar" role="progressbar" style="width:@($"{_usage.CpuPercent:0.0}%")"></div></div>
                    <div class="d-flex justify-content-between mb-1"><span>Memory</span><strong>@_usage.MemoryUsedGb.ToString("0.0") / @_usage.MemoryTotalGb.ToString("0.0") GB</strong></div>
                    <div class="progress mb-2" style="height:8px;"><div class="progress-bar bg-info" role="progressbar" style="width:@($"{(_usage.MemoryUsedGb / _usage.MemoryTotalGb * 100):0.0}%")"></div></div>
                    @if (_usage.DiskPercent is not null)
                    {
                        <div class="small text-muted">Disk: @_usage.DiskPercent.Value.ToString("0.0")%</div>
                    }
                    <div class="small text-muted">Sampled: @_usage.SampledUtc.ToLocalTime()</div>
                }
            </div>
        </div>
    </div>
</section>

<section class="dashboard-main-grid">
    <div class="card h-100 panel-requests">
        <div class="card-body">
            <h5 class="panel-title">Requests Trend</h5>
            <div class="chart-placeholder text-center text-muted">Mock chart area</div>
        </div>
    </div>

    <div class="card h-100 panel-policy">
        <div class="card-body">
            <h5 class="panel-title">Policy Blocks Trend</h5>
            <div class="chart-placeholder text-center text-muted">Mock chart area</div>
        </div>
    </div>

    <div class="card h-100 panel-activity">
        <div class="card-body">
            <h5 class="panel-title">Latest Activity</h5>
            @foreach (var item in _activity)
            {
                <div class="activity-item border-bottom py-2">
                    <div class="small fw-semibold">@item.Action</div>
                    <div class="small text-muted">@item.Actor · @item.Timestamp.ToLocalTime()</div>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private static readonly DateTime NewFeatureAddedUtc = new(2026, 3, 4, 22, 23, 0, DateTimeKind.Utc);

    private List<DashboardMetric> _metrics = [];
    private List<ActivityItem> _activity = [];
    private PolicyPackSummary? _policyPack;
    private SystemUsageSummary? _usage;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var metrics = await Api.GetDashboardMetricsAsync();
        var activity = await Api.GetActivityAsync();
        var policyPack = await Api.GetPolicyPackSummaryAsync();
        var usage = await Api.GetSystemUsageSummaryAsync();

        _error = metrics.Error ?? activity.Error ?? policyPack.Error ?? usage.Error;
        _metrics = metrics.Data ?? [];
        _activity = activity.Data ?? [];
        _policyPack = policyPack.Data;
        _usage = usage.Data;
    }
}
