@page "/"
@inject HipAdminApiClient Api

<PageTitle>Dashboard</PageTitle>

<PageHeader Title="Dashboard"
            Subtitle="Quick security snapshot for your team"
            LastUpdatedUtc="@_lastUpdatedUtc"
            Breadcrumbs="@_breadcrumbs">
    <Actions>
        <button type="button" class="btn btn-outline-secondary" @onclick="ReloadAsync">Refresh</button>
    </Actions>
</PageHeader>

@if (_state == StateViewMode.Error)
{
    <AlertBanner Kind="AlertBannerKind.Error" Title="Dashboard unavailable" Message="@_error" />
}

<FilterBar SearchText="@_searchText"
           SearchTextChanged="OnSearchTextChanged"
           SearchPlaceholder="Search incidents"
           Fields="@_filters"
           OnChanged="OnFiltersChanged">
    <Actions>
        <button type="button" class="btn btn-primary" @onclick="ReloadAsync">Apply</button>
    </Actions>
</FilterBar>

<StateView Mode="@_state" EmptyMessage="No incidents have been recorded yet." FilteredMessage="No incidents match the current filter set." ErrorMessage="@_error" OnRetry="ReloadAsync">
    <div class="hip-overview-metrics">
        @foreach (var metric in _metricCards)
        {
            <MetricCard Title="@metric.Title"
                        Value="@metric.Value"
                        TrendLabel="@metric.Delta"
                        TrendDirection="@metric.Trend"
                        Status="@WorkflowStatus.InProgress"
                        AssistiveText="Live updates from the security system" />
        }
    </div>

    <Tabs Label="Dashboard sections" Items="@_tabs" ActiveTabId="@_activeTabId" ActiveTabIdChanged="OnActiveTabChanged">
        <PanelTemplate Context="tab">
            @if (tab.Id == "incidents")
            {
                <DataTable TItem="AuditLogEntry"
                           Title="Needs action now"
                           Caption="Recent incident queue"
                           Items="@_filteredIncidents"
                           Columns="@_incidentColumns"
                           EmptyMessage="No incidents in queue for this filter."
                           ShowSearch="false" />
            }
            else
            {
                <section class="hip-overview-summary">
                    <h2>Protocol summary</h2>
                    <p class="text-muted mb-2">Placeholder for protocol health checks and unusual activity cards.</p>
                    <ul>
                        <li>Replay detection: <StatusBadge Severity="SeverityLevel.Low" /></li>
                        <li>Token freshness: <StatusBadge Status="WorkflowStatus.InProgress" /></li>
                        <li>Policy evaluation queue: <StatusBadge Status="WorkflowStatus.Queued" /></li>
                    </ul>
                </section>
            }
        </PanelTemplate>
    </Tabs>
</StateView>

@code {
    private IReadOnlyList<BreadcrumbItem> _breadcrumbs = [new("Dashboard", "/")];
    private readonly List<DashboardMetric> _metricCards = [];
    private readonly List<AuditLogEntry> _incidents = [];
    private List<AuditLogEntry> _filteredIncidents = [];
    private DateTimeOffset? _lastUpdatedUtc;
    private StateViewMode _state = StateViewMode.Loading;
    private string _error = "Please try again.";
    private string _searchText = string.Empty;
    private string _activeTabId = "incidents";

    private readonly IReadOnlyList<TabItem> _tabs =
    [
        new() { Id = "incidents", Label = "Incident Queue" },
        new() { Id = "protocol", Label = "Protocol Summary", BadgeText = "MVP" }
    ];

    private readonly List<FilterField> _filters =
    [
        new()
        {
            Key = "severity",
            Label = "Severity",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "All severities" },
                new FilterFieldOption { Value = "critical", Label = "Critical" },
                new FilterFieldOption { Value = "warning", Label = "Warning" },
                new FilterFieldOption { Value = "info", Label = "Info" }
            ]
        },
        new()
        {
            Key = "result",
            Label = "Result",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "Any result" },
                new FilterFieldOption { Value = "denied", Label = "Denied" },
                new FilterFieldOption { Value = "review", Label = "Review" },
                new FilterFieldOption { Value = "success", Label = "Success" }
            ]
        }
    ];

    private readonly IReadOnlyList<DataTableColumn<AuditLogEntry>> _incidentColumns =
    [
        new() { Header = "Time", ValueSelector = x => x.Timestamp.ToLocalTime().ToString("u"), SortSelector = x => x.Timestamp },
        new() { Header = "Actor", ValueSelector = x => x.Actor, SortSelector = x => x.Actor },
        new() { Header = "Event", ValueSelector = x => x.EventType, SortSelector = x => x.EventType },
        new() { Header = "Severity", CellTemplate = row => @<StatusBadge Severity="@AdminUiSemantics.ParseSeverity(row.Severity)" />, SortSelector = x => x.Severity },
        new() { Header = "Result", ValueSelector = x => x.Result, SortSelector = x => x.Result }
    ];

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _state = StateViewMode.Loading;
        _error = "Please try again.";

        var metricsTask = Api.GetDashboardMetricsAsync();
        var incidentsTask = Api.GetAuditLogsAsync();

        await Task.WhenAll(metricsTask, incidentsTask);

        var metrics = metricsTask.Result;
        var incidents = incidentsTask.Result;

        _metricCards.Clear();
        _incidents.Clear();

        if (metrics.Success && metrics.Data is { Count: > 0 })
        {
            _metricCards.AddRange(metrics.Data.Take(4));
        }

        if (incidents.Success && incidents.Data is { Count: > 0 })
        {
            _incidents.AddRange(incidents.Data.Take(25));
        }

        if (!metrics.Success && !incidents.Success)
        {
            _state = StateViewMode.Error;
            _error = string.Join(" ", new[] { metrics.Error, incidents.Error }.Where(x => !string.IsNullOrWhiteSpace(x)));
            return;
        }

        ApplyFilters(new FilterBarChangeSet
        {
            SearchText = _searchText,
            Values = _filters.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase)
        });

        _lastUpdatedUtc = DateTimeOffset.UtcNow;
        _state = _incidents.Count == 0
            ? StateViewMode.EmptyTrue
            : _filteredIncidents.Count == 0
                ? StateViewMode.EmptyFiltered
                : StateViewMode.Success;
    }

    private Task OnSearchTextChanged(string text)
    {
        _searchText = text;
        return Task.CompletedTask;
    }

    private Task OnFiltersChanged(FilterBarChangeSet changeSet)
    {
        ApplyFilters(changeSet);
        _state = _incidents.Count == 0
            ? StateViewMode.EmptyTrue
            : _filteredIncidents.Count == 0
                ? StateViewMode.EmptyFiltered
                : StateViewMode.Success;
        return Task.CompletedTask;
    }

    private Task OnActiveTabChanged(string tabId)
    {
        _activeTabId = tabId;
        return Task.CompletedTask;
    }

    private void ApplyFilters(FilterBarChangeSet changeSet)
    {
        var severity = changeSet.Values.TryGetValue("severity", out var severityValue) ? severityValue : "all";
        var result = changeSet.Values.TryGetValue("result", out var resultValue) ? resultValue : "all";

        _filteredIncidents = _incidents
            .Where(x => string.IsNullOrWhiteSpace(changeSet.SearchText)
                        || x.Actor.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.EventType.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.Detail.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase))
            .Where(x => severity is null || severity == "all" || x.Severity.Equals(severity, StringComparison.OrdinalIgnoreCase))
            .Where(x => result is null || result == "all" || x.Result.Equals(result, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => x.Timestamp)
            .ToList();
    }

}
