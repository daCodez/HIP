@page "/login"

<PageTitle>Login</PageTitle>

<section class="widget" style="max-width:420px;margin:2rem auto;">
    <div class="widget-header"><h3><i class="fa fa-lock"></i> HIP Admin Login</h3></div>
    <div class="widget-content">
        <div class="mb-2">
            <label class="form-label small">Email</label>
            <input class="form-control" placeholder="you@hip.local" />
        </div>
        <div class="mb-2">
            <label class="form-label small">Password</label>
            <input class="form-control" type="password" placeholder="••••••••" />
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <label class="small m-0"><input type="checkbox" /> Remember me</label>
            <button class="btn btn-primary btn-sm" type="button">Sign in</button>
        </div>
        <div class="small text-muted mt-2">Scaffold only: authentication is not enforced yet.</div>
    </div>
</section>
