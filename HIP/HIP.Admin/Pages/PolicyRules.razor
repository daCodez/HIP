@page "/policy-rules"
@attribute [Authorize]
@inject HipAdminApiClient Api
@inject AdminContextService AdminContext
@implements IDisposable

<PageTitle>Policy Management</PageTitle>

<PageHeader Title="Policy Management"
            Subtitle="Review policy health, stage edits safely, and preview impact before confirmation"
            LastUpdatedUtc="@_lastUpdatedUtc"
            Breadcrumbs="@_breadcrumbs">
    <Actions>
        <button type="button" class="btn btn-outline-secondary" @onclick="ReloadAsync">Refresh</button>
        <button type="button" class="btn btn-primary" @onclick="StartNewDraft" disabled="@(!CanEditPolicies)">New draft</button>
    </Actions>
</PageHeader>

@if (_state == StateViewMode.Error)
{
    <AlertBanner Kind="AlertBannerKind.Error" Title="Policy list unavailable" Message="@_error" />
}

@if (!string.IsNullOrWhiteSpace(_bannerMessage))
{
    <AlertBanner Kind="@_bannerKind" Title="Policy workflow" Message="@_bannerMessage">
        <Actions>
            @if (_bannerKind == AlertBannerKind.Error)
            {
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ReloadAsync">Retry</button>
            }
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearBanner">Dismiss</button>
        </Actions>
    </AlertBanner>
}

<FilterBar SearchText="@_searchText"
           SearchTextChanged="OnSearchChanged"
           SearchPlaceholder="Search policy id, name, category, condition, or action"
           Fields="@_filters"
           OnChanged="OnFiltersChanged">
    <Actions>
        <span class="small text-muted">Role: <strong>@AdminContext.CurrentRole</strong></span>
    </Actions>
</FilterBar>

<div class="small text-muted mb-2" aria-live="polite">
    Showing @_filtered.Count / @_items.Count policies
</div>

<StateView Mode="@_state"
           EmptyMessage="No policies are currently configured."
           FilteredMessage="No policy matches the selected filters."
           ErrorMessage="@_error"
           OnRetry="ReloadAsync">
    <div class="row g-3">
        <div class="col-xl-8">
            <DataTable TItem="PolicyRow"
                       Title="Policy rules"
                       Caption="Severity and workflow status are shown with icon + text, not color-only cues"
                       Items="@_filtered"
                       Columns="@_columns"
                       ShowSearch="false"
                       EmptyMessage="No policy rules found for this filter set."
                       IsRowSelected="@(x => _selected?.Id == x.Id)"
                       OnRowClick="OnRowSelected" />
        </div>

        <aside class="col-xl-4" aria-live="polite">
            <section class="card">
                <div class="card-body">
                    <h2 class="h6">Policy detail</h2>
                    @if (_selected is null)
                    {
                        <p class="text-muted mb-0">Select a policy to review status and available actions.</p>
                    }
                    else
                    {
                        <p class="mb-1"><strong>@_selected.Name</strong></p>
                        <p class="mb-1">Policy ID: @_selected.Id</p>
                        <p class="mb-1">Severity: <StatusBadge Severity="@_selected.Severity" /></p>
                        <p class="mb-1">Status: <StatusBadge Status="@_selected.Status" /></p>
                        <p class="mb-2">Category: @_selected.Category</p>
                        <p class="small text-muted mb-2">@_selected.Condition</p>
                        <div class="small border rounded p-2 mb-3 bg-light-subtle">
                            <div><strong>Visual rule builder</strong></div>
                            <div>IF <code>@_selected.Condition</code></div>
                            <div>THEN <code>@_selected.Action</code> with <code>@_selected.Severity</code> severity</div>
                            <div class="text-muted">(Readable builder view for non-technical operators)</div>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => OpenEditFlow(_selected)" disabled="@(!CanEditPolicies)">Edit draft</button>
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => PreviewImpactAsync(_selected)" disabled="@(!CanEditPolicies)">Preview impact</button>
                            <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => OpenConfirmStep(_selected)" disabled="@(!CanApprovePolicies)">Confirm apply</button>
                        </div>

                        @if (!CanEditPolicies)
                        {
                            <p class="small text-muted mt-2 mb-0">Read-only role: editing and apply actions are restricted.</p>
                        }
                        else if (!CanApprovePolicies)
                        {
                            <p class="small text-muted mt-2 mb-0">You can draft and preview. Apply confirmation requires Admin role.</p>
                        }
                    }
                </div>
            </section>

            <section class="card mt-3">
                <div class="card-body small">
                    <h2 class="h6">Policy status panel</h2>
                    <div class="d-flex justify-content-between border-bottom py-1"><span>Active policies</span><strong>@_items.Count(x => x.Enabled)</strong></div>
                    <div class="d-flex justify-content-between border-bottom py-1"><span>Critical policies</span><strong>@_items.Count(x => x.Severity == SeverityLevel.Critical)</strong></div>
                    <div class="d-flex justify-content-between border-bottom py-1"><span>Triggered today</span><strong>@PolicyTriggerCount</strong></div>
                    <div class="d-flex justify-content-between py-1"><span>Last triggered</span><strong>@LastTriggeredAgo</strong></div>
                </div>
            </section>
        </aside>
    </div>
</StateView>

<ModalDialog IsOpen="@_isFlowModalOpen"
             Title="@FlowTitle"
             ConfirmText="@FlowConfirmText"
             CancelText="Close"
             OnClose="CloseFlowModal"
             OnConfirm="AdvanceFlowAsync"
             CloseOnBackdropClick="false">
    <Body>
        @if (_flowPolicy is null)
        {
            <p class="mb-0 text-muted">No policy selected.</p>
        }
        else if (_flowStep == PolicyFlowStep.Draft)
        {
            <p class="mb-2"><strong>Draft</strong> — create a safe working copy before changing production logic.</p>
            <p class="mb-1">Policy: @_flowPolicy.Name (@_flowPolicy.Id)</p>
            <p class="small text-muted mb-0">No backend write occurs in this MVP shell. This prepares an in-memory draft only.</p>
        }
        else if (_flowStep == PolicyFlowStep.Edit)
        {
            <p class="mb-2"><strong>Edit</strong> — update draft placeholders for review.</p>
            <div class="mb-2">
                <label class="form-label" for="policy-edit-name">Draft name</label>
                <input id="policy-edit-name" class="form-control" @bind="_draftName" />
            </div>
            <div class="mb-1">
                <label class="form-label" for="policy-edit-condition">Draft condition</label>
                <textarea id="policy-edit-condition" class="form-control" rows="3" @bind="_draftCondition"></textarea>
            </div>
        }
        else if (_flowStep == PolicyFlowStep.PreviewImpact)
        {
            <p class="mb-2"><strong>Preview impact</strong> — review projected workflow effect before confirmation.</p>
            @if (string.IsNullOrWhiteSpace(_impactPreviewText))
            {
                <p class="small text-muted mb-0">Preview not generated yet. Continue to simulate placeholder impact.</p>
            }
            else
            {
                <p class="small mb-0">@_impactPreviewText</p>
            }
        }
        else
        {
            <p class="mb-2"><strong>Confirm</strong> — final safety checkpoint.</p>
            <p class="mb-1">Policy: @_flowPolicy.Name (@_flowPolicy.Id)</p>
            <p class="small text-muted mb-0">This MVP confirms only UI workflow state. No destructive apply call is executed.</p>
        }
    </Body>
</ModalDialog>

@code {
    private readonly IReadOnlyList<BreadcrumbItem> _breadcrumbs = [new("Dashboard", "/"), new("Policy Management", "/policy-rules")];

    private readonly List<PolicyRow> _items = [];
    private List<PolicyRow> _filtered = [];
    private PolicyRow? _selected;

    private string _searchText = string.Empty;
    private DateTimeOffset? _lastUpdatedUtc;
    private StateViewMode _state = StateViewMode.Loading;
    private string _error = "Please try again.";

    private string? _bannerMessage;
    private AlertBannerKind _bannerKind = AlertBannerKind.Info;

    private bool _isFlowModalOpen;
    private PolicyFlowStep _flowStep = PolicyFlowStep.Draft;
    private PolicyRow? _flowPolicy;
    private string _draftName = string.Empty;
    private string _draftCondition = string.Empty;
    private string? _impactPreviewText;

    private readonly List<FilterField> _filters =
    [
        new()
        {
            Key = "severity",
            Label = "Severity",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "All severities" },
                new FilterFieldOption { Value = "critical", Label = "Critical" },
                new FilterFieldOption { Value = "high", Label = "High" },
                new FilterFieldOption { Value = "medium", Label = "Medium" },
                new FilterFieldOption { Value = "low", Label = "Low" }
            ]
        },
        new()
        {
            Key = "status",
            Label = "Status",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "All statuses" },
                new FilterFieldOption { Value = "new", Label = "New" },
                new FilterFieldOption { Value = "inprogress", Label = "In Progress" },
                new FilterFieldOption { Value = "resolved", Label = "Resolved" },
                new FilterFieldOption { Value = "failed", Label = "Failed" }
            ]
        },
        new()
        {
            Key = "enabled",
            Label = "Enabled",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "Any" },
                new FilterFieldOption { Value = "true", Label = "Enabled" },
                new FilterFieldOption { Value = "false", Label = "Disabled" }
            ]
        }
    ];

    private readonly IReadOnlyList<DataTableColumn<PolicyRow>> _columns =
    [
        new() { Header = "Policy", ValueSelector = x => x.Name, SortSelector = x => x.Name },
        new() { Header = "Severity", CellTemplate = row => @<StatusBadge Severity="@row.Severity" />, SortSelector = x => x.Severity },
        new() { Header = "Status", CellTemplate = row => @<StatusBadge Status="@row.Status" />, SortSelector = x => x.Status },
        new() { Header = "Category", ValueSelector = x => x.Category, SortSelector = x => x.Category },
        new() { Header = "Action", ValueSelector = x => x.Action, SortSelector = x => x.Action },
        new() { Header = "Mode", ValueSelector = x => x.Enabled ? "Enabled" : "Disabled", SortSelector = x => x.Enabled }
    ];

    private bool CanEditPolicies => AdminContext.CurrentRole is AdminRole.Admin or AdminRole.Support;
    private bool CanApprovePolicies => AdminContext.CurrentRole == AdminRole.Admin;
    private int PolicyTriggerCount => _filtered.Count(x => x.Enabled && x.Status is WorkflowStatus.Escalated or WorkflowStatus.InProgress) * 3;
    private string LastTriggeredAgo => _items.Count == 0 ? "No recent triggers" : "2 minutes ago";

    private string FlowTitle => _flowStep switch
    {
        PolicyFlowStep.Draft => "Policy draft",
        PolicyFlowStep.Edit => "Edit draft",
        PolicyFlowStep.PreviewImpact => "Preview impact",
        PolicyFlowStep.Confirm => "Confirm policy apply",
        _ => "Policy workflow"
    };

    private string FlowConfirmText => _flowStep == PolicyFlowStep.Confirm ? "Confirm" : "Continue";

    protected override async Task OnInitializedAsync()
    {
        AdminContext.Changed += OnAdminContextChanged;
        await ReloadAsync();
    }

    public void Dispose() => AdminContext.Changed -= OnAdminContextChanged;

    private async void OnAdminContextChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAsync()
    {
        _state = StateViewMode.Loading;
        _error = "Please try again.";
        _items.Clear();

        var result = await Api.GetPolicyRulesAsync();
        if (!result.Success)
        {
            _state = StateViewMode.Error;
            _error = result.Error ?? "Unable to load policies.";
            return;
        }

        var rows = (result.Data ?? [])
            .Select(MapPolicy)
            .OrderByDescending(x => x.Severity)
            .ThenBy(x => x.Name)
            .ToList();

        _items.AddRange(rows);

        ApplyFilters(new FilterBarChangeSet
        {
            SearchText = _searchText,
            Values = _filters.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase)
        });

        _selected = _filtered.FirstOrDefault();
        _lastUpdatedUtc = DateTimeOffset.UtcNow;
        _state = _items.Count == 0
            ? StateViewMode.EmptyTrue
            : _filtered.Count == 0
                ? StateViewMode.EmptyFiltered
                : StateViewMode.Success;
    }

    private Task OnSearchChanged(string value)
    {
        _searchText = value;
        return Task.CompletedTask;
    }

    private Task OnFiltersChanged(FilterBarChangeSet changeSet)
    {
        ApplyFilters(changeSet);
        _selected = _filtered.FirstOrDefault(x => x.Id == _selected?.Id) ?? _filtered.FirstOrDefault();

        _state = _items.Count == 0
            ? StateViewMode.EmptyTrue
            : _filtered.Count == 0
                ? StateViewMode.EmptyFiltered
                : StateViewMode.Success;

        return Task.CompletedTask;
    }

    private Task OnRowSelected(PolicyRow row)
    {
        _selected = row;
        return Task.CompletedTask;
    }

    private void ApplyFilters(FilterBarChangeSet changeSet)
    {
        var severity = ReadValue(changeSet, "severity", "all");
        var status = ReadValue(changeSet, "status", "all");
        var enabled = ReadValue(changeSet, "enabled", "all");

        _filtered = _items
            .Where(x => string.IsNullOrWhiteSpace(changeSet.SearchText)
                        || x.Id.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.Name.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.Category.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.Action.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.Condition.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase))
            .Where(x => AdminUiSemantics.MatchesSeverity(x.Severity, severity))
            .Where(x => AdminUiSemantics.MatchesStatus(x.Status, status))
            .Where(x => enabled == "all" || x.Enabled.ToString().Equals(enabled, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void StartNewDraft()
    {
        if (!CanEditPolicies)
        {
            SetBanner(AlertBannerKind.Warning, "Your role is read-only for policy editing.");
            return;
        }

        _flowPolicy = _selected ?? _items.FirstOrDefault();
        _flowStep = PolicyFlowStep.Draft;
        _draftName = _flowPolicy?.Name ?? "New policy draft";
        _draftCondition = _flowPolicy?.Condition ?? "event matches rule";
        _impactPreviewText = null;
        _isFlowModalOpen = true;
    }

    private void OpenEditFlow(PolicyRow row)
    {
        if (!CanEditPolicies)
        {
            SetBanner(AlertBannerKind.Warning, "Your role is read-only for policy editing.");
            return;
        }

        _flowPolicy = row;
        _flowStep = PolicyFlowStep.Edit;
        _draftName = row.Name;
        _draftCondition = row.Condition;
        _impactPreviewText = null;
        _isFlowModalOpen = true;
    }

    private async Task PreviewImpactAsync(PolicyRow row)
    {
        if (!CanEditPolicies)
        {
            SetBanner(AlertBannerKind.Warning, "Your role is read-only for policy editing.");
            return;
        }

        _flowPolicy = row;
        _flowStep = PolicyFlowStep.PreviewImpact;
        _isFlowModalOpen = true;

        await Task.Delay(120);
        _impactPreviewText = $"Projected effect for {row.Id}: Block +1, Challenge +2, Warn +1 (placeholder simulation).";
    }

    private void OpenConfirmStep(PolicyRow row)
    {
        if (!CanApprovePolicies)
        {
            SetBanner(AlertBannerKind.Warning, "Apply confirmation requires Admin role.");
            return;
        }

        _flowPolicy = row;
        _flowStep = PolicyFlowStep.Confirm;
        _isFlowModalOpen = true;
    }

    private Task AdvanceFlowAsync()
    {
        if (_flowPolicy is null)
        {
            _isFlowModalOpen = false;
            return Task.CompletedTask;
        }

        if (_flowStep == PolicyFlowStep.Confirm)
        {
            SetBanner(AlertBannerKind.Success, $"Policy flow confirmed for {_flowPolicy.Id}. Apply remains a non-destructive placeholder in MVP.");
            _isFlowModalOpen = false;
            return Task.CompletedTask;
        }

        _flowStep = _flowStep switch
        {
            PolicyFlowStep.Draft => PolicyFlowStep.Edit,
            PolicyFlowStep.Edit => PolicyFlowStep.PreviewImpact,
            _ => PolicyFlowStep.Confirm
        };

        return Task.CompletedTask;
    }

    private Task CloseFlowModal()
    {
        _isFlowModalOpen = false;
        return Task.CompletedTask;
    }

    private void ClearBanner() => _bannerMessage = null;

    private void SetBanner(AlertBannerKind kind, string message)
    {
        _bannerKind = kind;
        _bannerMessage = message;
    }

    private static string ReadValue(FilterBarChangeSet changeSet, string key, string fallback)
        => changeSet.Values.TryGetValue(key, out var value)
            ? value ?? fallback
            : fallback;

    private static PolicyRow MapPolicy(PolicyRule rule)
    {
        var severity = AdminUiSemantics.ParseSeverity(rule.Severity);
        var status = rule.Enabled
            ? severity == SeverityLevel.Critical ? WorkflowStatus.Escalated : WorkflowStatus.InProgress
            : WorkflowStatus.Resolved;

        return new PolicyRow
        {
            Id = rule.RuleId,
            Name = rule.Name,
            Category = string.IsNullOrWhiteSpace(rule.Category) ? "General" : rule.Category!,
            Condition = string.IsNullOrWhiteSpace(rule.Condition) ? "event matches rule" : rule.Condition!,
            Action = string.IsNullOrWhiteSpace(rule.Action) ? "Review" : rule.Action!,
            Severity = severity,
            Status = status,
            Enabled = rule.Enabled
        };
    }

    private sealed class PolicyRow
    {
        public required string Id { get; init; }
        public required string Name { get; init; }
        public required string Category { get; init; }
        public required string Condition { get; init; }
        public required string Action { get; init; }
        public required SeverityLevel Severity { get; init; }
        public required WorkflowStatus Status { get; init; }
        public bool Enabled { get; init; }
    }

    private enum PolicyFlowStep
    {
        Draft,
        Edit,
        PreviewImpact,
        Confirm
    }
}
