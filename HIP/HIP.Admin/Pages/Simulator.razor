@page "/simulator"
@inject SimulatorAdminService SimulatorService
@inject HipAdminApiClient Api
@inject ToastService Toast

<PageTitle>Simulator</PageTitle>

<h4>Security Event Simulator</h4>
@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger">@Error</div>
}

<div class="card p-3 mb-3">
    <div class="row g-2">
        <div class="col-md-4">
            <label for="sim-suite">Suite</label>
            <select id="sim-suite" class="form-select" @bind="SelectedSuite">
                <option value="">(all)</option>
                @foreach (var suite in Suites)
                {
                    <option value="@suite">@suite</option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <label for="sim-scenario">Scenario</label>
            <select id="sim-scenario" class="form-select" @bind="SelectedScenarioId">
                <option value="">(all for suite)</option>
                @foreach (var s in Scenarios)
                {
                    <option value="@s.Id">@s.Id - @s.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button class="btn btn-outline-secondary" @onclick="LoadScenarios">Reload</button>
            <button class="btn btn-primary" @onclick="RunAsync">Run</button>
        </div>
    </div>
    <hr />
    <div class="row g-2">
        <div class="col-md-3">
            <label for="sim-campaign-profile">Campaign profile</label>
            <select id="sim-campaign-profile" class="form-select" @bind="CampaignProfile" aria-describedby="sim-campaign-profile-help">
                <option value="default">Balanced checks (recommended)</option>
                <option value="aggressive">High-pressure coverage</option>
                <option value="stealth">Low-noise checks</option>
                <option value="insider">Insider risk focus</option>
            </select>
            <div id="sim-campaign-profile-help" class="form-text">@GetCampaignProfileSubtitle(CampaignProfile)</div>
        </div>
        <div class="col-md-3">
            <label for="sim-duration-seconds">Duration (sec)</label>
            <input id="sim-duration-seconds" type="number" min="10" max="1800" class="form-control" @bind="CampaignDurationSeconds" />
        </div>
        <div class="col-md-3">
            <label for="sim-wave-interval-seconds">Wave interval (sec)</label>
            <input id="sim-wave-interval-seconds" type="number" min="1" max="300" class="form-control" @bind="CampaignWaveIntervalSeconds" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-danger" @onclick="RunCampaignAsync">Run Campaign Mode</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(RunId))
{
    <div class="card p-3 mb-3">
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Run</span><span class="fw-semibold">@RunId</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Status</span><span class="fw-semibold">@Status</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Stage</span><span class="fw-semibold">@Stage</span></div>
        <div class="d-flex justify-content-between py-1"><span class="text-muted">Progress</span><span class="fw-semibold">@Processed / @Total</span></div>
        @if (Status is "running" or "cancelling")
        {
            <button class="btn btn-sm btn-warning mt-2" @onclick="CancelAsync">Cancel</button>
        }
    </div>
}

@if (Result is not null)
{
    @if (ThreatCoverage is not null)
    {
        <div class="card p-3 mb-3">
            <h5>Threat Coverage (Taxonomy-first)</h5>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Total threats</span><span class="fw-semibold">@ThreatCoverage.TotalThreats</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Covered threats</span><span class="fw-semibold">@ThreatCoverage.CoveredThreats</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Partial threats</span><span class="fw-semibold">@ThreatCoverage.PartialThreats</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Uncovered threats</span><span class="fw-semibold">@ThreatCoverage.UncoveredThreats</span></div>
            <div class="d-flex justify-content-between py-1"><span class="text-muted">Critical uncovered</span><span class="fw-semibold">@ThreatCoverage.CriticalUncovered</span></div>

            @if (ThreatCoverage.UncoveredItems.Count > 0)
            {
                <h6 class="mt-2">Uncovered Threats</h6>
                <ul>
                    @foreach (var t in ThreatCoverage.UncoveredItems)
                    {
                        <li><b>@t.ThreatId</b> — @t.Title (@t.Family, @t.Severity)</li>
                    }
                </ul>
            }
        </div>
    }

    <div class="card p-3 mb-3">
        <h5>Run Summary</h5>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Total scenarios</span><span class="fw-semibold">@Result.TotalScenarios</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Passed</span><span class="fw-semibold">@Result.Passed</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Failed</span><span class="fw-semibold">@Result.Failed</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Uncovered scenarios</span><span class="fw-semibold">@Result.Uncovered</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Invalid scenarios</span><span class="fw-semibold">@Result.Invalid</span></div>
        <div class="d-flex justify-content-between py-1"><span class="text-muted">Suggestions</span><span class="fw-semibold">@Result.SuggestedPoliciesGenerated</span></div>
    </div>

    <div class="card p-3">
        <h5>Suggested Security Policies</h5>
        @{
            var displayedSuggestions = GetDisplayedSuggestions();
            var showingThreatFallback = Result.Scenarios.All(x => x.Suggestion is null) && displayedSuggestions.Count > 0;
        }

        @if (displayedSuggestions.Count == 0)
        {
            <div class="text-muted">No policy suggestions generated in this run.</div>
        }
        else
        {
            if (showingThreatFallback)
            {
                <div class="alert alert-secondary py-2 mb-3">
                    No scenario-level suggestions were generated. Showing draft-safe recommendations from uncovered taxonomy threats.
                </div>
            }

            @foreach (var item in displayedSuggestions)
            {
                var key = item.Key;
                var isApplying = Applying.Contains(key);
                var isAdded = Added.Contains(key);
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <div><strong>@item.Label:</strong> @item.DisplayId</div>
                        <button class="btn btn-sm @(isAdded ? "btn-success" : "btn-outline-primary")" disabled="@(isApplying || isAdded)" @onclick="() => AddSuggestionAsync(key, item.Suggestion)">
                            @(isApplying ? "Adding..." : isAdded ? "Added" : "Add Policy")
                        </button>
                    </div>
                    <pre class="bg-light p-2 border rounded">@item.Suggestion.ToTemplate()</pre>
                </div>
            }
        }
    </div>
}

@code {
    private IReadOnlyList<string> Suites = [];
    private IReadOnlyList<(string Id, string Name, string Suite)> Scenarios = [];
    private string? SelectedSuite;
    private string? SelectedScenarioId;

    private string? RunId;
    private string Status = "idle";
    private string Stage = "idle";
    private int Processed;
    private int Total;
    private string CampaignProfile = "default";
    private int CampaignDurationSeconds = 120;
    private int CampaignWaveIntervalSeconds = 6;
    private HIP.Simulator.Core.Models.SimulationRunResult? Result;
    private HIP.Simulator.Core.Models.ThreatCoverageSummary? ThreatCoverage;
    private string? Error;
    private HashSet<string> Applying = [];
    private HashSet<string> Added = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Suites = await SimulatorService.GetSuitesAsync();
            await LoadScenarios();
        }
        catch (Exception ex)
        {
            Error = $"Failed to initialize simulator: {ex.Message}";
        }
    }

    private async Task LoadScenarios()
    {
        Scenarios = await SimulatorService.GetScenariosAsync(SelectedSuite);
        if (!string.IsNullOrWhiteSpace(SelectedScenarioId) && !Scenarios.Any(x => x.Id == SelectedScenarioId))
        {
            SelectedScenarioId = null;
        }
    }

    private async Task RunAsync()
    {
        Result = null;
        ThreatCoverage = null;
        Status = "running";
        Stage = "starting";
        Processed = 0;
        Total = 0;

        RunId = await SimulatorService.StartRunAsync(SelectedSuite, SelectedScenarioId, null);
        await PollRunAsync(240);
    }

    private async Task RunCampaignAsync()
    {
        Result = null;
        ThreatCoverage = null;
        Status = "running-campaign";
        Stage = "campaign-starting";
        Processed = 0;
        Total = 0;

        CampaignDurationSeconds = Math.Clamp(CampaignDurationSeconds, 10, 1800);
        CampaignWaveIntervalSeconds = Math.Clamp(CampaignWaveIntervalSeconds, 1, 300);

        RunId = await SimulatorService.StartCampaignAsync(CampaignProfile, CampaignDurationSeconds, CampaignWaveIntervalSeconds, null);
        var pollLoops = Math.Max(240, (CampaignDurationSeconds * 2) + 120);
        await PollRunAsync(pollLoops);
    }

    private async Task PollRunAsync(int loops)
    {
        if (string.IsNullOrWhiteSpace(RunId)) return;

        for (var i = 0; i < loops; i++)
        {
            await Task.Delay(500);
            var snapshot = SimulatorService.GetRun(RunId);
            Status = snapshot.Status;
            Result = snapshot.Result;
            ThreatCoverage = snapshot.ThreatCoverage;
            if (snapshot.Progress is not null)
            {
                Stage = snapshot.Progress.Stage;
                Processed = snapshot.Progress.ProcessedScenarios;
                Total = snapshot.Progress.TotalScenarios;
            }

            if (Status is "completed" or "failed" or "cancelled")
            {
                break;
            }
        }
    }

    private async Task AddSuggestionAsync(string suggestionKey, HIP.Simulator.Core.Models.PolicySuggestion suggestion)
    {
        if (Applying.Contains(suggestionKey) || Added.Contains(suggestionKey))
        {
            return;
        }

        Applying.Add(suggestionKey);
        Error = null;

        try
        {
            var normalizedCategory = NormalizeCategory(suggestion.Category);
            var rule = new PolicyRule
            {
                RuleId = suggestion.RuleName.Replace('.', '-').Replace(' ', '-'),
                Name = suggestion.RuleName,
                Category = normalizedCategory,
                Condition = suggestion.ConditionExpression,
                Action = suggestion.RecommendedAction,
                Severity = suggestion.RecommendedSeverity,
                Enabled = false
            };

            var save = await Api.UpsertPolicyRuleAsync(rule);
            if (save.Success)
            {
                Added.Add(suggestionKey);
                Toast.Show("Simulator", $"Policy suggestion added for '{suggestionKey}'.", "success");
            }
            else
            {
                Error = save.Error ?? "Failed to add suggested policy.";
                Toast.Show("Simulator", Error, "danger");
            }
        }
        catch (Exception ex)
        {
            Error = $"Failed to add suggested policy: {ex.Message}";
            Toast.Show("Simulator", Error, "danger");
        }
        finally
        {
            Applying.Remove(suggestionKey);
        }
    }

    private IReadOnlyList<SuggestionViewModel> GetDisplayedSuggestions()
    {
        if (Result is null)
        {
            return [];
        }

        var scenarioSuggestions = Result.Scenarios
            .Where(x => x.Suggestion is not null)
            .Select(x => new SuggestionViewModel($"scenario:{x.ScenarioId}", "Scenario", x.ScenarioId, x.Suggestion!))
            .ToList();

        if (scenarioSuggestions.Count > 0)
        {
            return scenarioSuggestions;
        }

        if (ThreatCoverage?.UncoveredItems is null || ThreatCoverage.UncoveredItems.Count == 0)
        {
            return [];
        }

        return ThreatCoverage.UncoveredItems
            .Select(t => new SuggestionViewModel($"threat:{t.ThreatId}", "Threat", t.ThreatId, BuildFallbackSuggestionFromThreat(t)))
            .ToList();
    }

    private static HIP.Simulator.Core.Models.PolicySuggestion BuildFallbackSuggestionFromThreat(HIP.Simulator.Core.Models.ThreatCatalogItem threat)
    {
        var normalizedThreatId = threat.ThreatId.Trim().ToUpperInvariant();
        var normalizedFamily = string.IsNullOrWhiteSpace(threat.Family) ? "risk" : threat.Family.Trim().ToLowerInvariant();
        var severity = threat.Severity.Trim().ToLowerInvariant() switch
        {
            "critical" => "High",
            "high" => "High",
            "medium" => "Medium",
            "low" => "Low",
            _ => "Medium"
        };

        return new HIP.Simulator.Core.Models.PolicySuggestion(
            RuleName: $"Sim.Threat.{normalizedThreatId}.Draft",
            Category: "uncovered",
            ConditionExpression: $"threatTaxonomyId == '{normalizedThreatId}'",
            RecommendedAction: severity == "High" ? "Challenge" : "Alert",
            RecommendedSeverity: severity,
            Reason: $"Uncovered taxonomy threat: {threat.Title}",
            NeededSignals: ["threatTaxonomyId", "eventType", "actorId"],
            PositiveTestCase: $"{normalizedThreatId} event marked as {normalizedFamily}",
            NegativeTestCase: $"Event not mapped to {normalizedThreatId}",
            Notes: "Draft-safe fallback suggestion generated from uncovered taxonomy threat. Review and tune before enabling.");
    }

    private static string GetCampaignProfileSubtitle(string profile)
        => profile.Trim().ToLowerInvariant() switch
        {
            "aggressive" => "Covers the widest set of suites, including noisy/high-pressure checks.",
            "stealth" => "Runs a quieter mix focused on low-noise detection gaps.",
            "insider" => "Focuses on session/reputation insider-risk behavior and invalid flows.",
            _ => "Balanced baseline across core suites for day-to-day health checks."
        };

    private static string NormalizeCategory(string? category)
    {
        if (string.IsNullOrWhiteSpace(category)) return "Risk";

        return category.Trim().ToLowerInvariant() switch
        {
            "authentication" => "Login",
            "device" => "Device",
            "token" => "Token",
            "messaging" => "Messaging",
            "reputation" => "Reputation",
            "session" => "Session",
            "uncovered" => "Risk",
            "invalid" => "System",
            "risk" => "Risk",
            "system" => "System",
            _ => "Risk"
        };
    }

    private Task CancelAsync()
    {
        if (!string.IsNullOrWhiteSpace(RunId))
        {
            SimulatorService.Cancel(RunId);
            Status = "cancelling";
        }

        return Task.CompletedTask;
    }

    private sealed record SuggestionViewModel(string Key, string Label, string DisplayId, HIP.Simulator.Core.Models.PolicySuggestion Suggestion);
}
