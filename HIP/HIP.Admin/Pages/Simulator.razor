@page "/simulator"
@attribute [Authorize(Policy = AdminPolicyNames.SupportOrAdmin)]
@inject SimulatorAdminService SimulatorService
@inject HipAdminApiClient Api
@inject SimulatorAutoHardeningService AutoHardeningService
@inject ToastService Toast

<PageTitle>Security Event Simulator</PageTitle>

<PageHeader Title="Security Event Simulator"
            Subtitle="Run realistic security checks and review draft-safe policy recommendations"
            LastUpdatedUtc="@_lastUpdatedUtc"
            Breadcrumbs="@_breadcrumbs">
    <Actions>
        <button type="button" class="btn btn-outline-secondary" @onclick="LoadScenarios">Reload scenarios</button>
    </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger">@Error</div>
}

<div class="card p-3 mb-3">
    <div class="small text-muted mb-2">Pick a suite and scenario, then run once or launch campaign mode for broader coverage.</div>
    <div class="row g-2">
        <div class="col-md-4">
            <label for="sim-suite">Suite</label>
            <select id="sim-suite" class="form-select" @bind="SelectedSuite">
                <option value="">All suites</option>
                @foreach (var suite in Suites)
                {
                    <option value="@suite">@suite</option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <label for="sim-scenario">Scenario</label>
            <select id="sim-scenario" class="form-select" @bind="SelectedScenarioId">
                <option value="">All scenarios in selected suite</option>
                @foreach (var s in Scenarios)
                {
                    <option value="@s.Id">@s.Id - @s.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button class="btn btn-outline-secondary" @onclick="LoadScenarios">Reload</button>
            <button class="btn btn-primary" @onclick="RunAsync">Run</button>
        </div>
    </div>
    <hr />
    <div class="row g-2">
        <div class="col-md-3">
            <label for="sim-campaign-profile">Campaign profile</label>
            <select id="sim-campaign-profile" class="form-select" @bind="CampaignProfile" aria-describedby="sim-campaign-profile-help">
                <option value="default">Balanced checks (recommended)</option>
                <option value="aggressive">High-pressure coverage</option>
                <option value="stealth">Low-noise checks</option>
                <option value="insider">Insider risk focus</option>
            </select>
            <div id="sim-campaign-profile-help" class="form-text">@GetCampaignProfileSubtitle(CampaignProfile)</div>
        </div>
        <div class="col-md-3">
            <label for="sim-duration-seconds">Duration (sec)</label>
            <input id="sim-duration-seconds" type="number" min="10" max="1800" class="form-control" @bind="CampaignDurationSeconds" />
        </div>
        <div class="col-md-3">
            <label for="sim-wave-interval-seconds">Wave interval (sec)</label>
            <input id="sim-wave-interval-seconds" type="number" min="1" max="300" class="form-control" @bind="CampaignWaveIntervalSeconds" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-danger" @onclick="RunCampaignAsync">Run Campaign Mode</button>
        </div>
    </div>
</div>

<div class="card p-3 mb-3">
    <h5>What-If Attack Simulator</h5>
    <div class="small text-muted mb-2">Run a quick hypothetical without building a full scenario file.</div>
    <div class="row g-2">
        <div class="col-md-3">
            <label>Country</label>
            <select class="form-select" @bind="WhatIfCountry">
                <option>Russia</option><option>China</option><option>Brazil</option><option>Germany</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Device trust</label>
            <select class="form-select" @bind="WhatIfDeviceTrust">
                <option>Unknown</option><option>Trusted</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Reputation</label>
            <input class="form-control" type="number" min="0" max="100" @bind="WhatIfReputation" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-outline-primary" @onclick="RunWhatIf">Simulate</button>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(WhatIfResult))
    {
        <div class="alert alert-info py-2 mt-2 mb-0">@WhatIfResult</div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(RunId))
{
    <div class="card p-3 mb-3">
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Run</span><span class="fw-semibold">@RunId</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Status</span><span class="fw-semibold">@Status</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Stage</span><span class="fw-semibold">@Stage</span></div>
        <div class="d-flex justify-content-between py-1"><span class="text-muted">Progress</span><span class="fw-semibold">@Processed / @Total (@ProgressPercent%)</span></div>
        <div class="progress mb-2" role="progressbar" aria-label="Simulation run progress" aria-valuenow="@ProgressPercent" aria-valuemin="0" aria-valuemax="100">
            <div class="progress-bar" style="width: @ProgressPercentDisplay">@ProgressPercent%</div>
        </div>
        @if (Status is "running" or "cancelling")
        {
            <button class="btn btn-sm btn-warning mt-2" @onclick="CancelAsync">Cancel</button>
        }
    </div>
}

@if (Result is not null)
{
    @if (ThreatCoverage is not null)
    {
        <div class="card p-3 mb-3">
            <h5>Run Scope &amp; Taxonomy Coverage</h5>
            <div class="small text-muted mb-2">Run scope shows what this run could evaluate. Full taxonomy shows total catalog posture.</div>

            <h6 class="mt-2">Run-scope coverage</h6>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">In-scope threats for this run</span><span class="fw-semibold">@ThreatCoverage.InScopeThreats</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Covered (in-scope)</span><span class="fw-semibold">@ThreatCoverage.CoveredInScopeThreats</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Partial (in-scope)</span><span class="fw-semibold">@ThreatCoverage.PartialInScopeThreats</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Uncovered (in-scope)</span><span class="fw-semibold">@ThreatCoverage.UncoveredInScopeThreats</span></div>
            <div class="d-flex justify-content-between py-1"><span class="text-muted">Out-of-scope threats</span><span class="fw-semibold">@ThreatCoverage.OutOfScopeThreats</span></div>

            <hr class="my-3" />
            <h6>Full taxonomy coverage</h6>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Total taxonomy threats</span><span class="fw-semibold">@ThreatCoverage.TotalThreats</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Covered threats</span><span class="fw-semibold">@ThreatCoverage.CoveredThreats</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Partial threats</span><span class="fw-semibold">@ThreatCoverage.PartialThreats</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Uncovered threats</span><span class="fw-semibold">@ThreatCoverage.UncoveredThreats</span></div>
            <div class="d-flex justify-content-between py-1"><span class="text-muted">Critical uncovered (in-scope)</span><span class="fw-semibold">@ThreatCoverage.CriticalUncovered</span></div>

            @if (ThreatCoverage.UncoveredItems.Count > 0)
            {
                <h6 class="mt-3">Uncovered threats</h6>
                <ul>
                    @foreach (var item in ThreatCoverage.UncoveredItems.OrderByDescending(x => x.IsInScope).ThenBy(x => x.Threat.ThreatId, StringComparer.OrdinalIgnoreCase))
                    {
                        <li><b>@item.Threat.ThreatId</b> — @item.Threat.Title (@item.Threat.Family, @item.Threat.Severity) <span class="badge @(item.IsInScope ? "text-bg-warning" : "text-bg-secondary")">@(item.IsInScope ? "in scope" : "out of scope")</span></li>
                    }
                </ul>
            }
        </div>
    }

    <div class="card p-3 mb-3">
        <h5>Run Summary</h5>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Total scenarios</span><span class="fw-semibold">@Result.TotalScenarios</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Passed</span><span class="fw-semibold">@Result.Passed</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Failed</span><span class="fw-semibold">@Result.Failed</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Uncovered scenarios</span><span class="fw-semibold">@Result.Uncovered</span></div>
        <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Invalid scenarios</span><span class="fw-semibold">@Result.Invalid</span></div>
        <div class="d-flex justify-content-between py-1"><span class="text-muted">Suggestions</span><span class="fw-semibold">@Result.SuggestedPoliciesGenerated</span></div>
    </div>

    @if (Result.Coverage.FrameworkCoverage is { Count: > 0 })
    {
        <div class="card p-3 mb-3">
            <h5>Framework Coverage (MITRE / OWASP / NIST)</h5>
            <div class="small text-muted mb-2">Coverage rollup by security framework control.</div>
            @foreach (var row in Result.Coverage.FrameworkCoverage.OrderBy(x => x.Framework).ThenBy(x => x.Control))
            {
                <div class="border rounded p-2 mt-2">
                    <div class="d-flex justify-content-between">
                        <strong>@row.Framework</strong>
                        <span class="text-muted">@row.Control</span>
                    </div>
                    <div class="small mt-1">Total: <strong>@row.Total</strong> · Covered: <strong class="text-success">@row.Covered</strong> · Uncovered: <strong class="text-warning">@row.Uncovered</strong> · Invalid: <strong class="text-danger">@row.Invalid</strong></div>
                </div>
            }
        </div>
    }

    @if (GetLiveComparisons().Count > 0)
    {
        var liveRows = GetLiveComparisons();
        var mismatchCount = liveRows.Count(x => x.LiveComparison!.MismatchDetected);
        <div class="card p-3 mb-3">
            <h5>Live Validation Drift Report</h5>
            <div class="small text-muted mb-2">Expected vs actual behavior from live replay mode.</div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Live scenarios</span><span class="fw-semibold">@liveRows.Count</span></div>
            <div class="d-flex justify-content-between border-bottom py-1"><span class="text-muted">Matched</span><span class="fw-semibold">@(liveRows.Count - mismatchCount)</span></div>
            <div class="d-flex justify-content-between py-1"><span class="text-muted">Mismatches</span><span class="fw-semibold @(mismatchCount > 0 ? "text-danger" : "text-success")">@mismatchCount</span></div>

            @foreach (var row in liveRows.Take(20))
            {
                var cmp = row.LiveComparison!;
                <div class="border rounded p-2 mt-2">
                    <div class="d-flex justify-content-between">
                        <strong>@row.ScenarioId</strong>
                        <span class="badge @(cmp.MismatchDetected ? "text-bg-danger" : "text-bg-success")">@(cmp.MismatchDetected ? "Drift" : "Validated")</span>
                    </div>
                    <div class="small mt-1">Action: expected <strong>@cmp.ExpectedAction</strong> · actual <strong>@cmp.ActualAction</strong></div>
                    <div class="small">HTTP: expected <strong>@(cmp.ExpectedHttpStatus?.ToString() ?? "n/a")</strong> · actual <strong>@(cmp.ActualHttpStatus?.ToString() ?? "n/a")</strong></div>
                    <div class="small">Audit: expected <strong>@(cmp.ExpectedAuditEvent ?? "n/a")</strong> · actual <strong>@(cmp.ActualAuditEvent ?? "n/a")</strong></div>
                    <div class="small">Reputation: expected <strong>@(cmp.ExpectedReputationImpact ?? "n/a")</strong> · actual <strong>@(cmp.ActualReputationImpact ?? "n/a")</strong></div>
                    @if (cmp.Mismatches.Count > 0)
                    {
                        <ul class="small mt-1 mb-0 text-danger">
                            @foreach (var msg in cmp.Mismatches)
                            {
                                <li>@msg</li>
                            }
                        </ul>
                    }
                </div>
            }
        </div>
    }

    <div class="card p-3 mb-3">
        <h5>Attack Graph / Timeline (summary-first)</h5>
        <div class="small text-muted mb-2">Condensed by final action to keep simulator output readable.</div>
        @foreach (var group in Result.Scenarios.GroupBy(x => x.FinalAction).OrderByDescending(x => x.Count()))
        {
            <div class="d-flex justify-content-between border-bottom py-1"><span>@group.Key</span><span class="fw-semibold">@group.Count()</span></div>
        }
    </div>

    <div class="card p-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-2 gap-2">
            <h5 class="mb-0">Suggested Security Policies</h5>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-sm btn-outline-primary" disabled="@ApplyingScenarioRecommendations" @onclick="GenerateScenarioDraftsAsync">
                    @(ApplyingScenarioRecommendations ? "Generating..." : "Generate Scenarios (Draft)")
                </button>
                <button class="btn btn-sm btn-outline-secondary" disabled="@ApplyingTelemetryRecommendations" @onclick="AddTelemetryDraftsAsync">
                    @(ApplyingTelemetryRecommendations ? "Adding..." : "Add Telemetry (Draft)")
                </button>
                <button class="btn btn-sm btn-outline-success" disabled="@ApplyingAllSuggestions" @onclick="AutoFixAllAsync">
                    @(ApplyingAllSuggestions ? "Applying all..." : "Auto-Fix All (Draft)")
                </button>
            </div>
        </div>
        @{
            var displayedSuggestions = GetDisplayedSuggestions();
            var showingThreatFallback = Result.Scenarios.All(x => x.Suggestion is null) && displayedSuggestions.Count > 0;
        }

        @if (displayedSuggestions.Count == 0)
        {
            <div class="text-muted">No policy suggestions generated in this run.</div>
        }
        else
        {
            if (showingThreatFallback)
            {
                <div class="alert alert-secondary py-2 mb-3">
                    No scenario-level suggestions were generated. Showing draft-safe recommendations from uncovered taxonomy threats (in-scope items first).
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(AutoFixSummaryText))
            {
                <div class="alert alert-info py-2 mb-3">
                    <div>@AutoFixSummaryText</div>
                    @if (AutoFixFailureMessages.Count > 0)
                    {
                        <ul class="mb-0 mt-2 small">
                            @foreach (var msg in AutoFixFailureMessages)
                            {
                                <li>@msg</li>
                            }
                        </ul>
                    }
                </div>
            }

            @foreach (var item in displayedSuggestions)
            {
                var key = item.Key;
                var isApplying = Applying.Contains(key);
                var isAdded = Added.Contains(key);
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <div><strong>@item.Label:</strong> @item.DisplayId</div>
                        <button class="btn btn-sm @(isAdded ? "btn-success" : "btn-outline-primary")" disabled="@(isApplying || isAdded)" @onclick="() => AddSuggestionAsync(key, item.Suggestion)">
                            @(isApplying ? "Adding..." : isAdded ? "Added" : "Add Policy")
                        </button>
                    </div>
                    <pre class="bg-light p-2 border rounded">@item.Suggestion.ToTemplate()</pre>
                </div>
            }
        }
    </div>
}

@code {
    private IReadOnlyList<BreadcrumbItem> _breadcrumbs = [new("Simulator", "/simulator")];
    private DateTimeOffset? _lastUpdatedUtc;

    private IReadOnlyList<string> Suites = [];
    private IReadOnlyList<(string Id, string Name, string Suite)> Scenarios = [];
    private string? SelectedSuite;
    private string? SelectedScenarioId;

    private string? RunId;
    private string Status = "idle";
    private string Stage = "idle";
    private int Processed;
    private int Total;
    private string CampaignProfile = "default";
    private int CampaignDurationSeconds = 120;
    private int CampaignWaveIntervalSeconds = 6;
    private string WhatIfCountry = "Russia";
    private string WhatIfDeviceTrust = "Unknown";
    private int WhatIfReputation = 35;
    private string? WhatIfResult;
    private HIP.Simulator.Core.Models.SimulationRunResult? Result;
    private HIP.Simulator.Core.Models.ThreatCoverageSummary? ThreatCoverage;
    private string? Error;
    private HashSet<string> Applying = [];
    private HashSet<string> Added = [];
    private bool ApplyingAllSuggestions;
    private bool ApplyingScenarioRecommendations;
    private bool ApplyingTelemetryRecommendations;
    private string? AutoFixSummaryText;
    private List<string> AutoFixFailureMessages = [];

    private int ProgressPercent => Total <= 0
        ? 0
        : Math.Clamp((int)Math.Round((double)Processed / Total * 100d), 0, 100);

    private string ProgressPercentDisplay => $"{ProgressPercent}%";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Suites = await SimulatorService.GetSuitesAsync();
            await LoadScenarios();
        }
        catch (Exception ex)
        {
            Error = $"Failed to initialize simulator: {ex.Message}";
        }
    }

    private async Task LoadScenarios()
    {
        Scenarios = await SimulatorService.GetScenariosAsync(SelectedSuite);
        if (!string.IsNullOrWhiteSpace(SelectedScenarioId) && !Scenarios.Any(x => x.Id == SelectedScenarioId))
        {
            SelectedScenarioId = null;
        }

        _lastUpdatedUtc = DateTimeOffset.UtcNow;
    }

    private async Task RunAsync()
    {
        Result = null;
        ThreatCoverage = null;
        Status = "running";
        Stage = "starting";
        Processed = 0;
        Total = 0;

        RunId = await SimulatorService.StartRunAsync(SelectedSuite, SelectedScenarioId, null);
        await PollRunAsync(240);
    }

    private async Task RunCampaignAsync()
    {
        Result = null;
        ThreatCoverage = null;
        Status = "running-campaign";
        Stage = "campaign-starting";
        Processed = 0;
        Total = 0;

        CampaignDurationSeconds = Math.Clamp(CampaignDurationSeconds, 10, 1800);
        CampaignWaveIntervalSeconds = Math.Clamp(CampaignWaveIntervalSeconds, 1, 300);

        RunId = await SimulatorService.StartCampaignAsync(CampaignProfile, CampaignDurationSeconds, CampaignWaveIntervalSeconds, null);
        var pollLoops = Math.Max(240, (CampaignDurationSeconds * 2) + 120);
        await PollRunAsync(pollLoops);
    }

    private async Task PollRunAsync(int loops)
    {
        if (string.IsNullOrWhiteSpace(RunId)) return;

        for (var i = 0; i < loops; i++)
        {
            await Task.Delay(500);
            var snapshot = SimulatorService.GetRun(RunId);
            Status = snapshot.Status;
            Result = snapshot.Result;
            ThreatCoverage = snapshot.ThreatCoverage;
            if (snapshot.Progress is not null)
            {
                Stage = snapshot.Progress.Stage;
                Processed = snapshot.Progress.ProcessedScenarios;
                Total = snapshot.Progress.TotalScenarios;
            }

            _lastUpdatedUtc = DateTimeOffset.UtcNow;

            if (Status is "completed" or "failed" or "cancelled")
            {
                break;
            }
        }
    }

    private async Task GenerateScenarioDraftsAsync()
    {
        if (ApplyingScenarioRecommendations || string.IsNullOrWhiteSpace(RunId)) return;

        ApplyingScenarioRecommendations = true;
        try
        {
            var summary = await AutoHardeningService.GenerateScenarioDraftsAsync(RunId, null);
            HandleApplySummary(summary, "Scenario drafts");
        }
        catch (Exception ex)
        {
            Error = $"Failed to generate scenario drafts: {ex.Message}";
            Toast.Show("Simulator", Error, "danger");
        }
        finally
        {
            ApplyingScenarioRecommendations = false;
        }
    }

    private async Task AddTelemetryDraftsAsync()
    {
        if (ApplyingTelemetryRecommendations || string.IsNullOrWhiteSpace(RunId)) return;

        ApplyingTelemetryRecommendations = true;
        try
        {
            var summary = await AutoHardeningService.AddTelemetryDraftsAsync(RunId, null);
            HandleApplySummary(summary, "Telemetry drafts");
        }
        catch (Exception ex)
        {
            Error = $"Failed to add telemetry drafts: {ex.Message}";
            Toast.Show("Simulator", Error, "danger");
        }
        finally
        {
            ApplyingTelemetryRecommendations = false;
        }
    }

    private async Task AutoFixAllAsync()
    {
        if (ApplyingAllSuggestions || string.IsNullOrWhiteSpace(RunId))
        {
            return;
        }

        ApplyingAllSuggestions = true;
        AutoFixSummaryText = null;
        AutoFixFailureMessages = [];
        Error = null;

        try
        {
            var summary = await AutoHardeningService.AutoFixAllAsync(RunId, null);
            HandleApplySummary(summary, "Auto-fix all");
        }
        catch (Exception ex)
        {
            Error = $"Failed to auto-fix simulator recommendations: {ex.Message}";
            Toast.Show("Simulator", Error, "danger");
        }
        finally
        {
            ApplyingAllSuggestions = false;
        }
    }

    private void HandleApplySummary(HIP.Admin.Models.AutoFixAllApplySummary summary, string label)
    {
        AutoFixSummaryText = $"{label}: attempted {summary.Attempted}, created {summary.Created}, skipped {summary.Skipped}, failed {summary.Failed}.";

        foreach (var detail in summary.Details.Where(x => string.Equals(x.Outcome, "created", StringComparison.OrdinalIgnoreCase)))
        {
            Added.Add(detail.RecommendationId);
        }

        AutoFixFailureMessages = summary.Details
            .Where(x => string.Equals(x.Outcome, "failed", StringComparison.OrdinalIgnoreCase))
            .Select(x => $"{x.RuleId}: {x.Message}")
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(5)
            .ToList();

        Toast.Show("Simulator", AutoFixSummaryText, summary.Failed > 0 ? "warning" : "success");
    }

    private async Task AddSuggestionAsync(string suggestionKey, HIP.Simulator.Core.Models.PolicySuggestion suggestion)
    {
        if (Applying.Contains(suggestionKey) || Added.Contains(suggestionKey))
        {
            return;
        }

        Applying.Add(suggestionKey);
        Error = null;

        try
        {
            var normalizedCategory = NormalizeCategory(suggestion.Category);
            var rule = new PolicyRule
            {
                RuleId = suggestion.RuleName.Replace('.', '-').Replace(' ', '-'),
                Name = suggestion.RuleName,
                Category = normalizedCategory,
                Condition = suggestion.ConditionExpression,
                Action = suggestion.RecommendedAction,
                Severity = suggestion.RecommendedSeverity,
                Enabled = false
            };

            var save = await Api.UpsertPolicyRuleAsync(rule);
            if (save.Success)
            {
                Added.Add(suggestionKey);
                Toast.Show("Simulator", $"Policy suggestion added for '{suggestionKey}'.", "success");
            }
            else
            {
                Error = save.Error ?? "Failed to add suggested policy.";
                Toast.Show("Simulator", Error, "danger");
            }
        }
        catch (Exception ex)
        {
            Error = $"Failed to add suggested policy: {ex.Message}";
            Toast.Show("Simulator", Error, "danger");
        }
        finally
        {
            Applying.Remove(suggestionKey);
        }
    }

    private List<HIP.Simulator.Core.Models.ScenarioResult> GetLiveComparisons()
        => Result?.Scenarios
            .Where(x => x.LiveComparison is not null)
            .ToList()
            ?? [];

    private IReadOnlyList<SuggestionViewModel> GetDisplayedSuggestions()
    {
        if (Result is null)
        {
            return [];
        }

        var scenarioSuggestions = Result.Scenarios
            .Where(x => x.Suggestion is not null)
            .Select(x => new SuggestionViewModel($"scenario:{x.ScenarioId}", "Scenario", x.ScenarioId, x.Suggestion!))
            .ToList();

        if (scenarioSuggestions.Count > 0)
        {
            return scenarioSuggestions;
        }

        if (ThreatCoverage?.UncoveredItems is null || ThreatCoverage.UncoveredItems.Count == 0)
        {
            return [];
        }

        return ThreatCoverage.UncoveredItems
            .OrderByDescending(x => x.IsInScope)
            .ThenBy(x => x.Threat.ThreatId, StringComparer.OrdinalIgnoreCase)
            .Select(x => x.Threat)
            .Select(t => new SuggestionViewModel($"threat:{t.ThreatId}", "Threat", t.ThreatId, BuildFallbackSuggestionFromThreat(t)))
            .ToList();
    }

    private static HIP.Simulator.Core.Models.PolicySuggestion BuildFallbackSuggestionFromThreat(HIP.Simulator.Core.Models.ThreatCatalogItem threat)
    {
        var normalizedThreatId = threat.ThreatId.Trim().ToUpperInvariant();
        var normalizedFamily = string.IsNullOrWhiteSpace(threat.Family) ? "risk" : threat.Family.Trim().ToLowerInvariant();
        var severity = threat.Severity.Trim().ToLowerInvariant() switch
        {
            "critical" => "High",
            "high" => "High",
            "medium" => "Medium",
            "low" => "Low",
            _ => "Medium"
        };

        return new HIP.Simulator.Core.Models.PolicySuggestion(
            RuleName: $"Sim.Threat.{normalizedThreatId}.Draft",
            Category: "uncovered",
            ConditionExpression: $"threatTaxonomyId == '{normalizedThreatId}'",
            RecommendedAction: severity == "High" ? "Challenge" : "Alert",
            RecommendedSeverity: severity,
            Reason: $"Uncovered taxonomy threat: {threat.Title}",
            NeededSignals: ["threatTaxonomyId", "eventType", "actorId"],
            PositiveTestCase: $"{normalizedThreatId} event marked as {normalizedFamily}",
            NegativeTestCase: $"Event not mapped to {normalizedThreatId}",
            Notes: "Draft-safe fallback suggestion generated from uncovered taxonomy threat. Review and tune before enabling.");
    }

    private static string GetCampaignProfileSubtitle(string profile)
        => profile.Trim().ToLowerInvariant() switch
        {
            "aggressive" => "Covers the widest set of suites, including noisy/high-pressure checks.",
            "stealth" => "Runs a quieter mix focused on low-noise detection gaps.",
            "insider" => "Focuses on session/reputation insider-risk behavior and invalid flows.",
            _ => "Balanced baseline across core suites for day-to-day health checks."
        };

    private static string NormalizeCategory(string? category)
    {
        if (string.IsNullOrWhiteSpace(category)) return "Risk";

        return category.Trim().ToLowerInvariant() switch
        {
            "authentication" => "Login",
            "device" => "Device",
            "token" => "Token",
            "messaging" => "Messaging",
            "reputation" => "Reputation",
            "session" => "Session",
            "uncovered" => "Risk",
            "invalid" => "System",
            "risk" => "Risk",
            "system" => "System",
            _ => "Risk"
        };
    }

    private Task CancelAsync()
    {
        if (!string.IsNullOrWhiteSpace(RunId))
        {
            SimulatorService.Cancel(RunId);
            Status = "cancelling";
        }

        return Task.CompletedTask;
    }

    private Task RunWhatIf()
    {
        var unknownDevice = WhatIfDeviceTrust.Equals("Unknown", StringComparison.OrdinalIgnoreCase);
        var highRiskCountry = WhatIfCountry is "Russia" or "China";
        var shouldBlock = unknownDevice && (WhatIfReputation < 40 || highRiskCountry);
        var shouldChallenge = !shouldBlock && (unknownDevice || WhatIfReputation < 60);

        WhatIfResult = shouldBlock
            ? "System response: ✔ Impossible travel detected · ✔ MFA challenge · ✔ Reputation drop · ✔ Login blocked"
            : shouldChallenge
                ? "System response: ✔ Risk detected · ✔ MFA challenge issued · ✔ Session monitored"
                : "System response: ✔ Login allowed with normal monitoring";

        return Task.CompletedTask;
    }

    private sealed record SuggestionViewModel(string Key, string Label, string DisplayId, HIP.Simulator.Core.Models.PolicySuggestion Suggestion);
}
