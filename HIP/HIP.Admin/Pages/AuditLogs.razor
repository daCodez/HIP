@page "/audit-logs"
@inject HipAdminApiClient Api

<PageTitle>Audit Logs</PageTitle>

<PageHeader Title="Audit Logs"
            Subtitle="Find, review, and export audit records you can rely on"
            LastUpdatedUtc="@_lastUpdatedUtc"
            Breadcrumbs="@_breadcrumbs">
    <Actions>
        <button type="button" class="btn btn-outline-secondary" @onclick="ReloadAsync">Refresh</button>
        <button type="button" class="btn btn-primary" @onclick="QueueExportAsync" disabled="@(_state == StateViewMode.Loading || _filtered.Count == 0)">Export current results</button>
    </Actions>
</PageHeader>

@if (_state == StateViewMode.Error)
{
    <AlertBanner Kind="AlertBannerKind.Error" Title="Audit logs unavailable" Message="@_error" />
}

@if (!string.IsNullOrWhiteSpace(_exportBannerMessage))
{
    <AlertBanner Kind="@_exportBannerKind" Title="Export job" Message="@_exportBannerMessage">
        <Actions>
            @if (_exportState == ExportJobState.Failed)
            {
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="QueueExportAsync">Retry export</button>
            }
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="(() => _isExportDialogOpen = true)">View status</button>
        </Actions>
    </AlertBanner>
}

<FilterBar SearchText="@_searchText"
           SearchTextChanged="OnSearchTextChanged"
           SearchPlaceholder="Search actor, event, target, or detail"
           Fields="@_filters"
           OnChanged="OnFiltersChanged">
    <Actions>
        <label class="visually-hidden" for="corr-jump">Correlation ID quick jump</label>
        <input id="corr-jump"
               class="form-control"
               style="min-width: 220px;"
               placeholder="Correlation ID"
               value="@_correlationJump"
               @oninput="OnCorrelationInput"
               @onkeydown="OnCorrelationKeyDown" />
        <button type="button" class="btn btn-outline-primary" @onclick="JumpToCorrelation">Jump</button>
    </Actions>
</FilterBar>

<div class="small text-muted mb-2" aria-live="polite">
    Showing @_filtered.Count / @_items.Count results
    @if (_activeSummaryChips.Count > 0)
    {
        <span class="ms-2">• Active filters:</span>
        @foreach (var chip in _activeSummaryChips)
        {
            <span class="badge text-bg-light border ms-1">@chip</span>
        }
    }
</div>

<StateView Mode="@_state"
           EmptyMessage="No audit events have been recorded yet."
           FilteredMessage="No audit entries match the selected filters."
           ErrorMessage="@_error"
           OnRetry="ReloadAsync">
    <div class="row g-3">
        <div class="col-lg-8">
            <DataTable TItem="AuditViewRow"
                       Title="Audit results"
                       Caption="Audit records with severity and status shown beyond color cues"
                       Items="@_filtered"
                       Columns="@_columns"
                       EmptyMessage="No audit records for this selection."
                       ShowSearch="false"
                       IsRowSelected="@(x => _selected?.Id == x.Id)"
                       OnRowClick="OnRowSelected" />
        </div>

        <aside class="col-lg-4" aria-live="polite" aria-label="Audit timeline details">
            <section class="card">
                <div class="card-body">
                    <h2 class="h6">Timeline detail</h2>
                    @if (_selected is null)
                    {
                        <p class="text-muted mb-0">Select a row to view the event timeline and record details.</p>
                    }
                    else
                    {
                        <p class="mb-2"><strong>@_selected.EventLabel</strong></p>
                        <p class="mb-1">Severity: <StatusBadge Severity="@_selected.Severity" /></p>
                        <p class="mb-2">Status: <StatusBadge Status="@_selected.Status" /></p>
                        <ul class="small mb-0">
                            @foreach (var line in _selected.Timeline)
                            {
                                <li>@line</li>
                            }
                        </ul>
                    }
                </div>
            </section>
        </aside>
    </div>
</StateView>

<ModalDialog IsOpen="@_isExportDialogOpen"
             Title="Audit export status"
             ConfirmText="Close"
             CancelText="Close"
             OnClose="CloseExportDialog"
             OnConfirm="CloseExportDialog">
    <Body>
        <p class="mb-1">Current job status: <StatusBadge Status="@MapExportStatus(_exportState)" /></p>
        <p class="mb-1">Rows selected: @_filtered.Count</p>
        <p class="mb-1">Format: CSV (placeholder)</p>
        @if (!string.IsNullOrWhiteSpace(_exportError))
        {
            <p class="text-danger mb-0">Failure reason: @_exportError</p>
        }
    </Body>
</ModalDialog>

@code {
    private readonly IReadOnlyList<BreadcrumbItem> _breadcrumbs = [new("Dashboard", "/"), new("Audit Logs", "/audit-logs")];

    private readonly List<AuditViewRow> _items = [];
    private List<AuditViewRow> _filtered = [];
    private AuditViewRow? _selected;

    private DateTimeOffset? _lastUpdatedUtc;
    private StateViewMode _state = StateViewMode.Loading;
    private string _error = "Please try again.";

    private string _searchText = string.Empty;
    private string _correlationJump = string.Empty;
    private List<string> _activeSummaryChips = [];

    private bool _isExportDialogOpen;
    private ExportJobState _exportState = ExportJobState.None;
    private string? _exportError;
    private string? _exportBannerMessage;
    private AlertBannerKind _exportBannerKind = AlertBannerKind.Info;

    private readonly List<FilterField> _filters =
    [
        new()
        {
            Key = "preset",
            Label = "Preset",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "All activity" },
                new FilterFieldOption { Value = "critical-last24h", Label = "Critical + last 24h" },
                new FilterFieldOption { Value = "auth-denied", Label = "Authentication denied" },
                new FilterFieldOption { Value = "policy-review", Label = "Policy review queue" }
            ]
        },
        new()
        {
            Key = "severity",
            Label = "Severity",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "All severities" },
                new FilterFieldOption { Value = "critical", Label = "Critical" },
                new FilterFieldOption { Value = "high", Label = "High" },
                new FilterFieldOption { Value = "medium", Label = "Medium" },
                new FilterFieldOption { Value = "low", Label = "Low" }
            ]
        },
        new()
        {
            Key = "status",
            Label = "Status",
            Value = "all",
            Options =
            [
                new FilterFieldOption { Value = "all", Label = "All statuses" },
                new FilterFieldOption { Value = "new", Label = "New" },
                new FilterFieldOption { Value = "acknowledged", Label = "Acknowledged" },
                new FilterFieldOption { Value = "inprogress", Label = "In Progress" },
                new FilterFieldOption { Value = "resolved", Label = "Resolved" },
                new FilterFieldOption { Value = "failed", Label = "Failed" }
            ]
        },
        new()
        {
            Key = "window",
            Label = "Window",
            Value = "24h",
            Options =
            [
                new FilterFieldOption { Value = "24h", Label = "Last 24h" },
                new FilterFieldOption { Value = "7d", Label = "Last 7d" },
                new FilterFieldOption { Value = "30d", Label = "Last 30d" }
            ]
        }
    ];

    private readonly IReadOnlyList<DataTableColumn<AuditViewRow>> _columns =
    [
        new() { Header = "Time", ValueSelector = x => x.Timestamp.ToLocalTime().ToString("u"), SortSelector = x => x.Timestamp },
        new() { Header = "Severity", CellTemplate = row => @<StatusBadge Severity="@row.Severity" />, SortSelector = x => x.Severity },
        new() { Header = "Status", CellTemplate = row => @<StatusBadge Status="@row.Status" />, SortSelector = x => x.Status },
        new() { Header = "Actor", ValueSelector = x => x.Actor, SortSelector = x => x.Actor },
        new() { Header = "Event", ValueSelector = x => x.EventLabel, SortSelector = x => x.EventLabel },
        new() { Header = "Target", ValueSelector = x => x.Target, SortSelector = x => x.Target },
        new() { Header = "Correlation", ValueSelector = x => x.CorrelationId, SortSelector = x => x.CorrelationId }
    ];

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _state = StateViewMode.Loading;
        _error = "Please try again.";

        var response = await Api.GetAuditLogsAsync();
        _items.Clear();

        if (!response.Success)
        {
            _state = StateViewMode.Error;
            _error = response.Error ?? "Unable to load audit logs.";
            return;
        }

        if (response.Data is { Count: > 0 })
        {
            _items.AddRange(response.Data.Select(MapAuditRow));
        }

        ApplyFilters(new FilterBarChangeSet
        {
            SearchText = _searchText,
            Values = _filters.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase)
        });

        _selected = _filtered.FirstOrDefault();
        _lastUpdatedUtc = DateTimeOffset.UtcNow;
        _state = _items.Count == 0
            ? StateViewMode.EmptyTrue
            : _filtered.Count == 0
                ? StateViewMode.EmptyFiltered
                : StateViewMode.Success;
    }

    private Task OnSearchTextChanged(string value)
    {
        _searchText = value;
        return Task.CompletedTask;
    }

    private Task OnCorrelationInput(ChangeEventArgs args)
    {
        _correlationJump = args.Value?.ToString() ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnCorrelationKeyDown(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or "NumpadEnter")
        {
            JumpToCorrelation();
        }

        return Task.CompletedTask;
    }

    private Task OnFiltersChanged(FilterBarChangeSet changeSet)
    {
        ApplyFilters(changeSet);

        _selected = _filtered.FirstOrDefault(x => x.Id == _selected?.Id) ?? _filtered.FirstOrDefault();
        _state = _items.Count == 0
            ? StateViewMode.EmptyTrue
            : _filtered.Count == 0
                ? StateViewMode.EmptyFiltered
                : StateViewMode.Success;

        return Task.CompletedTask;
    }

    private Task OnRowSelected(AuditViewRow row)
    {
        _selected = row;
        return Task.CompletedTask;
    }

    private void ApplyFilters(FilterBarChangeSet changeSet)
    {
        var preset = ReadValue(changeSet, "preset", "all");
        var severity = ReadValue(changeSet, "severity", "all");
        var status = ReadValue(changeSet, "status", "all");
        var window = ReadValue(changeSet, "window", "24h");

        if (preset == "critical-last24h")
        {
            severity = "critical";
            status = "all";
            window = "24h";
        }
        else if (preset == "auth-denied")
        {
            severity = "high";
            status = "failed";
            window = "7d";
        }
        else if (preset == "policy-review")
        {
            severity = "medium";
            status = "acknowledged";
            window = "7d";
        }

        var threshold = window switch
        {
            "7d" => DateTime.UtcNow.AddDays(-7),
            "30d" => DateTime.UtcNow.AddDays(-30),
            _ => DateTime.UtcNow.AddHours(-24)
        };

        _filtered = _items
            .Where(x => x.Timestamp >= threshold)
            .Where(x => string.IsNullOrWhiteSpace(changeSet.SearchText)
                        || x.Actor.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.EventLabel.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.Target.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.Detail.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase)
                        || x.CorrelationId.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase))
            .Where(x => AdminUiSemantics.MatchesSeverity(x.Severity, severity))
            .Where(x => AdminUiSemantics.MatchesStatus(x.Status, status))
            .OrderByDescending(x => x.Timestamp)
            .ToList();

        var chips = new List<string>();
        if (preset != "all") chips.Add($"Preset: {preset}");
        if (severity != "all") chips.Add($"Severity: {severity}");
        if (status != "all") chips.Add($"Status: {NormalizeStatusChip(status)}");
        if (window != "24h") chips.Add($"Window: {window}");
        _activeSummaryChips = chips;
    }

    private void JumpToCorrelation()
    {
        if (string.IsNullOrWhiteSpace(_correlationJump))
        {
            return;
        }

        var match = _filtered.FirstOrDefault(x => x.CorrelationId.Contains(_correlationJump.Trim(), StringComparison.OrdinalIgnoreCase));
        if (match is null)
        {
            _exportBannerKind = AlertBannerKind.Warning;
            _exportBannerMessage = "No row matched that correlation ID in the current filtered set.";
            return;
        }

        _selected = match;
        _exportBannerKind = AlertBannerKind.Info;
        _exportBannerMessage = $"Jumped to correlation {match.CorrelationId}.";
    }

    private async Task QueueExportAsync()
    {
        _isExportDialogOpen = true;
        _exportError = null;

        _exportState = ExportJobState.Queued;
        SetExportBanner(AlertBannerKind.Info, "Export queued. Your audit package is waiting for processing.");

        await Task.Delay(250);
        _exportState = ExportJobState.Processing;
        SetExportBanner(AlertBannerKind.Info, "Export processing started.");

        await Task.Delay(350);

        if (_filtered.Count > 150)
        {
            _exportState = ExportJobState.Failed;
            _exportError = "Result set too large for MVP export placeholder. Refine filters and retry.";
            SetExportBanner(AlertBannerKind.Error, "Export failed. Reduce scope and retry.");
            return;
        }

        _exportState = ExportJobState.Completed;
        SetExportBanner(AlertBannerKind.Success, "Export completed (placeholder). Download wiring will attach to backend job endpoint.");
    }

    private Task CloseExportDialog()
    {
        _isExportDialogOpen = false;
        return Task.CompletedTask;
    }

    private void SetExportBanner(AlertBannerKind kind, string message)
    {
        _exportBannerKind = kind;
        _exportBannerMessage = message;
    }

    private static WorkflowStatus MapExportStatus(ExportJobState state)
        => state switch
        {
            ExportJobState.Queued => WorkflowStatus.Queued,
            ExportJobState.Processing => WorkflowStatus.InProgress,
            ExportJobState.Completed => WorkflowStatus.Resolved,
            ExportJobState.Failed => WorkflowStatus.Failed,
            _ => WorkflowStatus.New
        };

    private static string ReadValue(FilterBarChangeSet changeSet, string key, string fallback)
        => changeSet.Values.TryGetValue(key, out var value)
            ? value ?? fallback
            : fallback;

    private static string NormalizeStatusChip(string status)
    {
        if (Enum.TryParse<WorkflowStatus>(status, ignoreCase: true, out var parsedStatus))
        {
            return AdminUiSemantics.ToDisplayStatus(parsedStatus);
        }

        return status;
    }

    private static AuditViewRow MapAuditRow(AuditLogEntry entry)
    {
        var severity = AdminUiSemantics.ParseSeverity(entry.Severity, entry.Result);
        var status = InferStatus(entry.Result, severity, entry.Timestamp);
        var correlation = $"corr-{entry.Timestamp:yyyyMMddHHmm}-{Math.Abs((entry.Actor + entry.EventType).GetHashCode()) % 10000:0000}";

        return new AuditViewRow
        {
            Id = Guid.NewGuid().ToString("N"),
            Timestamp = entry.Timestamp,
            Actor = entry.Actor,
            EventLabel = entry.EventType.Replace('.', ' '),
            Target = entry.Category,
            Severity = severity,
            Status = status,
            Detail = entry.Detail,
            CorrelationId = correlation,
            Timeline =
            [
                $"{entry.Timestamp:u}: Event observed ({entry.Result})",
                $"{entry.Timestamp.AddMinutes(1):u}: Correlation linked ({correlation})",
                $"{entry.Timestamp.AddMinutes(2):u}: Workflow state {FormatStatus(status)}"
            ]
        };
    }

    private static WorkflowStatus InferStatus(string result, SeverityLevel severity, DateTime timestamp)
    {
        if (result.Equals("Denied", StringComparison.OrdinalIgnoreCase))
        {
            return WorkflowStatus.Failed;
        }

        if (severity == SeverityLevel.Critical)
        {
            return WorkflowStatus.Escalated;
        }

        return timestamp < DateTime.UtcNow.AddHours(-12)
            ? WorkflowStatus.Resolved
            : WorkflowStatus.Acknowledged;
    }

    private static string FormatStatus(WorkflowStatus status)
        => AdminUiSemantics.ToDisplayStatus(status);

    private sealed class AuditViewRow
    {
        public required string Id { get; init; }
        public required DateTime Timestamp { get; init; }
        public required string Actor { get; init; }
        public required string EventLabel { get; init; }
        public required string Target { get; init; }
        public required SeverityLevel Severity { get; init; }
        public required WorkflowStatus Status { get; init; }
        public required string Detail { get; init; }
        public required string CorrelationId { get; init; }
        public List<string> Timeline { get; init; } = [];
    }

    private enum ExportJobState
    {
        None,
        Queued,
        Processing,
        Completed,
        Failed
    }
}
