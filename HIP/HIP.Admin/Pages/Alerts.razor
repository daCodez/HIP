    private Task BlockIpAsync() => ApplySuggestedAction("Block IP");
    private Task LockAccountAsync() => ApplySuggestedAction("Lock Account");
    private Task RequireMfaAsync() => ApplySuggestedAction("Require MFA");
    private Task InvestigateAsync() => ApplySuggestedAction("Investigate");

    private Task AnalyzeIncidentAsync()
    {
        if (_selected is null) return Task.CompletedTask;
        _aiAnalysis = "Likely cause: credential stuffing attempt · Confidence: 82% · Suggested response: Require MFA + session reset.";
        return Task.CompletedTask;
    }

    private void SyncOwnerOptions()
    {
        var ownerField = _filters.First(x => x.Key == "owner");
        var owners = _items.Select(x => x.Owner).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x).ToList();
        ownerField.Options = [new FilterFieldOption { Value = "all", Label = "Any owner" }, ..owners.Select(owner => new FilterFieldOption { Value = owner, Label = owner })];
    }

    private static List<AlertQueueItem> Deduplicate(List<AlertQueueItem> queue)
        => queue.GroupBy(x => $"{x.RawEvent}|{x.Actor}|{x.Source}|{x.IncidentId}")
            .Select(g =>
            {
                var first = g.OrderByDescending(x => x.Timestamp).First();
                first.DedupCount = g.Count();
                if (first.DedupCount > 1) first.HumanTitle = $"{first.HumanTitle} ({first.DedupCount})";
                return first;
            }).ToList();

    private static AlertQueueItem ToAlertQueueItem(AuditLogEntry entry, int index)
    {
        var result = entry.Result ?? "Unknown";
        var eventType = entry.EventType ?? "unknown.event";
        var severity = AdminUiSemantics.ParseSeverity(entry.Severity, result);
        var incidentId = InferIncidentId(entry, index);
        var rawEvent = eventType.ToLowerInvariant();
        var source = InferSource(entry);
        var human = ToHumanTitle(rawEvent);
        var risk = ComputeRisk(severity, rawEvent, result);

        return new AlertQueueItem
        {
            Id = $"alert-{index}-{entry.Timestamp:yyyyMMddHHmmss}",
            Timestamp = entry.Timestamp,
            RawEvent = rawEvent,
            HumanTitle = human,
            Icon = MapIcon(rawEvent),
            Actor = entry.Actor,
            Owner = index % 2 == 0 ? "Analyst" : "SOC Tier 1",
            Source = source,
            IncidentId = incidentId,
            RiskScore = risk,
            Severity = severity,
            Status = InferStatus(risk, result, entry.Timestamp),
            Device = index % 2 == 0 ? "iPhone 15" : "MacBook Pro",
            IpAddress = $"212.44.92.{10 + (index % 80)}",
            Location = index % 2 == 0 ? "Warsaw, Poland" : "Berlin, Germany",
            Reputation = Math.Clamp(100 - risk, 10, 99),
            UserTrustScore = Math.Clamp(100 - (risk / 2), 1, 100),
            RiskFactors = ["New device", "New country", "TOR proxy", "Reputation < 40"],
            WhyTriggered = ["login country changed", "previous login 10 minutes ago", "distance > 4000km"],
            SuggestedActions = ["Require MFA", "Challenge login", "Block IP"],
            RelatedAlerts = ["login.impossible_travel", "device.untrusted", "session.ip_change"],
            Timeline = [
                $"{entry.Timestamp:u} Alert detected",
                $"{entry.Timestamp.AddMinutes(1):u} Policy evaluated",
                $"{entry.Timestamp.AddMinutes(2):u} Correlation complete"
            ]
        };
    }

    private static WorkflowStatus InferStatus(int risk, string result, DateTime timestamp)
    {
        if (risk >= 90) return WorkflowStatus.New;
        if (risk >= 75) return WorkflowStatus.Investigating;
        if (string.Equals(result, "Denied", StringComparison.OrdinalIgnoreCase)) return WorkflowStatus.Mitigated;
        if (timestamp < DateTime.UtcNow.AddHours(-12)) return WorkflowStatus.Resolved;
        return WorkflowStatus.Acknowledged;
    }

    private static int ComputeRisk(SeverityLevel severity, string rawEvent, string result)
    {
        var score = severity switch { SeverityLevel.Critical => 92, SeverityLevel.High => 78, SeverityLevel.Medium => 54, SeverityLevel.Low => 28, _ => 12 };
        if (rawEvent.Contains("impossible") || rawEvent.Contains("takeover")) score += 10;
        if (rawEvent.Contains("reputation")) score -= 8;
        if (string.Equals(result, "Denied", StringComparison.OrdinalIgnoreCase)) score += 6;
        return Math.Clamp(score, 0, 100);
    }

    private static string InferSource(AuditLogEntry entry)
    {
        var text = $"{entry.Category} {entry.EventType}".ToLowerInvariant();
        if (text.Contains("gmail")) return "Gmail";
        if (text.Contains("slack")) return "Slack";
        if (text.Contains("device")) return "Device";
        if (text.Contains("browser")) return "Browser";
        if (text.Contains("api")) return "API";
        return "HIP";
    }

    private static string InferIncidentId(AuditLogEntry entry, int index)
    {
        var marker = "INC-";
        var detail = entry.Detail ?? string.Empty;
        var pos = detail.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        if (pos >= 0)
        {
            var suffix = detail.Substring(pos).Split(' ', ')', ']', ';', ',')[0];
            return suffix.ToUpperInvariant();
        }
        return $"INC-{2300 + (index % 30)}";
    }

    private static string ToHumanTitle(string rawEvent) => rawEvent switch
    {
        var e when e.Contains("reputation.read") => "User reputation accessed",
        var e when e.Contains("identity.read") => "Identity lookup performed",
        var e when e.Contains("impossible") => "Impossible travel login",
        var e when e.Contains("suspicious") => "Suspicious login detected",
        _ => rawEvent.Replace('.', ' ').Replace('_', ' ')
    };

    private static string MapIcon(string rawEvent) => rawEvent switch
    {
        var e when e.Contains("login") => "🔐",
        var e when e.Contains("device") => "📱",
        var e when e.Contains("reputation") => "⭐",
        var e when e.Contains("spam") => "📧",
        var e when e.Contains("token") => "🔑",
        var e when e.Contains("policy") => "⚖️",
        _ => "🛡️"
    };

    private bool CanAcknowledge(AlertQueueItem item) => item.Status is WorkflowStatus.New or WorkflowStatus.Escalated;
    private bool CanEscalate(AlertQueueItem item) => AdminContext.CurrentRole is AdminRole.Admin or AdminRole.Analyst && item.Status is WorkflowStatus.New or WorkflowStatus.Acknowledged or WorkflowStatus.Investigating;
    private bool CanResolve(AlertQueueItem item) => AdminContext.CurrentRole == AdminRole.Admin && item.Status is WorkflowStatus.Acknowledged or WorkflowStatus.Escalated or WorkflowStatus.InProgress or WorkflowStatus.Mitigated;
    private static string FormatStatus(WorkflowStatus status) => AdminUiSemantics.ToDisplayStatus(status);

    private sealed class AlertQueueItem
    {
        public required string Id { get; init; }
        public required DateTime Timestamp { get; init; }
        public required string RawEvent { get; init; }
        public required string HumanTitle { get; set; }
        public required string Icon { get; init; }
        public required string Actor { get; init; }
        public required string Owner { get; init; }
        public required string Source { get; init; }
        public required string IncidentId { get; init; }
        public required int RiskScore { get; init; }
        public required SeverityLevel Severity { get; init; }
        public WorkflowStatus Status { get; set; }
        public int DedupCount { get; set; }
        public required string Device { get; init; }
        public required string IpAddress { get; init; }
        public required string Location { get; init; }
        public required int Reputation { get; init; }
        public required int UserTrustScore { get; init; }
        public List<string> RiskFactors { get; init; } = [];
        public List<string> WhyTriggered { get; init; } = [];
        public List<string> SuggestedActions { get; init; } = [];
        public List<string> RelatedAlerts { get; init; } = [];
        public List<string> Timeline { get; init; } = [];
    }
}
