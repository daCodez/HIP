@page "/alerts"
@attribute [Authorize]
@page "/admin/alerts"
@implements IDisposable
@inject HipAdminApiClient Api
@inject AdminContextService AdminContext

<PageTitle>Alerts &amp; Incidents</PageTitle>

<PageHeader Title="SOC Alerts &amp; Incidents"
            Subtitle="Threat Overview · Active Incidents · Alert Queue · build-marker: 0801"
            LastUpdatedUtc="@_lastUpdatedUtc"
            Breadcrumbs="@_breadcrumbs">
    <Actions>
        <div class="hip-alerts-header-counts" aria-label="Queue counts by status">
            <span class="hip-alerts-count-chip">Alerts (1h): @_lastHourAlerts</span>
            <span class="hip-alerts-count-chip">Critical: @_severityCounts.GetValueOrDefault(SeverityLevel.Critical)</span>
            <span class="hip-alerts-count-chip">High: @_severityCounts.GetValueOrDefault(SeverityLevel.High)</span>
            <span class="hip-alerts-count-chip">Medium: @_severityCounts.GetValueOrDefault(SeverityLevel.Medium)</span>
            <span class="hip-alerts-count-chip">Low: @_severityCounts.GetValueOrDefault(SeverityLevel.Low)</span>
            <span class="hip-alerts-count-chip">Info: @_severityCounts.GetValueOrDefault(SeverityLevel.Info)</span>
        </div>
        <label class="form-check form-switch mb-0" title="Refresh queue every 15 seconds">
            <input class="form-check-input" type="checkbox" checked="@_liveMode" @onchange="OnLiveModeChanged" />
            <span class="form-check-label ms-1">Live alerts: @(_liveMode ? "ON" : "OFF")</span>
        </label>
        <button type="button" class="btn btn-outline-secondary" @onclick="ReloadAsync">Refresh</button>
    </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(_actionFeedback))
{
    <AlertBanner Kind="@_actionFeedbackKind" Title="Queue update" Message="@_actionFeedback" />
}

@if (_state == StateViewMode.Error)
{
    <AlertBanner Kind="AlertBannerKind.Error" Title="Alerts unavailable" Message="@_error" />
}

<div class="hip-overview-metrics">
    <MetricCard Title="Threat Level" Value="@_threatLevel" Trend="up" Delta="@($"Active incidents: {_activeIncidentCount}")" />
    <MetricCard Title="Blocked Attempts" Value="@_blockedAttempts.ToString()" Trend="up" Delta="last hour" />
    <MetricCard Title="Alerts Last Hour" Value="@_lastHourAlerts.ToString()" Trend="up" Delta="queue volume" />
    <MetricCard Title="User Trust Score" Value="@(_selected?.UserTrustScore.ToString() ?? "--")" Trend="up" Delta="30-day: stable" />
</div>

<div class="hip-alerts-quick-filters mb-3">
    @foreach (var quick in _quickFilters)
    {
        <button type="button" class="btn btn-sm @(quick == _quickFilter ? "btn-primary" : "btn-outline-secondary")" @onclick="() => SetQuickFilter(quick)">@quick</button>
    }
</div>

<FilterBar SearchText="@_searchText"
           SearchTextChanged="OnSearchTextChanged"
           SearchPlaceholder="Search alerts"
           Fields="@_filters"
           OnChanged="OnFiltersChanged">
    <Actions>
        <button type="button" class="btn btn-primary" @onclick="ReloadAsync">Apply</button>
    </Actions>
</FilterBar>

<StateView Mode="@_state"
           EmptyMessage="No alerts or incidents have been detected yet."
           FilteredMessage="No queue items match the selected filters."
           ErrorMessage="@_error"
           OnRetry="ReloadAsync">
    <div class="hip-alerts-split-layout" tabindex="0" @onkeydown="HandleKeyboard">
        <div>
            <DataTable TItem="AlertQueueItem"
                       Title="Alert queue"
                       Caption="SOC queue with severity, risk, source and incident correlation"
                       Items="@_filteredItems"
                       Columns="@_columns"
                       EmptyMessage="No queue items available for the current filters."
                       ShowSearch="false"
                       IsRowSelected="@(x => _selected?.Id == x.Id)"
                       OnRowClick="OnRowSelected" />
        </div>

        <aside class="hip-alerts-detail" aria-live="polite" aria-label="Selected alert details">
            @if (_selected is null)
            {
                <p class="hip-state-title">No item selected</p>
                <p class="hip-state-subtitle">Select a row to review actor, risk factors, related alerts, and actions.</p>
            }
            else
            {
                <header class="d-flex justify-content-between gap-2 flex-wrap align-items-start">
                    <div>
                        <h2 class="h5 mb-1">@_selected.Icon @_selected.HumanTitle</h2>
                        <p class="text-muted mb-2">Raw event: @_selected.RawEvent</p>
                        <p class="mb-2">Source: @_selected.Source · Incident: @_selected.IncidentId</p>
                        <p class="mb-2">
                            Risk: <strong>@_selected.RiskScore</strong>/100
                            <span class="mx-1">|</span>
                            Severity: <StatusBadge Severity="@_selected.Severity" />
                            <span class="mx-1">|</span>
                            Status: <StatusBadge Status="@_selected.Status" />
                        </p>
                    </div>
                </header>

                <section class="mb-3">
                    <h3 class="h6">Actor</h3>
                    <ul class="mb-0">
                        <li>User: @_selected.Actor</li>
                        <li>Device: @_selected.Device</li>
                        <li>IP: @_selected.IpAddress</li>
                        <li>Location: @_selected.Location</li>
                        <li>Reputation: @_selected.Reputation</li>
                    </ul>
                </section>

                <section class="mb-3">
                    <h3 class="h6">Risk factors</h3>
                    <ul class="mb-0">
                        @foreach (var factor in _selected.RiskFactors)
                        {
                            <li>✔ @factor</li>
                        }
                    </ul>
                </section>

                <section class="mb-3">
                    <h3 class="h6">Triggered because</h3>
                    <ul class="mb-0">
                        @foreach (var reason in _selected.WhyTriggered)
                        {
                            <li>• @reason</li>
                        }
                    </ul>
                </section>

                <section class="mb-3">
                    <h3 class="h6">Related alerts (@_selected.RelatedAlerts.Count)</h3>
                    <ul class="mb-0">
                        @foreach (var item in _selected.RelatedAlerts)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </section>

                <section class="mb-3">
                    <h3 class="h6">Suggested actions</h3>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var action in _selected.SuggestedActions)
                        {
                            <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => ApplySuggestedAction(action)">@action</button>
                        }
                        <button class="btn btn-sm btn-primary" type="button" @onclick="ApplyPolicyAsync">Apply Policy</button>
                        <button class="btn btn-sm btn-dark" type="button" @onclick="AnalyzeIncidentAsync">AI Analyze Incident</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_aiAnalysis))
                    {
                        <p class="small mt-2 mb-0">@_aiAnalysis</p>
                    }
                </section>

                <section class="mb-3">
                    <h3 class="h6">Timeline</h3>
                    <div class="hip-alert-timeline">
                        @foreach (var item in _selected.Timeline)
                        {
                            <div class="hip-alert-timeline-item">
                                <span class="dot"></span>
                                <span>@item</span>
                            </div>
                        }
                    </div>
                </section>

                <section>
                    <h3 class="h6">Quick actions</h3>
                    <p class="text-muted">Current role: @AdminContext.CurrentRole</p>
                    <div class="d-flex gap-2 flex-wrap mb-2">
                        <button type="button" class="btn btn-outline-primary" disabled="@(!CanAcknowledge(_selected))" @onclick="() => OpenActionDialog(_selected, WorkflowStatus.Acknowledged)">Acknowledge</button>
                        <button type="button" class="btn btn-outline-info" @onclick="() => OpenActionDialog(_selected, WorkflowStatus.Investigating)">Investigating</button>
                        <button type="button" class="btn btn-outline-warning" disabled="@(!CanEscalate(_selected))" @onclick="() => OpenActionDialog(_selected, WorkflowStatus.Escalated)">Escalate</button>
                        <button type="button" class="btn btn-outline-success" @onclick="() => OpenActionDialog(_selected, WorkflowStatus.Mitigated)">Mitigate</button>
                        <button type="button" class="btn btn-outline-success" disabled="@(!CanResolve(_selected))" @onclick="() => OpenActionDialog(_selected, WorkflowStatus.Resolved)">Resolve</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => OpenActionDialog(_selected, WorkflowStatus.FalsePositive)">Mark Safe</button>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-sm btn-outline-danger" type="button" @onclick="BlockIpAsync">Block IP</button>
                        <button class="btn btn-sm btn-outline-danger" type="button" @onclick="LockAccountAsync">Lock Account</button>
                        <button class="btn btn-sm btn-outline-warning" type="button" @onclick="RequireMfaAsync">Require MFA</button>
                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="InvestigateAsync">Investigate</button>
                    </div>
                </section>
            }
        </aside>
    </div>
</StateView>

<ModalDialog IsOpen="@_isActionDialogOpen"
             Title="@_dialogTitle"
             ConfirmText="Submit"
             CancelText="Cancel"
             OnClose="CloseActionDialog"
             OnConfirm="ApplyActionAsync">
    <Body>
        <p class="mb-2">Provide rationale for status change.</p>
        <label class="form-label" for="alerts-action-rationale">Rationale</label>
        <textarea id="alerts-action-rationale"
                  class="form-control"
                  rows="4"
                  placeholder="Required note for audit trail"
                  aria-invalid="@(!string.IsNullOrWhiteSpace(_dialogValidationError))"
                  aria-describedby="alerts-action-rationale-error"
                  @bind="_actionRationale"></textarea>
        @if (!string.IsNullOrWhiteSpace(_dialogValidationError))
        {
            <p id="alerts-action-rationale-error" class="text-danger mt-2 mb-0">@_dialogValidationError</p>
        }
    </Body>
</ModalDialog>

@code {
    private readonly IReadOnlyList<BreadcrumbItem> _breadcrumbs = [new("Dashboard", "/"), new("Alerts & Incidents", "/alerts")];
    private readonly List<AlertQueueItem> _items = [];
    private List<AlertQueueItem> _filteredItems = [];
    private AlertQueueItem? _selected;
    private DateTimeOffset? _lastUpdatedUtc;
    private StateViewMode _state = StateViewMode.Success;
    private string _error = "Please try again.";
    private string _searchText = string.Empty;
    private IReadOnlyDictionary<string, int> _statusCounts = new Dictionary<string, int>();
    private IReadOnlyDictionary<SeverityLevel, int> _severityCounts = new Dictionary<SeverityLevel, int>();
    private readonly string[] _quickFilters = ["All", "Critical", "My Alerts", "New Devices", "Login Alerts", "Reputation Alerts", "Spam Alerts"];
    private string _quickFilter = "All";

    private int _lastHourAlerts;
    private int _activeIncidentCount;
    private int _blockedAttempts;
    private string _threatLevel = "LOW";
    private bool _liveMode = false;
    private Timer? _liveTimer;
    private Timer? _loadingWatchdog;
    private bool _reloadInProgress;

    private string? _actionFeedback;
    private AlertBannerKind _actionFeedbackKind = AlertBannerKind.Info;
    private string? _aiAnalysis;

    private bool _isActionDialogOpen;
    private string _dialogTitle = "Update status";
    private string _actionRationale = string.Empty;
    private string? _dialogValidationError;
    private WorkflowStatus? _pendingStatus;
    private string? _pendingItemId;

    private readonly List<FilterField> _filters =
    [
        new() { Key = "severity", Label = "Severity", Value = "all", Options = [ new FilterFieldOption { Value = "all", Label = "All severities" }, new FilterFieldOption { Value = "critical", Label = "Critical" }, new FilterFieldOption { Value = "high", Label = "High" }, new FilterFieldOption { Value = "medium", Label = "Medium" }, new FilterFieldOption { Value = "low", Label = "Low" }, new FilterFieldOption { Value = "info", Label = "Info" } ] },
        new() { Key = "status", Label = "Status", Value = "all", Options = [ new FilterFieldOption { Value = "all", Label = "All statuses" }, new FilterFieldOption { Value = "new", Label = "New" }, new FilterFieldOption { Value = "investigating", Label = "Investigating" }, new FilterFieldOption { Value = "escalated", Label = "Escalated" }, new FilterFieldOption { Value = "mitigated", Label = "Mitigated" }, new FilterFieldOption { Value = "resolved", Label = "Resolved" }, new FilterFieldOption { Value = "falsepositive", Label = "False Positive" } ] },
        new() { Key = "owner", Label = "Owner", Value = "all", Options = [new FilterFieldOption { Value = "all", Label = "Any owner" }] },
        new() { Key = "window", Label = "Window", Value = "24h", Options = [new FilterFieldOption { Value = "24h", Label = "Last 24h" }, new FilterFieldOption { Value = "7d", Label = "Last 7d" }] }
    ];

    private readonly IReadOnlyList<DataTableColumn<AlertQueueItem>> _columns =
    [
        new() { Header = "Time", ValueSelector = x => x.Timestamp.ToLocalTime().ToString("HH:mm"), SortSelector = x => x.Timestamp },
        new() { Header = "Source", ValueSelector = x => x.Source, SortSelector = x => x.Source },
        new() { Header = "Event", ValueSelector = x => $"{x.Icon} {x.HumanTitle}", SortSelector = x => x.HumanTitle },
        new() { Header = "Owner", ValueSelector = x => x.Owner, SortSelector = x => x.Owner },
        new() { Header = "Risk", ValueSelector = x => x.RiskScore.ToString(), SortSelector = x => x.RiskScore },
        new() { Header = "Severity", CellTemplate = row => @<StatusBadge Severity="@row.Severity" />, SortSelector = x => x.Severity },
        new() { Header = "Status", CellTemplate = row => @<StatusBadge Status="@row.Status" />, SortSelector = x => x.Status },
        new() { Header = "Incident", ValueSelector = x => x.IncidentId, SortSelector = x => x.IncidentId }
    ];

    protected override void OnInitialized()
    {
        AdminContext.Changed += OnAdminContextChanged;
        ConfigureLiveTimer();
        ConfigureLoadingWatchdog();
        SeedFallbackItems();
        _ = ReloadAsync();
    }

    public void Dispose()
    {
        AdminContext.Changed -= OnAdminContextChanged;
        _liveTimer?.Dispose();
        _loadingWatchdog?.Dispose();
    }

    private async void OnAdminContextChanged() => await InvokeAsync(StateHasChanged);

    private Task ReloadAsync() => ReloadAsyncCore(backgroundRefresh: false);

    private async Task ReloadAsyncCore(bool backgroundRefresh)
    {
        if (_reloadInProgress)
        {
            return;
        }

        _reloadInProgress = true;
        try
        {
            // Keep page interactive with existing rows/fallback while reloading in background.

            using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            var alertsTask = Api.GetAuditLogsAsync(timeoutCts.Token);
            var completed = await Task.WhenAny(alertsTask, Task.Delay(TimeSpan.FromSeconds(12), timeoutCts.Token));
            if (completed != alertsTask)
            {
                _error = "Alerts request timed out (hard limit). Showing fallback data.";
                SeedFallbackItems();
                return;
            }

            var alerts = await alertsTask;
            _items.Clear();

            if (!alerts.Success)
            {
                _error = (alerts.Error ?? "Unable to load alert queue.") + " Showing fallback data.";
                SeedFallbackItems();
                return;
            }

            if (alerts.Data is { Count: > 0 })
            {
                var queue = alerts.Data.Take(120).Select((entry, index) => ToAlertQueueItem(entry, index)).ToList();
                _items.AddRange(Deduplicate(queue));
                SyncOwnerOptions();
            }

            ApplyFilters(new FilterBarChangeSet { SearchText = _searchText, Values = _filters.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase) });
            _selected ??= _filteredItems.FirstOrDefault();
            ComputeOverview();
            _lastUpdatedUtc = DateTimeOffset.UtcNow;
            _state = _items.Count == 0 ? StateViewMode.EmptyTrue : _filteredItems.Count == 0 ? StateViewMode.EmptyFiltered : StateViewMode.Success;
        }
        catch (OperationCanceledException)
        {
            _error = "Alerts request timed out. Showing fallback data.";
            SeedFallbackItems();
        }
        catch (Exception ex)
        {
            _error = $"Alerts failed to load: {ex.Message}. Showing fallback data.";
            SeedFallbackItems();
        }
        finally
        {
            _reloadInProgress = false;
        }
    }

    private void ConfigureLiveTimer()
    {
        _liveTimer = new Timer(async _ =>
        {
            if (!_liveMode) return;
            await InvokeAsync(() => ReloadAsyncCore(backgroundRefresh: true));
        }, null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
    }

    private void ConfigureLoadingWatchdog()
    {
        _loadingWatchdog = new Timer(_ =>
        {
            if (_state == StateViewMode.Loading)
            {
                _state = StateViewMode.Error;
                _error = "Alerts load watchdog fired. Service is not responding.";
                _reloadInProgress = false;
                _ = InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
    }

    private Task OnLiveModeChanged(ChangeEventArgs e)
    {
        _liveMode = e?.Value is true || string.Equals(e?.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase) || string.Equals(e?.Value?.ToString(), "on", StringComparison.OrdinalIgnoreCase);
        return Task.CompletedTask;
    }

    private void SeedFallbackItems()
    {
        if (_items.Count > 0)
        {
            return;
        }

        var now = DateTime.UtcNow;
        var sample = new List<AlertQueueItem>
        {
            new()
            {
                Id = "fallback-1",
                Timestamp = now.AddMinutes(-2),
                RawEvent = "login.impossible_travel",
                HumanTitle = "Impossible travel login",
                Icon = "🔐",
                Actor = "eric@example.com",
                Owner = "SOC Tier 1",
                Source = "HIP",
                IncidentId = "INC-2391",
                RiskScore = 92,
                Severity = SeverityLevel.Critical,
                Status = WorkflowStatus.New,
                Device = "iPhone 15",
                IpAddress = "212.44.92.18",
                Location = "Warsaw, Poland",
                Reputation = 32,
                UserTrustScore = 58,
                RiskFactors = ["New device", "New country", "TOR proxy", "Reputation < 40"],
                WhyTriggered = ["login country changed", "previous login 10 minutes ago", "distance > 4000km"],
                SuggestedActions = ["Require MFA", "Challenge login", "Block IP"],
                RelatedAlerts = ["login.impossible_travel", "device.untrusted", "session.ip_change"],
                Timeline = ["Alert detected", "Policy evaluated", "Correlation complete"]
            },
            new()
            {
                Id = "fallback-2",
                Timestamp = now.AddMinutes(-6),
                RawEvent = "reputation.read",
                HumanTitle = "User reputation accessed",
                Icon = "⭐",
                Actor = "soc-bot",
                Owner = "Analyst",
                Source = "HIP",
                IncidentId = "INC-2388",
                RiskScore = 12,
                Severity = SeverityLevel.Info,
                Status = WorkflowStatus.Acknowledged,
                Device = "Service",
                IpAddress = "127.0.0.1",
                Location = "Local",
                Reputation = 88,
                UserTrustScore = 91,
                RiskFactors = ["Low-risk read"],
                WhyTriggered = ["Reputation requested by policy engine"],
                SuggestedActions = ["Investigate"],
                RelatedAlerts = ["identity.read"],
                Timeline = ["Signal requested", "Read completed"]
            }
        };

        _items.Clear();
        _items.AddRange(sample);
        SyncOwnerOptions();
        ApplyFilters(new FilterBarChangeSet { SearchText = _searchText, Values = _filters.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase) });
        _selected = _filteredItems.FirstOrDefault();
        ComputeOverview();
        _lastUpdatedUtc = DateTimeOffset.UtcNow;
        _state = StateViewMode.Success;
    }

    private Task OnSearchTextChanged(string text) { _searchText = text; return Task.CompletedTask; }

    private Task OnFiltersChanged(FilterBarChangeSet changeSet)
    {
        ApplyFilters(changeSet);
        _selected = _filteredItems.FirstOrDefault(x => x.Id == _selected?.Id) ?? _filteredItems.FirstOrDefault();
        _state = _items.Count == 0 ? StateViewMode.EmptyTrue : _filteredItems.Count == 0 ? StateViewMode.EmptyFiltered : StateViewMode.Success;
        return Task.CompletedTask;
    }

    private Task OnRowSelected(AlertQueueItem item) { _selected = item; _aiAnalysis = null; return Task.CompletedTask; }

    private void SetQuickFilter(string value)
    {
        _quickFilter = value;
        ApplyFilters(new FilterBarChangeSet { SearchText = _searchText, Values = _filters.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase) });
        _selected = _filteredItems.FirstOrDefault();
    }

    private void ApplyFilters(FilterBarChangeSet changeSet)
    {
        var severity = changeSet.Values.TryGetValue("severity", out var severityValue) ? severityValue : "all";
        var status = changeSet.Values.TryGetValue("status", out var statusValue) ? statusValue : "all";
        var owner = changeSet.Values.TryGetValue("owner", out var ownerValue) ? ownerValue : "all";
        var window = changeSet.Values.TryGetValue("window", out var windowValue) ? windowValue : "24h";
        var threshold = window == "7d" ? DateTime.UtcNow.AddDays(-7) : DateTime.UtcNow.AddHours(-24);

        _filteredItems = _items
            .Where(x => x.Timestamp >= threshold)
            .Where(x => string.IsNullOrWhiteSpace(changeSet.SearchText) || x.HumanTitle.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase) || x.Actor.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase) || x.RawEvent.Contains(changeSet.SearchText, StringComparison.OrdinalIgnoreCase))
            .Where(x => AdminUiSemantics.MatchesSeverity(x.Severity, severity))
            .Where(x => AdminUiSemantics.MatchesStatus(x.Status, status))
            .Where(x => owner == "all" || x.Owner.Equals(owner, StringComparison.OrdinalIgnoreCase))
            .Where(ApplyQuickFilter)
            .OrderByDescending(x => x.RiskScore)
            .ThenByDescending(x => x.Timestamp)
            .ToList();

        _statusCounts = _filteredItems.GroupBy(x => FormatStatus(x.Status)).ToDictionary(g => g.Key, g => g.Count());
        _severityCounts = _filteredItems.GroupBy(x => x.Severity).ToDictionary(g => g.Key, g => g.Count());
    }

    private bool ApplyQuickFilter(AlertQueueItem item) => _quickFilter switch
    {
        "Critical" => item.Severity == SeverityLevel.Critical,
        "My Alerts" => item.Owner.Equals(AdminContext.CurrentRole.ToString(), StringComparison.OrdinalIgnoreCase),
        "New Devices" => item.RawEvent.Contains("device", StringComparison.OrdinalIgnoreCase),
        "Login Alerts" => item.RawEvent.Contains("login", StringComparison.OrdinalIgnoreCase),
        "Reputation Alerts" => item.RawEvent.Contains("reputation", StringComparison.OrdinalIgnoreCase),
        "Spam Alerts" => item.RawEvent.Contains("spam", StringComparison.OrdinalIgnoreCase),
        _ => true
    };

    private void ComputeOverview()
    {
        _lastHourAlerts = _items.Count(x => x.Timestamp >= DateTime.UtcNow.AddHours(-1));
        _activeIncidentCount = _items.Select(x => x.IncidentId).Distinct().Count();
        _blockedAttempts = _items.Count(x => x.Severity is SeverityLevel.Critical or SeverityLevel.High && x.RawEvent.Contains("login", StringComparison.OrdinalIgnoreCase));
        _threatLevel = _severityCounts.GetValueOrDefault(SeverityLevel.Critical) > 0 ? "HIGH" : _severityCounts.GetValueOrDefault(SeverityLevel.High) > 3 ? "ELEVATED" : "LOW";
    }

    private async Task HandleKeyboard(KeyboardEventArgs e)
    {
        if (_filteredItems.Count == 0) return;
        var idx = _selected is null ? 0 : _filteredItems.FindIndex(x => x.Id == _selected.Id);
        if (e.Key.Equals("j", StringComparison.OrdinalIgnoreCase)) _selected = _filteredItems[Math.Min(_filteredItems.Count - 1, idx + 1)];
        if (e.Key.Equals("k", StringComparison.OrdinalIgnoreCase)) _selected = _filteredItems[Math.Max(0, idx - 1)];
        if (e.Key == "Enter" && idx >= 0) _selected = _filteredItems[idx];
        if (e.Key.Equals("a", StringComparison.OrdinalIgnoreCase) && _selected is not null) OpenActionDialog(_selected, WorkflowStatus.Acknowledged);
        if (e.Key.Equals("r", StringComparison.OrdinalIgnoreCase) && _selected is not null) OpenActionDialog(_selected, WorkflowStatus.Resolved);
        if (e.Key.Equals("e", StringComparison.OrdinalIgnoreCase) && _selected is not null) OpenActionDialog(_selected, WorkflowStatus.Escalated);
        await InvokeAsync(StateHasChanged);
    }

    private void OpenActionDialog(AlertQueueItem item, WorkflowStatus targetStatus)
    {
        _pendingItemId = item.Id; _pendingStatus = targetStatus; _dialogTitle = $"Set status to {FormatStatus(targetStatus)}"; _actionRationale = string.Empty; _dialogValidationError = null; _isActionDialogOpen = true;
    }

    private Task CloseActionDialog() { _isActionDialogOpen = false; _dialogValidationError = null; return Task.CompletedTask; }

    private async Task ApplyActionAsync()
    {
        if (string.IsNullOrWhiteSpace(_actionRationale)) { _dialogValidationError = "Rationale is required for auditability."; return; }
        var item = _items.FirstOrDefault(x => x.Id == _pendingItemId);
        if (item is null || _pendingStatus is null) { await CloseActionDialog(); return; }
        item.Status = _pendingStatus.Value;
        item.Timeline.Insert(0, $"{DateTimeOffset.Now:u}: {FormatStatus(_pendingStatus.Value)} ({_actionRationale.Trim()})");
        _actionFeedback = $"Status updated to {FormatStatus(_pendingStatus.Value)}.";
        _actionFeedbackKind = AlertBannerKind.Success;
        ApplyFilters(new FilterBarChangeSet { SearchText = _searchText, Values = _filters.ToDictionary(x => x.Key, x => x.Value, StringComparer.OrdinalIgnoreCase) });
        await CloseActionDialog();
    }

    private Task ApplySuggestedAction(string action)
    {
        if (_selected is not null) _selected.Timeline.Insert(0, $"{DateTimeOffset.UtcNow:u}: Suggested action applied -> {action}");
        _actionFeedback = $"Applied action: {action}";
        _actionFeedbackKind = AlertBannerKind.Info;
        return Task.CompletedTask;
    }

