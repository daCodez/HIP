{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HIP Simulator Scenario",
  "type": "object",
  "required": ["id", "name", "category", "expectedAction", "expectedSeverity", "shouldBeCovered", "shouldBeValid"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "category": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "executionMode": { "type": "string", "enum": ["application", "protocol", "hybrid"] },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["offsetSeconds", "eventType", "actorId", "payload"],
        "properties": {
          "offsetSeconds": { "type": "integer", "minimum": 0 },
          "eventType": { "type": "string", "minLength": 1 },
          "actorId": { "type": "string", "minLength": 1 },
          "targetId": { "type": ["string", "null"] },
          "payload": { "type": ["object", "array", "string", "number", "boolean"] }
        }
      }
    },
    "protocolSteps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stepType"],
        "properties": {
          "stepType": {
            "type": "string",
            "enum": [
              "SignEnvelope",
              "VerifyEnvelope",
              "ReplayAttempt",
              "TimestampSkew",
              "IssueReceipt",
              "VerifyReceipt",
              "ChallengeCreate",
              "ChallengeVerify",
              "KeyRevoked",
              "KeyReplaced"
            ]
          },
          "expectSuccess": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "expectedRules": { "type": "array", "items": { "type": "string" } },
    "expectedAction": { "type": "string" },
    "expectedSeverity": { "type": "string" },
    "shouldBeCovered": { "type": "boolean" },
    "shouldBeValid": { "type": "boolean" }
  },
  "anyOf": [
    { "required": ["steps"] },
    { "required": ["protocolSteps"] }
  ]
}
