# Copy this file to .env for local Docker Compose runs.
# Do not commit .env. Keep real secrets outside source control.

HIP_POSTGRES_DB=hip
HIP_POSTGRES_USER=hip
HIP_POSTGRES_PASSWORD=replace-with-local-dev-password

HIP_RABBITMQ_USER=hip
HIP_RABBITMQ_PASSWORD=replace-with-local-dev-password

# Development-only keys used by HIP containers.
# Replace these locally. Production must use managed secrets, not .env files.
HIP_RECORD_ENCRYPTION_KEY=replace-with-32-byte-dev-key
HIP_PRIVACY_HASHING_KEY=replace-with-32-byte-dev-key

# Local host ports.
HIP_API_PORT=5099
HIP_WEB_PORT=5123
HIP_POSTGRES_PORT=5432
HIP_REDIS_PORT=6379
HIP_RABBITMQ_PORT=5672
HIP_RABBITMQ_MANAGEMENT_PORT=15672
