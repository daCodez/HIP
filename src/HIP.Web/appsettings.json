{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ExternalSiteEvidence": {
    "_comment": "External scanners are disabled by default. Set ExternalProvidersEnabled=true only when outbound provider checks are intentionally allowed.",
    "ExternalProvidersEnabled": false,
    "AllowFullUrlChecks": false,
    "ProviderTimeout": "00:00:02",
    "DefaultCacheDuration": "06:00:00",
    "SslLabs": {
      "Enabled": true,
      "Endpoint": "https://api.ssllabs.com/api/v3/analyze"
    },
    "GoogleWebRisk": {
      "Enabled": false
    },
    "VirusTotal": {
      "Enabled": false
    }
  },
  "AllowedHosts": "*"
}
