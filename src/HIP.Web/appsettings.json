{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ExternalSiteEvidence": {
    "_comment": "SSL Labs / Qualys TLS evidence is enabled by default for HIP MVP testing. Set ExternalProvidersEnabled=false or SslLabs.Enabled=false to disable outbound TLS checks.",
    "ExternalProvidersEnabled": true,
    "AllowFullUrlChecks": false,
    "ProviderTimeout": "00:00:10",
    "DefaultCacheDuration": "06:00:00",
    "SslLabs": {
      "Enabled": true,
      "Endpoint": "https://api.ssllabs.com/api/v3/analyze"
    },
    "GoogleWebRisk": {
      "Enabled": false
    },
    "VirusTotal": {
      "Enabled": false
    }
  },
  "HipPerformance": {
    "UseRedisOutputCacheWhenAvailable": true,
    "PublicLookupCacheSeconds": 30,
    "BadgeCacheSeconds": 60,
    "SafetyCacheSeconds": 10,
    "SiteSafetyCacheSeconds": 15,
    "PublicScanRequestsPerMinute": 60,
    "PublicFeedbackRequestsPerMinute": 30,
    "IdentityRequestsPerMinute": 10
  },
  "AllowedHosts": "*"
}
