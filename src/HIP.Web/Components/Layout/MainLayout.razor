@inherits LayoutComponentBase

<div class="hip-shell">
    <aside class="hip-sidebar">
        <NavMenu />
    </aside>

    <main class="hip-main">
        <header class="hip-topbar">
            <label class="hip-search" aria-label="Search HIP">
                <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m16 16 4 4" /></svg>
                <input type="search" placeholder="Search threats, identities, rules..." />
                <kbd>Ctrl K</kbd>
            </label>

            <div class="hip-topbar-actions">
                <button class="hip-env" type="button"><span></span> Production</button>
                <button class="hip-icon-button" type="button" aria-label="Switch to light mode" data-hip-theme-toggle>
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 15A8 8 0 0 1 9 4a8 8 0 1 0 11 11Z" /></svg>
                </button>
                <button class="hip-icon-button hip-has-alert" type="button" aria-label="Notifications">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 17h14l-2-3V9a5 5 0 0 0-10 0v5l-2 3Z" /><path d="M10 20h4" /></svg>
                </button>
                <div class="hip-user">
                    <span class="hip-avatar">H</span>
                    <span>
                        <strong>HIP Admin</strong>
                        <small>Local MVP Session</small>
                    </span>
                </div>
            </div>
        </header>

        <div class="hip-content">
            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
