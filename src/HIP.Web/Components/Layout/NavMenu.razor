@code {
    private static RenderFragment Svg(string body) => builder =>
    {
        builder.OpenElement(0, "svg");
        builder.AddAttribute(1, "viewBox", "0 0 24 24");
        builder.AddAttribute(2, "aria-hidden", "true");
        builder.AddMarkupContent(3, body);
        builder.CloseElement();
    };

    private static RenderFragment IconDashboard() => Svg("<rect x=\"4\" y=\"4\" width=\"6\" height=\"6\" rx=\"1\"/><rect x=\"14\" y=\"4\" width=\"6\" height=\"6\" rx=\"1\"/><rect x=\"4\" y=\"14\" width=\"6\" height=\"6\" rx=\"1\"/><rect x=\"14\" y=\"14\" width=\"6\" height=\"6\" rx=\"1\"/>");
    private static RenderFragment IconBell() => Svg("<path d=\"M18 9a6 6 0 0 0-12 0c0 7-2 7-2 7h16s-2 0-2-7\"/><path d=\"M10 20h4\"/>");
    private static RenderFragment IconShield() => Svg("<path d=\"M12 3.5 18 6v5.2c0 4.2-2.5 7.4-6 8.8-3.5-1.4-6-4.6-6-8.8V6l6-2.5Z\"/>");
    private static RenderFragment IconClipboard() => Svg("<rect x=\"6\" y=\"5\" width=\"12\" height=\"15\" rx=\"2\"/><path d=\"M9 5a3 3 0 0 1 6 0\"/><path d=\"M9 11h6M9 15h4\"/>");
