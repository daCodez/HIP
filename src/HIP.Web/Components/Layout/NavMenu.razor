    private static RenderFragment IconIdentity() => Svg("<circle cx=\"12\" cy=\"8\" r=\"3\"/><path d=\"M5 20a7 7 0 0 1 14 0\"/>");
    private static RenderFragment IconLink() => Svg("<path d=\"M10 13a5 5 0 0 0 7.1 0l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1\"/><path d=\"M14 11a5 5 0 0 0-7.1 0l-2 2A5 5 0 0 0 12 20.1l1.1-1.1\"/>");
    private static RenderFragment IconZap() => Svg("<path d=\"M13 2 4 14h7l-1 8 9-12h-7l1-8Z\"/>");
    private static RenderFragment IconMonitor() => Svg("<rect x=\"4\" y=\"5\" width=\"16\" height=\"11\" rx=\"2\"/><path d=\"M8 20h8M12 16v4\"/>");
    private static RenderFragment IconSliders() => Svg("<path d=\"M4 7h10M18 7h2M4 17h2M10 17h10\"/><circle cx=\"16\" cy=\"7\" r=\"2\"/><circle cx=\"8\" cy=\"17\" r=\"2\"/>");
    private static RenderFragment IconConnection() => Svg("<path d=\"M9 7H7a4 4 0 0 0 0 8h2M15 7h2a4 4 0 0 1 0 8h-2M8 12h8\"/>");
    private static RenderFragment IconBars() => Svg("<path d=\"M5 19V9M12 19V5M19 19v-7\"/>");
    private static RenderFragment IconMessage() => Svg("<path d=\"M5 6h14v10H8l-3 3V6Z\"/>");
    private static RenderFragment IconFile() => Svg("<path d=\"M7 3h7l4 4v14H7V3Z\"/><path d=\"M14 3v5h5M10 13h5M10 17h5\"/>");
    private static RenderFragment IconCode() => Svg("<path d=\"m8 8-4 4 4 4M16 8l4 4-4 4M14 5l-4 14\"/>");
    private static RenderFragment IconLock() => Svg("<rect x=\"5\" y=\"10\" width=\"14\" height=\"10\" rx=\"2\"/><path d=\"M8 10V7a4 4 0 0 1 8 0v3\"/>");
    private static RenderFragment IconSettings() => Svg("<circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19 12a7 7 0 0 0-.1-1.2l2-1.5-2-3.4-2.4 1a7 7 0 0 0-2-1.2L14.2 3h-4.4l-.4 2.7a7 7 0 0 0-2 1.2l-2.4-1-2 3.4 2 1.5A7 7 0 0 0 5 12c0 .4 0 .8.1 1.2l-2 1.5 2 3.4 2.4-1a7 7 0 0 0 2 1.2l.4 2.7h4.4l.4-2.7a7 7 0 0 0 2-1.2l2.4 1 2-3.4-2-1.5c.1-.4.1-.8.1-1.2Z\"/>");
