    <NavLink class="nav-item" href="consumer/devices">@Icon("grid")<span>Devices</span></NavLink>
    <NavLink class="nav-item" href="admin/licenses">@Icon("file")<span>Licenses</span></NavLink>
    <NavLink class="nav-item" href="admin/sl-hud-simulator">@Icon("eye")<span>HUD Simulator</span></NavLink>

    <p class="group-title">Automation</p>
