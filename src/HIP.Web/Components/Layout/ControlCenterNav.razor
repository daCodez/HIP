@code {
    private static RenderFragment Icon(string name) => name switch
    {
        "search" => Svg("<circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"m16 16 4 4\"/>"),
        "shield" => Svg("<path d=\"M12 3 20 6v5c0 5-3.3 8.5-8 10-4.7-1.5-8-5-8-10V6z\"/><path d=\"m9 12 2 2 4-5\"/>"),
        "eye" => Svg("<path d=\"M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12Z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/>"),
        "bolt" => Svg("<path d=\"m13 2-9 12h7l-1 8 9-12h-7z\"/>"),
        "settings" => Svg("<circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19 12a7 7 0 0 0-.1-1l2-1.6-2-3.4-2.5 1A8 8 0 0 0 15 6l-.4-2.7h-4L10 6a8 8 0 0 0-1.5 1L6 6 4 9.4 6.1 11a7 7 0 0 0 0 2L4 14.6 6 18l2.5-1a8 8 0 0 0 1.5 1l.5 2.7h4L15 18a8 8 0 0 0 1.5-1l2.5 1 2-3.4-2.1-1.6a7 7 0 0 0 .1-1Z\"/>"),
        "file" => Svg("<path d=\"M6 2h8l4 4v16H6zM14 2v5h5\"/>"),
        "bell" => Svg("<path d=\"M5 17h14l-2-3V9a5 5 0 0 0-10 0v5zM10 20h4\"/>"),
        _ => Svg("<path d=\"M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z\"/>")
    };

    private static RenderFragment Svg(string body) => builder =>
    {
        builder.OpenElement(0, "svg");
        builder.AddAttribute(1, "viewBox", "0 0 24 24");
        builder.AddAttribute(2, "aria-hidden", "true");
        builder.AddMarkupContent(3, body);
        builder.CloseElement();
    };
}
