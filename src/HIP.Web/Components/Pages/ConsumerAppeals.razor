@page "/consumer/appeals"
@attribute [Authorize(Policy = ConsumerPolicies.CanUseConsumerPortal)]
@rendermode InteractiveServer
@inject IConsumerPortalService ConsumerPortalService

<PageTitle>HIP Consumer Appeals</PageTitle>

<ConsumerTable Title="Appeal Status" Description="Appeal status uses target IDs and privacy-safe summaries. Full private evidence is not shown.">
    @foreach (var item in _items)
    {
        <tr>
            <td>@item.UpdatedAtUtc.UtcDateTime.ToString("u")</td>
            <td>@item.TargetType</td>
            <td>@item.TargetId</td>
            <td>@item.Status</td>
            <td>@item.Summary</td>
        </tr>
    }
</ConsumerTable>

@code {
    private IReadOnlyCollection<ConsumerAppealItem> _items = [];

    protected override async Task OnInitializedAsync()
    {
        _items = await ConsumerPortalService.GetAppealsAsync("development-consumer", CancellationToken.None);
    }
}
