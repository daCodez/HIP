@page "/lookup/domain/{Domain}"
@page "/lookup/{Domain}"
@inject IPublicDomainLookupService LookupService

<PageTitle>HIP Domain Lookup</PageTitle>

<main class="hip-lookup-page">
    @if (_lookup is null && _error is null)
    {
        <p>Loading HIP lookup...</p>
    }
    else if (_error is not null)
    {
        <section class="hip-lookup-panel">
            <h1>Lookup unavailable</h1>
            <p>@_error</p>
            <a href="/lookup">Try another lookup</a>
        </section>
    }
    else if (_lookup is not null)
    {
        <section class="hip-lookup-panel">
            <p class="eyebrow">Public HIP Lookup</p>
            <div class="lookup-heading">
                <div>
                    <h1>@_lookup.Domain</h1>
                    <p>TCP connects devices. TLS encrypts the connection. HIP verifies trust, origin, reputation, and risk.</p>
                </div>
                <a href="/lookup">Check another domain</a>
            </div>

            <div class="score-card status-@_lookup.Status.ToString().ToLowerInvariant()">
                <span>HIP Score</span>
                <strong>@(_lookup.DataSource == "NoStoredData" ? "Not enough data yet" : $"{_lookup.FinalHipScore}/100")</strong>
                <p>Status: @_lookup.Status</p>
                <p>Risk Level: @_lookup.RiskLevel</p>
                <p>Data source: @_lookup.DataSource</p>
                <p>Verified: @_lookup.VerificationStatus</p>
                <p>Signed Identity: @_lookup.SignedIdentityStatus</p>
                <p>Signature Status: @_lookup.SignatureStatus</p>
                <p>Verification Method: @_lookup.VerificationMethod</p>
                <p>Recommended Action: @_lookup.RecommendedAction</p>
                <p>Last checked UTC: @_lookup.LastCheckedUtc.ToString("u")</p>
            </div>

            <section class="lookup-section">
                <h2>Layered HIP Score</h2>
                <p>@_lookup.FinalHipScoreExplanation</p>
                <div class="breakdown-grid">
                    <article class="breakdown-card">
                        <h3>DomainTrustScore</h3>
                        <strong>@_lookup.DomainTrustScore/100</strong>
                        <p>How trustworthy the root domain is overall. This does not automatically make every page safe.</p>
                    </article>
                    <article class="breakdown-card">
                        <h3>PageTrustScore</h3>
                        <strong>@_lookup.PageTrustScore/100</strong>
                        <p>How trustworthy this exact page or URL context is.</p>
                    </article>
                    <article class="breakdown-card">
                        <h3>ContentRiskScore</h3>
                        <strong>@_lookup.ContentRiskScore/100</strong>
                        <p>How safe the observed content signals are. Downloads, scripts, forms, and suspicious links are evaluated separately.</p>
                    </article>
                </div>
            </section>

            @if (_lookup.DataSource == "BrowserPluginScan")
            {
                <section class="lookup-section">
                    <h2>Last HIP Scan</h2>
                    <p>This is the latest public-safe browser plugin scan summary for this domain. HIP does not expose page URLs, page text, form contents, user identity, private messages, or raw scan payloads here.</p>
                    <div class="breakdown-grid">
                        <article class="breakdown-card">
                            <h3>Links scanned</h3>
                            <strong>@_lookup.LinksScanned</strong>
                        </article>
                        <article class="breakdown-card">
                            <h3>Risky links found</h3>
                            <strong>@_lookup.RiskyLinksFound</strong>
                        </article>
                        <article class="breakdown-card">
                            <h3>Suspicious links</h3>
                            <strong>@_lookup.SuspiciousLinksFound</strong>
                        </article>
                        <article class="breakdown-card">
                            <h3>Dangerous links</h3>
                            <strong>@_lookup.DangerousLinksFound</strong>
                        </article>
                    </div>
                </section>
            }
            else
            {
                <section class="lookup-section">
                    <h2>Not Enough Data Yet</h2>
                    <p>@_lookup.Message</p>
                    <p>HIP will show stored browser scan data here after a HIP client scans this domain.</p>
                </section>
            }

            <section class="lookup-section">
                <h2>Important Context</h2>
                <p>A verified identity does not automatically mean safe. It means HIP knows who signed or owns it. The trust score still matters.</p>
            </section>

            <section class="lookup-section">
                <h2>Score Ranges</h2>
                <ul class="range-list">
                    <li>0-9 = Dangerous</li>
                    <li>10-24 = High Risk</li>
                    <li>25-39 = Suspicious</li>
                    <li>40-49 = Unknown</li>
                    <li>50-69 = Limited Trust Data</li>
                    <li>70-84 = Mostly Trusted</li>
                    <li>85-100 = Trusted</li>
                </ul>
            </section>

            @if (_lookup.KnownRisks.Count > 0)
            {
                <section class="lookup-section">
                    <h2>Known Public Risks</h2>
                    <ul>
                        @foreach (var risk in _lookup.KnownRisks)
                        {
                            <li>@risk</li>
                        }
                    </ul>
                </section>
            }

            <section class="lookup-section">
                <h2>Explanation</h2>
                <ul>
                    @foreach (var explanation in _lookup.Reasons.Take(6))
                    {
                        <li>@explanation</li>
                    }
                </ul>
            </section>

            <section class="lookup-section">
                <h2>Signed Identity Foundation</h2>
                <p>Verification status: @_lookup.IdentityVerificationStatus</p>
                <p>Verified organization: @(_lookup.VerifiedOrganization ?? "Not configured")</p>
                <p>DNS TXT and .well-known/hip.json verification are planned for signed website support.</p>
            </section>

            <section class="lookup-section">
                <h2>Score Breakdown</h2>
                <div class="breakdown-grid">
                    @foreach (var score in _lookup.ScoreBreakdown.Where(score => score.Category != "Final"))
                    {
                        <article class="breakdown-card">
                            <h3>@score.Category Score</h3>
                            <strong>@score.Score/100</strong>
                            <p>Status: @score.Status</p>
                            <p>@score.Explanation</p>
                            <ul>
                                @foreach (var reason in score.Reasons)
                                {
                                    <li>@reason</li>
                                }
                            </ul>
                        </article>
                    }
                </div>
            </section>

            @if (_lookup.PublicBadgeEligible)
            {
                <section class="lookup-section">
                    <h2>Badge Preview</h2>
                    <div class="hip-trust-badge-preview">
                        <span>HIP Verified</span>
                        <strong>Score: @_lookup.FinalHipScore/100</strong>
                        <span>Status: @_lookup.Status</span>
                    </div>
                </section>
            }

            <section class="lookup-section">
                <h2>Share</h2>
                <p><a href="@_lookup.PublicLookupUrl">@_lookup.PublicLookupUrl</a></p>
            </section>
        </section>
    }
</main>

@code {
    [Parameter]
    public string? Domain { get; set; }

    private PublicDomainLookupResponse? _lookup;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(Domain))
        {
            _error = "Domain is required.";
            return;
        }

        try
        {
            _lookup = await LookupService.LookupDomainAsync(Domain, CancellationToken.None);
            _error = null;
        }
        catch (ArgumentException ex)
        {
            _error = ex.Message;
        }
    }
}
