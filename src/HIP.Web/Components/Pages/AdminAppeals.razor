@page "/admin/appeals"
@page "/admin/appeals/{AppealId}"
@attribute [Authorize(Policy = AdminPolicies.CanReviewReports)]
@rendermode InteractiveServer
@inject IAppealService AppealService

<PageTitle>HIP Appeals</PageTitle>

<main class="admin-rule-page">
    <section class="admin-rule-header">
        <p class="eyebrow">Admin MVP</p>
        <h1>Appeals</h1>
        <p>Review privacy-safe appeals for domains, senders, device keys, organizations, and content patterns.</p>
        <button type="button" @onclick="CreateSample">Create Sample Appeal</button>
    </section>

    @if (_selected is not null)
    {
        <section class="rule-builder-panel">
            <h2>Appeal Detail</h2>
            <dl class="lookup-details">
                <dt>ID</dt><dd>@_selected.AppealId</dd>
                <dt>Target</dt><dd>@_selected.TargetType: @_selected.TargetId</dd>
                <dt>Status</dt><dd>@_selected.Status</dd>
                <dt>Reason</dt><dd>@_selected.Reason</dd>
                <dt>Decision</dt><dd>@_selected.Decision @_selected.DecisionReason</dd>
            </dl>
        </section>
    }

    <section class="rule-builder-panel">
        <h2>Appeal Requests</h2>
        <table class="admin-rule-table">
            <thead>
                <tr><th>Target</th><th>Reason</th><th>Status</th><th>Submitted</th><th>Decision</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var appeal in _appeals)
                {
                    <tr>
                        <td>@appeal.TargetType: @appeal.TargetId</td>
                        <td>@appeal.Reason</td>
                        <td>@appeal.Status</td>
                        <td>@appeal.CreatedAtUtc.UtcDateTime.ToString("u")</td>
                        <td>@appeal.Decision @appeal.DecisionReason</td>
                        <td>
                            <button type="button" @onclick="() => Approve(appeal.AppealId)">Approve</button>
                            <button type="button" @onclick="() => Reject(appeal.AppealId)">Reject</button>
                            <button type="button" @onclick="() => MoreInfo(appeal.AppealId)">More Info</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</main>

@code {
    [Parameter]
    public string? AppealId { get; set; }

    private IReadOnlyCollection<AppealRequest> _appeals = [];
    private AppealRequest? _selected;

    protected override void OnInitialized() => Refresh();

    protected override void OnParametersSet() => Refresh();

    private void Refresh()
    {
        _appeals = AppealService.List();
        _selected = string.IsNullOrWhiteSpace(AppealId) ? null : AppealService.Get(AppealId);
    }

    private void CreateSample()
    {
        AppealService.Submit(new AppealRequest(
            "",
            TargetType.Domain,
            "appeal-example.com",
            "sha256:submitter",
            "The domain has remediated the reported redirect issue.",
            AppealStatus.Submitted,
            DateTimeOffset.UtcNow,
            DateTimeOffset.UtcNow,
            null,
            null,
            null,
            new Dictionary<string, string> { ["evidenceSummary"] = "public DNS and redirect fix notes" }));
        Refresh();
    }

    private void Approve(string id)
    {
        AppealService.Approve(id, "admin-dev", "Appeal accepted based on privacy-safe evidence.");
        Refresh();
    }

    private void Reject(string id)
    {
        AppealService.Reject(id, "admin-dev", "Risk evidence remains valid.");
        Refresh();
    }

    private void MoreInfo(string id)
    {
        AppealService.RequestMoreInfo(id, "admin-dev", "Need more public remediation evidence.");
        Refresh();
    }
}
