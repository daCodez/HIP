@page "/login"
@layout AuthLayout
@attribute [AllowAnonymous]

<PageTitle>Sign in | HIP</PageTitle>

<main class="login-page">
    <section class="login-brand-panel" aria-labelledby="login-brand-heading">
        <a class="login-brand" href="/" aria-label="HIP home">
            <img src="/hip-logo-original.png" alt="" width="52" height="53" />
            <span><strong>HIP CONTROL</strong><small>TRUST OPERATIONS</small></span>
        </a>
        <div class="login-brand-copy">
            <span class="login-eyebrow">Human Identity Protocol</span>
            <h1 id="login-brand-heading">Trust starts with knowing who is on the other side.</h1>
            <p>HIP helps protect identity, reputation, and access across connected digital spaces.</p>
        </div>
        <p class="login-privacy-note"><strong>Your password stays private.</strong> HIP uses it only to confirm that this account is yours.</p>
    </section>

    <section class="login-form-panel">
        <div class="login-form-wrap">
            <div class="login-form-heading">
                <span class="login-eyebrow">HIP Admin</span>
                <h2>Welcome back</h2>
                <p>Sign in to continue to the control center.</p>
            </div>

            @if (string.Equals(Error, "invalid", StringComparison.OrdinalIgnoreCase))
            {
                <div class="login-error" role="alert">
                    <strong>We could not sign you in.</strong>
                    <span>Check your email and password, then try again.</span>
                </div>
            }
            else if (string.Equals(Error, "too-many", StringComparison.OrdinalIgnoreCase))
            {
                <div class="login-error" role="alert">
                    <strong>Please wait before trying again.</strong>
                    <span>There have been several sign-in attempts. Try again in a few minutes.</span>
                </div>
            }

            <form class="login-form" method="post" action="/auth/login">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@SafeReturnUrl" />

                <label for="login-email">Email address</label>
                <input id="login-email" name="email" type="email" inputmode="email" autocomplete="username" maxlength="254" required autofocus />

                <div class="login-password-label"><label for="login-password">Password</label><span>Case-sensitive</span></div>
                <input id="login-password" name="password" type="password" autocomplete="current-password" maxlength="256" required />

                <label class="login-remember"><input name="remember" type="checkbox" value="true" /> <span>Keep me signed in on this device</span></label>
                <button class="login-submit" type="submit">Sign in</button>
            </form>

            <p class="login-help">Cannot sign in? Ask the HIP owner to reset your local access.</p>
        </div>
    </section>
</main>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string SafeReturnUrl => HipDevelopmentLoginEndpoints.SafeLocalReturnUrl(ReturnUrl);
}
