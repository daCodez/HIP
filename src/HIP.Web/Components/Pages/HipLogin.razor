@page "/login"

<PageTitle>HIP Login</PageTitle>

<section class="hip-login-page">
    <div class="hip-login-brand">
        <div class="hip-brand inline">
            <div class="hip-mark">H</div>
            <div><strong>HIP</strong><span>Human Identity Protocol</span></div>
        </div>
        <h1>Protect human identity in digital spaces</h1>
        <p>Advanced threat detection, reputation scoring, and identity verification for secure digital interactions.</p>
        <div class="hip-login-feature cyan">Real-time message threat scanning</div>
        <div class="hip-login-feature green">Identity verification & reputation</div>
        <div class="hip-login-feature yellow">AI-assisted phishing detection foundation</div>
        <div class="hip-login-feature orange">Second Life HUD integration</div>
    </div>

    <form class="hip-login-form">
        <h2>Sign in to your account</h2>
        <p>Enter your credentials to access the security dashboard.</p>
        <label>Email address<input value="dacodez@test.com" /></label>
        <label>Password<input type="password" value="demo" /></label>
        <label class="remember"><input type="checkbox" /> Remember this device for 30 days</label>
        <button type="button">Sign in</button>
        <small>Demo mode: use any email + 4+ character password</small>
    </form>
</section>
