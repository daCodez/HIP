@page "/admin/api"
@attribute [Authorize(Policy = AdminPolicies.CanViewAdminDashboard)]
@rendermode InteractiveServer
@inject IAdminDashboardService DashboardService

<PageTitle>HIP API & Developer</PageTitle>

<section class="hip-page-heading compact">
    <div>
        <h1>API & Developer <span class="hip-pill info">MVP</span></h1>
        <p>Integrate HIP into your own tools and workflows.</p>
    </div>
    <button class="hip-primary-action" type="button" disabled>+ New API Key</button>
</section>

@if (_summary is null)
{
    <section class="hip-panel padded narrow">
        <h2>Loading API data</h2>
        <p>HIP is reading live scan and submission summaries.</p>
    </section>
}
else
{
    <section class="hip-two-column">
        <article class="hip-panel padded">
            <h2>API Activity</h2>
            <p>HIP does not have API key usage telemetry connected yet.</p>
            <div class="hip-stat-pair">
                <strong>@CardValue("totalScans")<small>Stored scan submissions</small></strong>
                <strong>@CardValue("scansToday")<small>Scans today</small></strong>
            </div>
        </article>

        <article class="hip-panel padded">
            <h2>Rate Limits</h2>
            <p>Production rate-limit counters are not connected yet.</p>
            <div class="hip-progress-row">
                <span>Plugin/API submissions</span>
                <strong>Development placeholder</strong>
                <i style="--value:0%"></i>
            </div>
        </article>
    </section>

    <section class="hip-panel padded narrow">
        <h2>API Keys</h2>
        <p>API key storage is not connected yet, so HIP is not showing fake tokens or fake usage.</p>
        <article class="hip-key-row">
            <div>
                <h3>No API keys yet <span>0 calls</span></h3>
                <code>API key management not connected</code>
                <small>Use this page after real API key persistence and auditing are added.</small>
            </div>
        </article>
    </section>
}

@code {
    private AdminDashboardSummary? _summary;

    /// <summary>
    /// Loads live dashboard counters for API-adjacent activity.
    /// </summary>
    protected override async Task OnInitializedAsync() =>
        _summary = await DashboardService.GetSummaryAsync(CancellationToken.None);

    /// <summary>
    /// Gets a live dashboard card value.
    /// </summary>
    /// <param name="key">Dashboard card key.</param>
    /// <returns>Card value or zero.</returns>
    private int CardValue(string key) =>
        _summary?.Cards.FirstOrDefault(card => card.Key.Equals(key, StringComparison.OrdinalIgnoreCase))?.Value ?? 0;
}
