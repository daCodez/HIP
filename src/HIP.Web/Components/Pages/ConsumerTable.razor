<main class="admin-rule-page">
    <section class="admin-rule-header">
        <div>
            <p class="eyebrow">Consumer Portal</p>
            <h1>@Title</h1>
            <p>@Description</p>
        </div>
    </section>

    <section class="lookup-result">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Target</th>
                        <th>Risk/Type</th>
                        <th>Status</th>
                        <th>Summary</th>
                    </tr>
                </thead>
                <tbody>
                    @ChildContent
                </tbody>
            </table>
        </div>
    </section>
</main>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
