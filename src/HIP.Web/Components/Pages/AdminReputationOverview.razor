@page "/admin/reputation"
@attribute [Authorize(Policy = AdminPolicies.CanViewAdminDashboard)]
@rendermode InteractiveServer
@inject IAdminDashboardService DashboardService

<PageTitle>HIP Reputation Overview</PageTitle>

<main class="admin-rule-page">
    <section class="admin-rule-header">
        <div>
            <p class="eyebrow">HIP Reputation</p>
            <h1>Score Overview</h1>
            <p>Live reputation summary from stored scans, feedback, review signals, and rule activity.</p>
        </div>
    </section>

    @if (_summary is null)
    {
        <section class="dashboard-loading-state" aria-busy="true">
            <strong>Loading reputation data...</strong>
            <span>HIP is reading privacy-safe dashboard projections.</span>
        </section>
    }
    else
    {
        <section class="score-grid dashboard-grid">
            @foreach (var card in ReputationCards())
            {
                <article class="score-card">
                    <span>@card.Status</span>
                    <strong>@card.Value</strong>
                    <h3>@card.Label</h3>
                    <p>@card.Description</p>
                </article>
            }
        </section>

        <section class="hip-panel hip-threat-panel">
            <div class="hip-panel-heading">
                <div>
                    <h2>Reputation Inputs</h2>
                    <p>HIP shows domain-level summaries only. No page text, private messages, form values, passwords, cookies, or tokens are exposed.</p>
                </div>
                <span class="hip-pill good">@_summary.DataSource</span>
            </div>

            @if (!_summary.HasScanData)
            {
                <div class="hip-threat-empty">
                    <strong>No stored scan data yet.</strong>
                    <span>Visit sites with the browser plugin enabled, then refresh the dashboard.</span>
                </div>
            }
            else
            {
                <div class="hip-table-wrap">
                    <table class="hip-data-table">
                        <thead>
                            <tr>
                                <th>Domain</th>
                                <th>Status</th>
                                <th>Final Score</th>
                                <th>Confidence</th>
                                <th>Reason</th>
                                <th>Scanned</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var scan in _summary.RecentScans.Take(10))
                            {
                                <tr>
                                    <td><a href="@($"/lookup/{Uri.EscapeDataString(scan.Domain)}")">@scan.Domain</a></td>
                                    <td><span class="hip-pill">@scan.Status</span></td>
                                    <td><strong>@scan.Score</strong></td>
                                    <td>@scan.ConfidenceLevel</td>
                                    <td>@scan.ReasonSummary</td>
                                    <td>@scan.LastCheckedUtc.UtcDateTime.ToString("u")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</main>

@code {
    private AdminDashboardSummary? _summary;

    /// <summary>
    /// Loads the live dashboard projection used as the MVP reputation read model.
    /// </summary>
    protected override async Task OnInitializedAsync() =>
        _summary = await DashboardService.GetSummaryAsync(CancellationToken.None);

    /// <summary>
    /// Selects the reputation-focused cards from the live dashboard summary.
    /// </summary>
    /// <returns>Dashboard cards that explain reputation-relevant state.</returns>
    private IEnumerable<AdminDashboardCard> ReputationCards()
    {
        if (_summary is null)
        {
            return [];
        }

        var preferredLabels = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "Trusted",
            "MostlyTrusted",
            "LimitedTrustData",
            "Unknown",
            "Suspicious",
            "HighRisk",
            "Dangerous",
            "Feedback Count",
            "Pending Reviews"
        };

        return _summary.Cards.Where(card => preferredLabels.Contains(card.Label));
    }
}
