@page "/admin/audit-logs"
@page "/admin/audit"
@attribute [Authorize(Policy = AdminPolicies.CanViewAuditLogs)]
@rendermode InteractiveServer
@inject IAuditLogService AuditLogService

<PageTitle>HIP Audit Logs</PageTitle>

<main class="hip-admin-page">
    <section class="hip-page-heading compact">
        <div>
        <h1>Audit Logs</h1>
            <p>Full history of system and user actions.</p>
        </div>
    </section>

    <section class="hip-panel padded narrow">
        <h2>Recent Activity</h2>
        <p>All security events and configuration changes.</p>
        <table class="hip-data-table">
            <thead>
                <tr><th>Time</th><th>Action</th><th>User</th><th>Detail</th><th>Severity</th></tr>
            </thead>
            <tbody>
                @if (!AuditLogService.List().Any())
                {
                    <tr>
                        <td colspan="5">No audit log entries yet. HIP is not showing artificial activity.</td>
                    </tr>
                }
                else
                {
                    @foreach (var entry in AuditLogService.List())
                    {
                        <tr>
                            <td>@entry.CreatedAtUtc.UtcDateTime.ToString("u")</td>
                            <td>@entry.Action</td>
                            <td><span class="hip-pill info">@entry.ActorId</span></td>
                            <td>@entry.Summary</td>
                            <td>@entry.Severity</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </section>
</main>
