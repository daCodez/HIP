@page "/admin/feedback"
@attribute [Authorize(Policy = AdminPolicies.CanViewAdminDashboard)]
@rendermode InteractiveServer
@inject IAdminDashboardService DashboardService

<PageTitle>HIP Feedback Loop</PageTitle>

<section class="hip-page-heading compact">
    <div>
        <h1>Feedback Loop</h1>
        <p>Weighted trust feedback from HIP clients. Feedback is evidence, not voting.</p>
    </div>
</section>

@if (_summary is null)
{
    <section class="hip-panel padded narrow">
        <h2>Loading feedback</h2>
        <p>HIP is reading stored feedback summaries.</p>
    </section>
}
else
{
    <section class="hip-card-row">
        <article class="hip-action-card good">
            <span>✓</span>
            <div><h2>Looks Safe</h2><p>@CardValue("looksSafeFeedback") weighted feedback signal(s).</p></div>
        </article>
        <article class="hip-action-card suspicious">
            <span>!</span>
            <div><h2>Looks Suspicious</h2><p>@CardValue("looksSuspiciousFeedback") weighted feedback signal(s).</p></div>
        </article>
        <article class="hip-action-card danger">
            <span>!</span>
            <div><h2>Reported Issues</h2><p>@CardValue("reportIssueFeedback") issue feedback signal(s).</p></div>
        </article>
    </section>

    <section class="hip-panel padded narrow">
        <h2>Feedback-Driven Review Signals</h2>
        @if (_summary.RecentThreats.All(threat => !threat.Source.Contains("Feedback", StringComparison.OrdinalIgnoreCase)))
        {
            <p>No feedback-driven review signals yet. HIP is not showing fake private messages here.</p>
        }
        else
        {
            @foreach (var threat in _summary.RecentThreats.Where(threat => threat.Source.Contains("Feedback", StringComparison.OrdinalIgnoreCase)))
            {
                <article class="hip-feedback-item">
                    <div>
                        <strong>@threat.Domain</strong>
                        <span>@threat.Source</span>
                        <span class="hip-pill @Tone(threat.Severity)">@threat.Severity</span>
                    </div>
                    <p>@threat.ReasonSummary</p>
                    <small>@threat.CreatedAtUtc.UtcDateTime.ToString("u")</small>
                </article>
            }
        }
    </section>
}

@code {
    private AdminDashboardSummary? _summary;

    /// <summary>
    /// Loads live feedback and review summaries.
    /// </summary>
    protected override async Task OnInitializedAsync() =>
        _summary = await DashboardService.GetSummaryAsync(CancellationToken.None);

    /// <summary>
    /// Gets a live dashboard card value.
    /// </summary>
    /// <param name="key">Dashboard card key.</param>
    /// <returns>Card value or zero.</returns>
    private int CardValue(string key) =>
        _summary?.Cards.FirstOrDefault(card => card.Key.Equals(key, StringComparison.OrdinalIgnoreCase))?.Value ?? 0;

    /// <summary>
    /// Maps severity to a visual tone.
    /// </summary>
    /// <param name="severity">Severity label.</param>
    /// <returns>CSS tone.</returns>
    private static string Tone(string severity) =>
        severity.Equals("Critical", StringComparison.OrdinalIgnoreCase) ||
        severity.Equals("High", StringComparison.OrdinalIgnoreCase)
            ? "danger"
            : severity.Equals("Medium", StringComparison.OrdinalIgnoreCase)
                ? "suspicious"
                : "caution";
}
