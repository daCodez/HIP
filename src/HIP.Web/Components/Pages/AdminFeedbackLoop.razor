@page "/admin/feedback"

<PageTitle>HIP Feedback Loop</PageTitle>

<section class="hip-page-heading compact">
    <div>
        <h1>Feedback Loop</h1>
        <p>Help HIP learn from mistakes. Feedback improves detection for everyone.</p>
    </div>
</section>

<section class="hip-card-row">
    <article class="hip-action-card good">
        <span>👍</span>
        <div><h2>Mark as Helpful</h2><p>Confirm that a warning was accurate and useful.</p></div>
    </article>
    <article class="hip-action-card suspicious">
        <span>△</span>
        <div><h2>Report False Positive</h2><p>Tell HIP it flagged something safe by mistake.</p></div>
    </article>
    <article class="hip-action-card danger">
        <span>↓</span>
        <div><h2>Report False Negative</h2><p>Flag something HIP missed as a threat.</p></div>
    </article>
</section>

<section class="hip-panel padded narrow">
    <h2>Try It — Recent Flagged Messages</h2>
    <p>Rate each warning below to see how feedback adjusts sender reputation.</p>
    @foreach (var item in Messages)
    {
        <article class="hip-feedback-item">
            <div>
                <strong>@item.Sender</strong>
                <span>@item.Platform</span>
                <span class="hip-pill @item.Tone">@item.Risk</span>
            </div>
            <p>"@item.Message"</p>
            <div class="hip-button-row">
                <span>Was this warning accurate?</span>
                <button type="button">Yes, helpful</button>
                <button type="button">Not helpful</button>
                <button type="button">False positive</button>
                @if (item.AllowMissedThreat)
                {
                    <button type="button">Missed threat</button>
                }
            </div>
        </article>
    }
</section>

@code {
    private static readonly FeedbackMessage[] Messages =
    [
        new("SL_GiftBot", "Second Life", "dangerous", "Click here to claim your 500L$ reward now!", "danger", false),
        new("alice_w", "Discord, Email", "caution", "Hey, are you joining the meetup Saturday?", "caution", true),
        new("deals_hunter99", "Telegram", "suspicious", "Limited time: Check out this deal https://tinyurl.com/deal9", "suspicious", false)
    ];

    private sealed record FeedbackMessage(string Sender, string Platform, string Risk, string Message, string Tone, bool AllowMissedThreat);
}
