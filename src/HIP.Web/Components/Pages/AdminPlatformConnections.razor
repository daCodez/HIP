@page "/admin/platforms"
@attribute [Authorize(Policy = AdminPolicies.CanViewAdminDashboard)]
@rendermode InteractiveServer
@inject IAdminDashboardService DashboardService

<PageTitle>HIP Platform Connections</PageTitle>

<section class="hip-page-heading compact">
    <div>
        <h1>Platform Connections</h1>
        <p>Manage platforms that HIP monitors for threats.</p>
    </div>
    <button class="hip-primary-action" type="button" disabled>+ Connect Platform</button>
</section>

@if (_summary is null)
{
    <section class="hip-panel padded narrow">
        <h2>Loading platform status</h2>
        <p>HIP is reading connected data sources.</p>
    </section>
}
else
{
    <section class="hip-card-row three">
        <article class="hip-mini-stat good"><strong>1</strong><span>Connected Client Type</span></article>
        <article class="hip-mini-stat"><strong>@CardValue("totalScans")</strong><span>Browser Scans</span></article>
        <article class="hip-mini-stat"><strong>1</strong><span>Configured Message Platform</span></article>
    </section>

    <section class="hip-stack">
        <h2>Connected Sources</h2>
        <article class="hip-platform-row">
            <span class="platform-avatar">BP</span>
            <div>
                <h3>Browser Plugin <span class="hip-pill good">Connected</span> <span class="hip-pill good">active</span></h3>
                <p>@CardValue("totalScans") stored privacy-safe scan(s) · Last scan: @LatestScanLabel()</p>
                <div>
                    <small>Read current domain</small>
                    <small>Scan links</small>
                    <small>Submit URL hashes</small>
                    <small>Route risky links to safety page</small>
                </div>
            </div>
        </article>

        <article class="hip-platform-row">
            <span class="platform-avatar">DC</span>
            <div>
                <h3>Discord <span class="hip-pill caution">Not connected yet</span> <span class="hip-pill info">configured</span></h3>
                <p>Discord is available as a message platform foundation, but no live Discord connector has submitted HIP data yet.</p>
                <div>
                    <small>Sender hash only</small>
                    <small>URL and domain reports</small>
                    <small>No message body storage</small>
                    <small>Safety page routing ready</small>
                    <small>No fake Discord traffic shown</small>
                </div>
            </div>
        </article>

        <article class="hip-platform-row">
            <span class="platform-avatar">--</span>
            <div>
                <h3>Other Messaging Platforms <span class="hip-pill caution">Not connected yet</span></h3>
                <p>Second Life, Telegram, and email connectors do not have live connector records yet.</p>
                <div>
                    <small>Connectors will appear here after privacy-safe ingestion exists.</small>
                </div>
            </div>
        </article>
    </section>
}

@code {
    private AdminDashboardSummary? _summary;

    /// <summary>
    /// Loads live platform-adjacent scan data.
    /// </summary>
    protected override async Task OnInitializedAsync() =>
        _summary = await DashboardService.GetSummaryAsync(CancellationToken.None);

    /// <summary>
    /// Gets a live dashboard card value.
    /// </summary>
    /// <param name="key">Dashboard card key.</param>
    /// <returns>Card value or zero.</returns>
    private int CardValue(string key) =>
        _summary?.Cards.FirstOrDefault(card => card.Key.Equals(key, StringComparison.OrdinalIgnoreCase))?.Value ?? 0;

    /// <summary>
    /// Returns a human-readable latest scan label from live dashboard cards.
    /// </summary>
    /// <returns>Latest scan label.</returns>
    private string LatestScanLabel()
    {
        var latestScan = _summary?.Cards.FirstOrDefault(card => card.Key.Equals("latestScan", StringComparison.OrdinalIgnoreCase));
        return latestScan is null || latestScan.IsPlaceholder ? "No scan data yet" : $"{latestScan.Value} minutes ago";
    }
}
