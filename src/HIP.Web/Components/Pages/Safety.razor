@page "/safety"
@inject NavigationManager Navigation
@inject ISafetyRoutingService SafetyService

<PageTitle>HIP Safety Warning</PageTitle>

<main class="hip-safety-page">
    <section class="hip-safety-panel">
        <p class="eyebrow">HIP Safety Page</p>
        <h1>@Heading</h1>

        @if (_error is not null)
        {
            <p class="reason">@_error</p>
            <div class="actions">
                <button type="button" @onclick="GoBack">Go Back</button>
            </div>
        }
        else if (_result is not null)
        {
            <dl>
                <div>
                    <dt>Original URL</dt>
                    <dd>@DisplayOriginalUrl</dd>
                </div>
                <div>
                    <dt>Final destination</dt>
                    <dd>@(_result.FinalDestinationUrl ?? "Not resolved in MVP")</dd>
                </div>
                <div>
                    <dt>Risk</dt>
                    <dd>@SafetyRoutingService.DisplayRiskLevel(_result.RiskLevel)</dd>
                </div>
                <div>
                    <dt>Domain score</dt>
                    <dd>@_result.DomainScore/100</dd>
                </div>
                <div>
                    <dt>Sender score</dt>
                    <dd>@(_result.SenderScore?.ToString() ?? "Not supplied")</dd>
                </div>
                <div>
                    <dt>Recommended action</dt>
                    <dd>@_result.RecommendedAction</dd>
                </div>
                <div>
                    <dt>Source</dt>
                    <dd>@DisplaySource</dd>
                </div>
            </dl>

            <p class="reason">@_result.Reason</p>

            <div class="actions">
                <button type="button" @onclick="GoBack">Go Back</button>
                @if (_result.AllowContinue)
                {
                    <a class="continue" href="@_result.OriginalUrl" target="_self" rel="noreferrer noopener">Continue Anyway</a>
                }
                else
                {
                    <span class="blocked">Continue is blocked for critical risk.</span>
                }
                <button type="button">Report Safe</button>
                <button type="button">Report Dangerous</button>
            </div>
        }
    </section>
</main>

@code {
    [SupplyParameterFromQuery(Name = "url")]
    private string? Url { get; set; }

    [SupplyParameterFromQuery(Name = "source")]
    private string? Source { get; set; }

    [SupplyParameterFromQuery(Name = "risk")]
    private string? Risk { get; set; }

    private SafetyResult? _result;
    private string? _error;

    private string DisplaySource => string.IsNullOrWhiteSpace(Source) ? "Unknown" : Source;

    private string DisplayOriginalUrl => _result is null
        ? "Unknown"
        : SafetyUrlDisplay.StripQueryAndFragment(_result.OriginalUrl);

    private string Heading => _result?.RiskLevel == RiskStatus.Critical
        ? "HIP blocked this critical-risk link"
        : "Review this link before continuing";

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(Url))
        {
            _error = "No URL was provided.";
            _result = null;
            return;
        }

        try
        {
            _result = SafetyService.EvaluateUrl(Url, Source);
            if (Enum.TryParse<RiskStatus>(Risk, ignoreCase: true, out var suppliedRisk) &&
                suppliedRisk == RiskStatus.Critical)
            {
                _result = _result with
                {
                    RiskLevel = RiskStatus.Critical,
                    DomainScore = 5,
                    RecommendedAction = SafetyRoutingService.RecommendedActionFor(RiskStatus.Critical),
                    AllowContinue = false,
                    ShouldRouteToSafetyPage = true
                };
            }

            _error = null;
        }
        catch (ArgumentException ex)
        {
            _error = ex.Message;
            _result = null;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/lookup");
    }
}
