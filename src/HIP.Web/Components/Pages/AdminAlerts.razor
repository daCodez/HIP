@page "/admin/alerts"
@attribute [Authorize(Policy = AdminPolicies.CanReviewReports)]
@rendermode InteractiveServer
@inject IAdminDashboardService DashboardService

<PageTitle>HIP Alert Center</PageTitle>

<section class="hip-page-heading compact">
    <div>
        <h1>Alert Center</h1>
        <p>Unified inbox of live HIP security signals requiring attention.</p>
    </div>
    <span class="hip-pill @(_alerts.Count == 0 ? "good" : "danger")">@_alerts.Count active</span>
</section>

<section class="hip-tabs">
    <button class="active">All <span>@_alerts.Count</span></button>
    <button>High Risk <span>@_alerts.Count(alert => alert.Severity is "High" or "Critical")</span></button>
    <button>Provider <span>@_alerts.Count(alert => alert.Source.Contains("Provider", StringComparison.OrdinalIgnoreCase))</span></button>
    <button>Feedback <span>@_alerts.Count(alert => alert.Source.Contains("Feedback", StringComparison.OrdinalIgnoreCase))</span></button>
</section>

<section class="hip-list-panel">
    @if (_isLoading)
    {
        <article class="hip-alert-row">
            <span class="hip-alert-icon info">i</span>
            <div>
                <h2>Loading live alerts</h2>
                <p>HIP is reading stored scan, review, feedback, and provider signals.</p>
            </div>
        </article>
    }
    else if (_alerts.Count == 0)
    {
        <article class="hip-alert-row">
            <span class="hip-alert-icon good">i</span>
            <div>
                <h2>No live alerts</h2>
                <p>HIP has no current high-risk or uncertain security signals in the connected data sources.</p>
                <small>No artificial alert rows are generated.</small>
            </div>
        </article>
    }
    else
    {
        @foreach (var alert in _alerts)
        {
            <article class="hip-alert-row">
                <span class="hip-alert-icon @Tone(alert.Severity)">!</span>
                <div>
                    <h2>@alert.Domain <span class="hip-pill @Tone(alert.Severity)">@alert.Severity</span> <span class="hip-pill info">@alert.SiteSafetyStatus</span></h2>
                    <p>@alert.ReasonSummary</p>
                    <small>@alert.Source · @alert.TargetType · @alert.CreatedAtUtc.UtcDateTime.ToString("u")</small>
                </div>
                @if (!string.IsNullOrWhiteSpace(alert.RelatedScanId))
                {
                    <a class="hip-source-pill" href="@($"/admin/scans/{Uri.EscapeDataString(alert.RelatedScanId)}")">Details</a>
                }
            </article>
        }
    }
</section>

@code {
    private IReadOnlyCollection<AdminRecentThreatItem> _alerts = [];
    private bool _isLoading = true;

    /// <summary>
    /// Loads live dashboard threat signals for the alert center.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var summary = await DashboardService.GetSummaryAsync(CancellationToken.None);
        _alerts = summary.RecentThreats;
        _isLoading = false;
    }

    /// <summary>
    /// Maps live severity labels to existing HIP visual tones.
    /// </summary>
    /// <param name="severity">Threat severity label.</param>
    /// <returns>CSS tone name.</returns>
    private static string Tone(string severity) =>
        severity.Equals("Critical", StringComparison.OrdinalIgnoreCase) ||
        severity.Equals("High", StringComparison.OrdinalIgnoreCase)
            ? "danger"
            : severity.Equals("Medium", StringComparison.OrdinalIgnoreCase)
                ? "suspicious"
                : "caution";
}
