@page "/admin"
@attribute [Authorize(Policy = AdminPolicies.CanViewAdminDashboard)]
@rendermode InteractiveServer
@inject IAdminDashboardService DashboardService

<PageTitle>HIP Admin Dashboard</PageTitle>

<main class="admin-rule-page">
    <section class="admin-rule-header">
        <div>
            <p class="eyebrow">HIP Admin</p>
            <h1>Dashboard</h1>
            <p>Privacy-safe operational overview for HIP review, rules, reputation, and reporting.</p>
        </div>
        <button class="primary-button" @onclick="RefreshAsync">Refresh</button>
    </section>

    @if (_summary is null)
    {
        <p>Loading dashboard...</p>
    }
    else
    {
        @if (!_summary.HasScanData)
        {
            <section class="lookup-result">
                <h2>No scan data yet.</h2>
                <p>Run the browser plugin on a test page to generate real data.</p>
                <p>Dashboard scan cards are sourced from @_summary.DataSource and do not use fake scan counts.</p>
            </section>
        }
        else
        {
            <section class="lookup-result">
                <div class="result-header">
                    <div>
                        <h2>Stored Browser Scan Data</h2>
                        <p>Data source: @_summary.DataSource. Domain-level summaries only; HIP does not show page text, form values, tokens, private messages, or raw scan payloads here.</p>
                    </div>
                    <span>@_summary.GeneratedAtUtc.UtcDateTime.ToString("u")</span>
                </div>
            </section>
        }

        <section class="score-grid dashboard-grid">
            @foreach (var card in _summary.Cards)
            {
                <article class="score-card">
                    <span>@card.Status</span>
                    <strong>@card.Value</strong>
                    <h3>@card.Label</h3>
                    <p>@card.Description</p>
                    @if (card.IsPlaceholder)
                    {
                        <small>Placeholder</small>
                    }
                </article>
            }
        </section>

        <section class="lookup-result">
            <div class="result-header">
                <div>
                    <h2>Top Risky Domains</h2>
                    <p>Sorted by dangerous links first, then total risky links. Domain-level summaries only.</p>
                </div>
            </div>

            @if (_summary.TopRiskyDomains.Count == 0)
            {
                <p>No risky domains from stored browser scans yet.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Domain</th>
                                <th>Risky</th>
                                <th>Dangerous</th>
                                <th>Average Score</th>
                                <th>Latest Scan</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var domain in _summary.TopRiskyDomains)
                            {
                                <tr>
                                    <td>@domain.Domain</td>
                                    <td>@domain.RiskyLinksFound</td>
                                    <td>@domain.DangerousLinksFound</td>
                                    <td>@domain.AverageHipScore</td>
                                    <td>@domain.LatestScanUtc.UtcDateTime.ToString("u")</td>
                                    <td>@domain.ReasonSummary</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="hip-panel hip-threat-panel" aria-labelledby="recent-threats-heading">
            <div class="hip-panel-heading">
                <div>
                    <h2 id="recent-threats-heading">Recent Threats</h2>
                    <p>Real HIP threat signals only. Clean pages and normal low-risk scans are not shown here.</p>
                </div>
                <span class="hip-pill @( _summary.RecentThreats.Count == 0 ? "good" : "danger" )">@_summary.RecentThreats.Count active</span>
            </div>

            @if (_summary.RecentThreats.Count == 0)
            {
                <div class="hip-threat-empty">
                    <strong>No recent threats found.</strong>
                    <span>HIP has no current high-risk evidence in the connected dashboard data.</span>
                </div>
            }
            else
            {
                <div class="hip-table-wrap">
                    <table class="hip-data-table hip-threat-table">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Domain</th>
                                <th>Severity</th>
                                <th>Status</th>
                                <th>Score</th>
                                <th>Source</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var threat in _summary.RecentThreats)
                            {
                                <tr>
                                    <td class="hip-threat-time">@threat.CreatedAtUtc.UtcDateTime.ToString("u")</td>
                                    <td>
                                        <div class="hip-threat-domain">
                                            <span class="hip-threat-icon @ThreatIconClass(threat.Severity)">!</span>
                                            <div>
                                                @if (!string.IsNullOrWhiteSpace(threat.RelatedScanId))
                                                {
                                                    <a href="@($"/admin/scans/{Uri.EscapeDataString(threat.RelatedScanId)}")">@threat.Domain</a>
                                                }
                                                else
                                                {
                                                    <strong>@threat.Domain</strong>
                                                }
                                                <small>@threat.TargetType</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="hip-pill @ThreatSeverityClass(threat.Severity)">@DisplaySeverity(threat.Severity)</span></td>
                                    <td><span class="hip-pill @ThreatStatusClass(threat.SiteSafetyStatus)">@DisplayStatus(threat.SiteSafetyStatus)</span></td>
                                    <td><strong class="hip-threat-score">@(threat.FinalHipScore?.ToString() ?? "-")</strong></td>
                                    <td><span class="hip-source-pill">@threat.Source</span></td>
                                    <td class="hip-threat-reason">
                                        <span>@threat.ReasonSummary</span>
                                        @if (!string.IsNullOrWhiteSpace(threat.WarningSummary))
                                        {
                                            <small>@threat.WarningSummary</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="lookup-result">
            <div class="result-header">
                <div>
                    <h2>Recent Scans</h2>
                    <p>Newest stored browser plugin scans, with privacy-safe summaries only.</p>
                </div>
            </div>

            @if (_summary.RecentScans.Count == 0)
            {
                <p>No recent browser plugin scans yet.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Domain</th>
                                <th>Score</th>
                                <th>Risk</th>
                                <th>Links</th>
                                <th>Risky</th>
                                <th>Dangerous</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var scan in _summary.RecentScans)
                            {
                                <tr>
                                    <td>@scan.LastCheckedUtc.UtcDateTime.ToString("u")</td>
                                    <td><a href="@($"/admin/scans/{Uri.EscapeDataString(scan.ScanResultId)}")">@scan.Domain</a></td>
                                    <td>@scan.Score</td>
                                    <td>@scan.RiskLevel</td>
                                    <td>@scan.LinksScanned</td>
                                    <td>@scan.RiskyLinksFound</td>
                                    <td>@scan.DangerousLinksFound</td>
                                    <td>@scan.ReasonSummary</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="lookup-result">
            <div class="result-header">
                <div>
                    <h2>Recent Activity</h2>
                    <p>Summaries only. HIP does not show private chat logs, message bodies, or raw private evidence here.</p>
                </div>
                <span>@_summary.ApiHealth</span>
            </div>

            @if (_summary.RecentActivity.Count == 0)
            {
                <p>No recent activity yet.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Type</th>
                                <th>Target</th>
                                <th>Risk</th>
                                <th>Summary</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _summary.RecentActivity)
                            {
                                <tr>
                                    <td>@item.CreatedAtUtc.UtcDateTime.ToString("u")</td>
                                    <td>@item.ActivityType</td>
                                    <td>@item.TargetType: @item.TargetId</td>
                                    <td>@(item.RiskLevel?.ToString() ?? "-")</td>
                                    <td>@item.Summary</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="lookup-result">
            <h2>Quick Links</h2>
            <div class="quick-link-grid">
                <a href="/admin/rules">Rules</a>
                <a href="/admin/self-healing">Self-Healing</a>
                <a href="/admin/review">Review Queue</a>
                <a href="/admin/appeals">Appeals</a>
                <a href="/admin/reputation-overrides">Reputation Overrides</a>
                <a href="/admin/audit">Audit Logs</a>
                <a href="/admin/roles">Roles</a>
                <a href="/lookup">Public Lookup</a>
                <a href="/docs/public-lookup-and-badges.md">Badge Docs</a>
                <a href="/clients/browser-extension/README.md">Browser Plugin Docs</a>
            </div>
        </section>
    }
</main>

@code {
    private AdminDashboardSummary? _summary;

    protected override Task OnInitializedAsync() => RefreshAsync();

    /// <summary>
    /// Maps a Recent Threats severity label to the existing HIP pill color system.
    /// </summary>
    /// <param name="severity">Severity label from the dashboard summary.</param>
    /// <returns>CSS class for the pill.</returns>
    private static string ThreatSeverityClass(string severity) =>
        severity.Equals("Critical", StringComparison.OrdinalIgnoreCase) ||
        severity.Equals("Dangerous", StringComparison.OrdinalIgnoreCase) ||
        severity.Equals("High", StringComparison.OrdinalIgnoreCase)
            ? "danger"
            : severity.Equals("Medium", StringComparison.OrdinalIgnoreCase)
                ? "suspicious"
                : "caution";

    /// <summary>
    /// Maps the Site Safety status into the HIP pill tone used by the prototype.
    /// </summary>
    /// <param name="status">Site Safety status label.</param>
    /// <returns>CSS class for the pill.</returns>
    private static string ThreatStatusClass(string status) =>
        status.Contains("Danger", StringComparison.OrdinalIgnoreCase) ||
        status.Contains("Critical", StringComparison.OrdinalIgnoreCase) ||
        status.Contains("HighRisk", StringComparison.OrdinalIgnoreCase)
            ? "danger"
            : status.Contains("Suspicious", StringComparison.OrdinalIgnoreCase) ||
              status.Contains("Feedback", StringComparison.OrdinalIgnoreCase) ||
              status.Contains("Review", StringComparison.OrdinalIgnoreCase)
                ? "suspicious"
                : "caution";

    /// <summary>
    /// Gives the row icon the same risk tone as the severity badge.
    /// </summary>
    /// <param name="severity">Severity label.</param>
    /// <returns>CSS class for the icon.</returns>
    private static string ThreatIconClass(string severity) => ThreatSeverityClass(severity);

    /// <summary>
    /// Adds readable spacing to compact severity labels.
    /// </summary>
    /// <param name="severity">Severity label.</param>
    /// <returns>Display label.</returns>
    private static string DisplaySeverity(string severity) =>
        severity.Equals("HighRisk", StringComparison.OrdinalIgnoreCase) ? "High Risk" : severity;

    /// <summary>
    /// Adds readable spacing to compact status labels while preserving the source value.
    /// </summary>
    /// <param name="status">Status label.</param>
    /// <returns>Display label.</returns>
    private static string DisplayStatus(string status) =>
        status switch
        {
            "HighRisk" => "High Risk",
            "LimitedTrustData" => "Limited Trust Data",
            "FeedbackSignal" => "Feedback Signal",
            "ReviewSignal" => "Review Signal",
            _ => status
        };

    /// <summary>
    /// Refreshes dashboard data from the privacy-safe admin summary service.
    /// </summary>
    private async Task RefreshAsync()
    {
        _summary = await DashboardService.GetSummaryAsync(CancellationToken.None);
    }
}
