@page "/audit"
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Audit | HIP Admin</PageTitle>

<div class="content-wrapper">
    <div class="content">
        <div class="main-header">
            <h2>AUDIT</h2>
            <em>recent trust/security decisions</em>
        </div>

        <div class="widget" style="margin-bottom:12px;">
            <div class="widget-header">
                <h3><i class="fa fa-balance-scale"></i> Policy Pack</h3>
                <div class="btn-group widget-header-toolbar">
                    <button class="link-btn icon-btn" @onclick="LoadPolicyAsync" disabled="@_loadingPolicy" title="Refresh"><i class="fa @(_loadingPolicy ? "fa-spinner fa-spin" : "fa-refresh")"></i></button>
                </div>
            </div>
            <div class="widget-content">
                @if (!string.IsNullOrWhiteSpace(_policyError))
                {
                    <p class="status-bad">@_policyError</p>
                }
                else if (_policyCurrent is null)
                {
                    <p>Policy pack info unavailable.</p>
                }
                else
                {
                    <p><strong>Active:</strong> @_policyCurrent.PluginId (@_policyCurrent.Version)</p>
                    <ul class="meta-list">
                        <li><strong>Low:</strong> @_policyCurrent.RequiredScores.Low</li>
                        <li><strong>Medium:</strong> @_policyCurrent.RequiredScores.Medium</li>
                        <li><strong>High:</strong> @_policyCurrent.RequiredScores.High</li>
                    </ul>
                    @if (_strictPolicy is not null)
                    {
                        <p><strong>Strict pack available:</strong> @_strictPolicy.PluginId</p>
                    }
                }
            </div>
        </div>

        <div class="widget">
            <div class="widget-header">
                <h3><i class="fa fa-shield"></i> Audit Trail</h3>
                <div class="btn-group widget-header-toolbar">
                    <button class="link-btn icon-btn" @onclick="LoadAuditAsync" disabled="@_loading" title="Refresh"><i class="fa @(_loading ? "fa-spinner fa-spin" : "fa-refresh")"></i></button>
                </div>
            </div>
            <div class="widget-content">
                <div class="input-row" style="display:flex; gap:8px; margin-bottom:10px;">
                    <input type="number" class="text-input" min="1" max="200" @bind="_take" />
                    <button class="btn btn-sm btn-primary" @onclick="LoadAuditAsync" disabled="@_loading">Load</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <p class="status-bad">@_error</p>
                }
                else if (_events.Count == 0)
                {
                    <p>No audit events yet.</p>
                }
                else
                {
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>UTC</th>
                                <th>Event</th>
                                <th>Subject</th>
                                <th>Outcome</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var evt in _events)
                            {
                                <tr>
                                    <td>@evt.CreatedAtUtc.ToString("MM-dd HH:mm:ss")</td>
                                    <td>@evt.EventType</td>
                                    <td>@evt.Subject</td>
                                    <td>@(evt.Outcome ?? "-")</td>
                                    <td>@(evt.ReasonCode ?? evt.Detail)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private int _take = 50;
    private bool _loading;
    private string? _error;
    private List<AuditEventDto> _events = new();

    private bool _loadingPolicy;
    private string? _policyError;
    private PolicyCurrentDto? _policyCurrent;
    private PolicyStrictDto? _strictPolicy;

    protected override async Task OnInitializedAsync()
    {
        await LoadPolicyAsync();
        await LoadAuditAsync();
    }

    private async Task LoadPolicyAsync()
    {
        _loadingPolicy = true;
        _policyError = null;

        try
        {
            var client = HttpClientFactory.CreateClient("hip-bff");
            _policyCurrent = await client.GetFromJsonAsync<PolicyCurrentDto>("/bff/policy/current");

            using var strictResponse = await client.GetAsync("/bff/policy/strict");
            if (strictResponse.IsSuccessStatusCode)
            {
                _strictPolicy = await strictResponse.Content.ReadFromJsonAsync<PolicyStrictDto>();
            }
            else
            {
                _strictPolicy = null;
            }
        }
        catch (Exception ex)
        {
            _policyError = ex.Message;
            _policyCurrent = null;
            _strictPolicy = null;
        }
        finally
        {
            _loadingPolicy = false;
        }
    }

    private async Task LoadAuditAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var client = HttpClientFactory.CreateClient("hip-bff");
            _events = await client.GetFromJsonAsync<List<AuditEventDto>>($"/bff/audit?take={Math.Clamp(_take, 1, 200)}") ?? new();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _events = new();
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed record PolicyScoresDto(int Low, int Medium, int High);
    private sealed record PolicyCurrentDto(string PluginId, string Version, PolicyScoresDto RequiredScores);
    private sealed record PolicyStrictDto(string PluginId, string Version);

    private sealed record AuditEventDto(
        string Id,
        DateTimeOffset CreatedAtUtc,
        string EventType,
        string Subject,
        string Source,
        string Detail,
        string? Category,
        string? Outcome,
        string? ReasonCode);
}
