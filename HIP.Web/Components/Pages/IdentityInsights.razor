@page "/identity/insights"
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Identity Insights | HIP Admin</PageTitle>

<div class="content-wrapper">
    <div class="content">
        <div class="main-header">
            <h2>IDENTITY INSIGHTS</h2>
            <em>trust and risk view per identity</em>
        </div>

        <div class="widget" style="margin-bottom:12px;">
            <div class="widget-header"><h3><i class="fa fa-search"></i> Lookup</h3></div>
            <div class="widget-content">
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <input class="text-input" placeholder="identity id" @bind="_identityId" />
                    <button class="btn btn-sm btn-primary" @onclick="LoadIdentityAsync">Load</button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <p class="status-bad">@_error</p>
        }
        else if (_insights is not null)
        {
            <div class="widget" style="margin-bottom:12px;">
                <div class="widget-header"><h3><i class="fa fa-user"></i> Identity Snapshot</h3></div>
                <div class="widget-content">
                    <p><strong>Exists:</strong> @_insights.Exists</p>
                    <p><strong>Reputation:</strong> @_insights.ReputationScore</p>
                </div>
            </div>

            <div class="widget" style="margin-bottom:12px;">
                <div class="widget-header"><h3><i class="fa fa-list"></i> Recent Policy Outcomes</h3></div>
                <div class="widget-content">
                    <ul class="meta-list">
                        @foreach (var row in _insights.RecentPolicy)
                        {
                            <li>@row.Utc.ToString("MM-dd HH:mm:ss") — @row.Outcome — @row.ReasonCode</li>
                        }
                    </ul>
                </div>
            </div>

            <div class="widget">
                <div class="widget-header"><h3><i class="fa fa-exclamation-circle"></i> Reason Breakdown</h3></div>
                <div class="widget-content">
                    <ul class="meta-list">
                        @foreach (var row in _insights.ReasonBreakdown)
                        {
                            <li>@row.ReasonCode: @row.Count</li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string _identityId = "openclaw-control-ui";
    private string? _error;
    private IdentityInsightsDto? _insights;

    protected override async Task OnInitializedAsync()
    {
        await LoadIdentityAsync();
    }

    private async Task LoadIdentityAsync()
    {
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("hip-bff");
            _insights = await client.GetFromJsonAsync<IdentityInsightsDto>($"/bff/identity/insights/{Uri.EscapeDataString(_identityId)}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _insights = null;
        }
    }

    private sealed record PolicyOutcomeDto(DateTimeOffset Utc, string? Outcome, string? ReasonCode);
    private sealed record ReasonBreakdownDto(string ReasonCode, int Count);
    private sealed record IdentityInsightsDto(string IdentityId, bool Exists, int ReputationScore, List<PolicyOutcomeDto> RecentPolicy, List<ReasonBreakdownDto> ReasonBreakdown);
}
