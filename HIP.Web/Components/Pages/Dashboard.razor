@page "/"
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.JSInterop
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>HIP Admin Dashboard</PageTitle>

<div class="main-header">
    <h2>DASHBOARD</h2>
    <em>the first priority information</em>
</div>

<section class="cards">
    <article class="card">
        <div class="card-head">
            <h3>Service Health</h3>
            <button class="link-btn" @onclick="LoadServiceHealthAsync" disabled="@_loadingHealth">@(_loadingHealth ? "Checking..." : "Refresh")</button>
        </div>

        @if (_loadingHealth)
        {
            <p>Loading service status...</p>
        }
        else if (!string.IsNullOrWhiteSpace(_healthError))
        {
            <p class="status-bad">Unavailable: @_healthError</p>
        }
        else if (_serviceHealth is not null)
        {
            <p class="status-ok">Status: Online</p>
            <ul class="meta-list">
                <li><strong>Service:</strong> @_serviceHealth.ServiceName</li>
                <li><strong>Version:</strong> @_serviceHealth.AssemblyVersion</li>
                <li><strong>UTC:</strong> @_serviceHealth.UtcTimestamp.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</li>
            </ul>
        }
        else
        {
            <p>Status not loaded yet.</p>
        }
    </article>

    <article class="card">
        <div class="card-head">
            <h3>Crypto Config (Dev)</h3>
            <button class="link-btn" @onclick="LoadCryptoConfigAsync" disabled="@_loadingCrypto">@(_loadingCrypto ? "Checking..." : "Refresh")</button>
        </div>

        <div class="input-row">
            <input class="text-input" @bind="_cryptoKeyId" placeholder="key id (e.g. hip-system)" />
        </div>

        @if (_loadingCrypto)
        {
            <p>Loading crypto config...</p>
        }
        else if (!string.IsNullOrWhiteSpace(_cryptoError))
        {
            <p class="status-bad">@_cryptoError</p>
        }
        else if (_cryptoConfig is not null)
        {
            <p class="status-ok">Config loaded</p>
            <ul class="meta-list">
                <li><strong>Provider:</strong> @_cryptoConfig.Provider</li>
                <li><strong>KeyId:</strong> @_cryptoConfig.KeyId</li>
                <li><strong>Private key:</strong> @(_cryptoConfig.PrivateKeyExists ? "Found" : "Missing")</li>
                <li><strong>Public key:</strong> @(_cryptoConfig.PublicKeyExists ? "Found" : "Missing")</li>
            </ul>
        }
        else
        {
            <p>No crypto config loaded yet.</p>
        }
    </article>

    <article class="card">
        <div class="card-head">
            <h3>Security Status</h3>
            <button class="link-btn" @onclick="LoadSecurityStatusAsync" disabled="@_loadingSecurity">@(_loadingSecurity ? "Loading..." : "Refresh")</button>
        </div>

        @if (_loadingSecurity)
        {
            <p>Loading security counters...</p>
        }
        else if (!string.IsNullOrWhiteSpace(_securityError))
        {
            <p class="status-bad">@_securityError</p>
        }
        else if (_securityStatus is not null)
        {
            <p class="status-ok">Counters loaded</p>
            <ul class="meta-list">
                <li><strong>Replay detected:</strong> @_securityStatus.ReplayDetected</li>
                <li><strong>Message expired:</strong> @_securityStatus.MessageExpired</li>
                <li><strong>Policy blocked:</strong> @_securityStatus.PolicyBlocked</li>
                <li><strong>UTC:</strong> @_securityStatus.UtcTimestamp.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</li>
            </ul>
            <div class="selected-detail">
                <strong>Recent Security Rejects</strong>
                @if (_securityEvents.Count == 0)
                {
                    <p>No recent rejects.</p>
                }
                else
                {
                    <ul class="meta-list">
                        @foreach (var evt in _securityEvents.Take(10))
                        {
                            <li>
                                <strong>@evt.Reason</strong> · @evt.IdentityId<br />
                                <small>msg=@(evt.MessageId ?? "-") · skew=@(evt.ClockSkewSeconds?.ToString("0.##") ?? "-")s · @evt.UtcTimestamp.ToString("MM-dd HH:mm:ss 'UTC'")</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        }
        else
        {
            <p>No security data loaded yet.</p>
        }
    </article>

    <article class="card">
        <div class="card-head">
            <h3>Extension Download</h3>
        </div>
        <div class="button-row" style="margin-top:10px;">
            <a class="link-btn" href="@($"/bff/extensions/hip-mail-bridge?v={_extensionDownloadVersion}")" download="hip-mail-bridge.tar.gz">Download Extension</a>
        </div>
    </article>

    <article class="card card-wide">
        <div class="card-head">
            <h3>Audit Feed</h3>
            <button class="link-btn" @onclick="LoadAuditFeedAsync" disabled="@_loadingAudit">@(_loadingAudit ? "Loading..." : "Refresh")</button>
        </div>

        <div class="form-grid">
            <div class="input-row">
                <label class="field-label">Event Type</label>
                <select class="text-input" @bind="_auditEventTypeFilter" @bind:after="LoadAuditFeedAsync">
                    <option value="all">All</option>
                    <option value="message.sign">message.sign</option>
                    <option value="message.verify">message.verify</option>
                    <option value="identity.get">identity.get</option>
                    <option value="reputation.get">reputation.get</option>
                </select>
            </div>
            <div class="input-row">
                <label class="field-label">Take</label>
                <select class="text-input" @bind="_auditTake" @bind:after="LoadAuditFeedAsync">
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
            <div class="input-row checkbox-row">
                <label>
                    <input type="checkbox" @bind="_auditAutoRefresh" @bind:after="OnAuditAutoRefreshChangedAsync" />
                    Auto-refresh (10s)
                </label>
            </div>
        </div>

        @if (_loadingAudit)
        {
            <p>Loading audit events...</p>
        }
        else if (!string.IsNullOrWhiteSpace(_auditError))
        {
            <p class="status-bad">Unavailable: @_auditError</p>
        }
        else if (_filteredAuditEvents is { Count: > 0 })
        {
            <ul class="meta-list clickable-list">
                @foreach (var evt in _filteredAuditEvents.Take(5))
                {
                    <li class="clickable-item" @onclick="() => SelectAuditEvent(evt)">
                        <strong>@evt.EventType</strong> · @evt.Subject<br />
                        <small>@evt.CreatedAtUtc.ToString("MM-dd HH:mm:ss 'UTC'") · @evt.Detail</small>
                    </li>
                }
            </ul>

            @if (_selectedAuditEvent is not null)
            {
                <div class="selected-detail">
                    <strong>Selected Event</strong>
                    <ul class="meta-list">
                        <li><strong>Id:</strong> @_selectedAuditEvent.Id</li>
                        <li><strong>EventType:</strong> @_selectedAuditEvent.EventType</li>
                        <li><strong>Subject:</strong> @_selectedAuditEvent.Subject</li>
                        <li><strong>Source:</strong> @_selectedAuditEvent.Source</li>
                        <li><strong>Detail:</strong> @_selectedAuditEvent.Detail</li>
                        <li><strong>UTC:</strong> @_selectedAuditEvent.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</li>
                    </ul>
                </div>
            }
        }
        else
        {
            <p>No audit events yet.</p>
        }
    </article>

    <article class="card">
        <div class="card-head">
            <h3>Identity Lookup</h3>
            <button class="link-btn" @onclick="LookupIdentityAsync" disabled="@_loadingIdentity">@(_loadingIdentity ? "Looking up..." : "Lookup")</button>
        </div>

        <div class="input-row">
            <input class="text-input" @bind="_identityLookupId" placeholder="identity id (e.g. hip-system)" />
        </div>

        @if (_loadingIdentity)
        {
            <p>Loading identity...</p>
        }
        else if (!string.IsNullOrWhiteSpace(_identityError))
        {
            <p class="status-bad">@_identityError</p>
        }
        else if (_identityResult is not null)
        {
            <p class="status-ok">Identity found</p>
            <ul class="meta-list">
                <li><strong>Id:</strong> @_identityResult.Id</li>
                <li><strong>PublicKeyRef:</strong> @_identityResult.PublicKeyRef</li>
            </ul>
        }
        else
        {
            <p>Enter an identity id and click Lookup.</p>
        }
    </article>

    <article class="card">
        <div class="card-head">
            <h3>Reputation Lookup</h3>
            <button class="link-btn" @onclick="LookupReputationAsync" disabled="@_loadingReputation">@(_loadingReputation ? "Looking up..." : "Lookup")</button>
        </div>

        <div class="input-row">
            <input class="text-input" @bind="_reputationLookupId" placeholder="identity id (e.g. hip-system)" />
        </div>

        @if (_loadingReputation)
        {
            <p>Loading reputation...</p>
        }
        else if (!string.IsNullOrWhiteSpace(_reputationError))
        {
            <p class="status-bad">@_reputationError</p>
        }
        else if (_reputationResult is not null)
        {
            <p class="status-ok">Reputation loaded</p>
            <ul class="meta-list">
                <li><strong>IdentityId:</strong> @_reputationResult.IdentityId</li>
                <li><strong>Score:</strong> @_reputationResult.Score</li>
                <li><strong>UTC:</strong> @_reputationResult.UtcTimestamp.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</li>
            </ul>
        }
        else
        {
            <p>Enter an identity id and click Lookup.</p>
        }
    </article>

    <article class="card card-wide">
        <div class="card-head">
            <h3>Message Sign / Verify Playground</h3>
            <div class="button-row">
                <button class="link-btn" @onclick="SignMessageAsync" disabled="@_loadingSign">@(_loadingSign ? "Signing..." : "Sign")</button>
                <button class="link-btn" @onclick="VerifyLastSignedMessageAsync" disabled="@(_loadingVerify || _lastSignedMessage is null)">@(_loadingVerify ? "Verifying..." : "Verify Last")</button>
                <button class="link-btn" @onclick="CopyLastSignedJsonAsync" disabled="@(string.IsNullOrWhiteSpace(_lastSignedMessageJson))">Copy JSON</button>
            </div>
        </div>

        <div class="input-row">
            <input class="text-input" @bind="_signFrom" placeholder="from" />
        </div>
        <div class="input-row">
            <input class="text-input" @bind="_signTo" placeholder="to" />
        </div>
        <div class="input-row">
            <input class="text-input" @bind="_signKeyId" placeholder="keyId (optional, e.g. hip-system-v2)" />
        </div>
        <div class="input-row">
            <textarea class="text-input text-area" @bind="_signBody" placeholder="message body"></textarea>
        </div>

        @if (!string.IsNullOrWhiteSpace(_signError))
        {
            <p class="status-bad">@_signError</p>
        }
        else if (!string.IsNullOrWhiteSpace(_signStatus))
        {
            <p class="status-ok">@_signStatus</p>
        }

        @if (!string.IsNullOrWhiteSpace(_verifyError))
        {
            <p class="status-bad">@_verifyError</p>
        }
        else if (!string.IsNullOrWhiteSpace(_verifyStatus))
        {
            <p class="status-ok">@_verifyStatus</p>
        }

        @if (!string.IsNullOrWhiteSpace(_copyError))
        {
            <p class="status-bad">@_copyError</p>
        }
        else if (!string.IsNullOrWhiteSpace(_copyStatus))
        {
            <p class="status-ok">@_copyStatus</p>
        }

        @if (!string.IsNullOrWhiteSpace(_lastSignedMessageJson))
        {
            <details>
                <summary>Last signed payload</summary>
                <pre class="json-block">@_lastSignedMessageJson</pre>
            </details>
        }
    </article>
</section>

@code {

    private ServiceStatusDto? _serviceHealth;
    private string? _healthError;
    private bool _loadingHealth;

    private CryptoConfigDto? _cryptoConfig;
    private string _cryptoKeyId = "hip-system";
    private string? _cryptoError;
    private bool _loadingCrypto;

    private SecurityStatusDto? _securityStatus;
    private List<SecurityEventDto> _securityEvents = new();
    private string? _securityError;
    private bool _loadingSecurity;

    private List<AuditEventDto> _auditEvents = new();
    private List<AuditEventDto> _filteredAuditEvents = new();
    private AuditEventDto? _selectedAuditEvent;
    private string _auditEventTypeFilter = "all";
    private int _auditTake = 50;
    private bool _auditAutoRefresh;
    private CancellationTokenSource? _auditLoopCts;
    private Task? _auditLoopTask;
    private string? _auditError;
    private bool _loadingAudit;

    private string _identityLookupId = "hip-system";
    private IdentityDto? _identityResult;
    private string? _identityError;
    private bool _loadingIdentity;

    private string _reputationLookupId = "hip-system";
    private ReputationDto? _reputationResult;
    private string? _reputationError;
    private bool _loadingReputation;

    private string _signFrom = "hip-system";
    private string _signTo = "target";
    private string _signBody = "hello from dashboard";
    private string _signKeyId = string.Empty;
    private bool _loadingSign;
    private string? _signError;
    private string? _signStatus;

    private bool _loadingVerify;
    private string? _verifyError;
    private string? _verifyStatus;

    private SignedMessageDto? _lastSignedMessage;
    private string? _lastSignedMessageJson;
    private string? _copyStatus;
    private string? _copyError;

    private readonly string _extensionDownloadVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString();

    protected override async Task OnInitializedAsync()
    {
        await LoadServiceHealthAsync();
        await LoadCryptoConfigAsync();
        await LoadSecurityStatusAsync();
        await LoadAuditFeedAsync();
        await LookupIdentityAsync();
        await LookupReputationAsync();
    }

    private async Task LoadServiceHealthAsync()
    {
        _loadingHealth = true;
        _healthError = null;

        try
        {
            var client = HttpClientFactory.CreateClient("hip-bff");
            _serviceHealth = await client.GetFromJsonAsync<ServiceStatusDto>("/bff/status");

            if (_serviceHealth is null)
            {
                _healthError = "No data returned.";
            }
        }
        catch (Exception ex)
        {
            _healthError = ex.Message;
            _serviceHealth = null;
        }
        finally
        {
            _loadingHealth = false;
        }
    }

    private async Task LoadCryptoConfigAsync()
    {
        _loadingCrypto = true;
        _cryptoError = null;

        try
        {
            var client = HttpClientFactory.CreateClient("hip-api");
            var keyId = string.IsNullOrWhiteSpace(_cryptoKeyId) ? "hip-system" : _cryptoKeyId.Trim();
            using var response = await client.GetAsync($"/api/admin/crypto-config?keyId={Uri.EscapeDataString(keyId)}");

            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _cryptoError = "Crypto config endpoint is only available in Development.";
                _cryptoConfig = null;
                return;
            }

            response.EnsureSuccessStatusCode();
            _cryptoConfig = await response.Content.ReadFromJsonAsync<CryptoConfigDto>();

            if (_cryptoConfig is null)
            {
                _cryptoError = "No data returned.";
            }
        }
        catch (Exception ex)
        {
            _cryptoError = ex.Message;
            _cryptoConfig = null;
        }
        finally
        {
            _loadingCrypto = false;
        }
    }

    private async Task LoadSecurityStatusAsync()
    {
        _loadingSecurity = true;
        _securityError = null;

        try
        {
            var client = HttpClientFactory.CreateClient("hip-bff");
            _securityStatus = await client.GetFromJsonAsync<SecurityStatusDto>("/bff/security-status");
            _securityEvents = await client.GetFromJsonAsync<List<SecurityEventDto>>("/bff/security-events?take=10") ?? new List<SecurityEventDto>();
            if (_securityStatus is null)
            {
                _securityError = "No data returned.";
            }
        }
        catch (Exception ex)
        {
            _securityError = ex.Message;
            _securityStatus = null;
        }
        finally
        {
            _loadingSecurity = false;
        }
    }

    private async Task LoadAuditFeedAsync()
    {
        _loadingAudit = true;
        _auditError = null;

        try
        {
            var client = HttpClientFactory.CreateClient("hip-api");
            var result = await client.GetFromJsonAsync<List<AuditEventDto>>($"/api/admin/audit?take={_auditTake}");
            _auditEvents = result ?? new List<AuditEventDto>();
            ApplyAuditFilter();
        }
        catch (Exception ex)
        {
            _auditError = ex.Message;
            _auditEvents = new List<AuditEventDto>();
            _filteredAuditEvents = new List<AuditEventDto>();
            _selectedAuditEvent = null;
        }
        finally
        {
            _loadingAudit = false;
        }
    }

    private void ApplyAuditFilter()
    {
        _filteredAuditEvents = _auditEventTypeFilter == "all"
            ? _auditEvents
            : _auditEvents.Where(x => string.Equals(x.EventType, _auditEventTypeFilter, StringComparison.OrdinalIgnoreCase)).ToList();

        if (_selectedAuditEvent is not null)
        {
            _selectedAuditEvent = _filteredAuditEvents.FirstOrDefault(x => x.Id == _selectedAuditEvent.Id);
        }
    }

    private void SelectAuditEvent(AuditEventDto evt)
    {
        _selectedAuditEvent = evt;
    }

    private async Task OnAuditAutoRefreshChangedAsync()
    {
        if (_auditAutoRefresh)
        {
            StartAuditAutoRefresh();
            await LoadAuditFeedAsync();
        }
        else
        {
            await StopAuditAutoRefreshAsync();
        }
    }

    private void StartAuditAutoRefresh()
    {
        _auditLoopCts?.Cancel();
        _auditLoopCts = new CancellationTokenSource();
        _auditLoopTask = RunAuditLoopAsync(_auditLoopCts.Token);
    }

    private async Task RunAuditLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                var hasNext = await timer.WaitForNextTickAsync(cancellationToken);
                if (!hasNext)
                {
                    break;
                }

                await InvokeAsync(LoadAuditFeedAsync);
            }
            catch (OperationCanceledException)
            {
                break;
            }
        }
    }

    private async Task StopAuditAutoRefreshAsync()
    {
        if (_auditLoopCts is not null)
        {
            _auditLoopCts.Cancel();
            _auditLoopCts.Dispose();
            _auditLoopCts = null;
        }

        if (_auditLoopTask is not null)
        {
            try
            {
                await _auditLoopTask;
            }
            catch (OperationCanceledException)
            {
            }
            _auditLoopTask = null;
        }
    }

    private async Task LookupIdentityAsync()
    {
        _loadingIdentity = true;
        _identityError = null;
        _identityResult = null;

        var id = _identityLookupId?.Trim();
        if (string.IsNullOrWhiteSpace(id))
        {
            _identityError = "Please enter an identity id.";
            _loadingIdentity = false;
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient("hip-bff");
            using var response = await client.GetAsync($"/bff/identity/{Uri.EscapeDataString(id)}");

            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _identityError = $"Identity '{id}' was not found.";
                return;
            }

            if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                _identityError = "Invalid identity id format.";
                return;
            }

            response.EnsureSuccessStatusCode();
            _identityResult = await response.Content.ReadFromJsonAsync<IdentityDto>();

            if (_identityResult is null)
            {
                _identityError = "No data returned.";
            }
        }
        catch (Exception ex)
        {
            _identityError = ex.Message;
        }
        finally
        {
            _loadingIdentity = false;
        }
    }

    private async Task LookupReputationAsync()
    {
        _loadingReputation = true;
        _reputationError = null;
        _reputationResult = null;

        var id = _reputationLookupId?.Trim();
        if (string.IsNullOrWhiteSpace(id))
        {
            _reputationError = "Please enter an identity id.";
            _loadingReputation = false;
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient("hip-bff");
            using var response = await client.GetAsync($"/bff/reputation/{Uri.EscapeDataString(id)}");

            if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                _reputationError = "Invalid identity id format.";
                return;
            }

            response.EnsureSuccessStatusCode();
            _reputationResult = await response.Content.ReadFromJsonAsync<ReputationDto>();

            if (_reputationResult is null)
            {
                _reputationError = "No data returned.";
            }
        }
        catch (Exception ex)
        {
            _reputationError = ex.Message;
        }
        finally
        {
            _loadingReputation = false;
        }
    }

    private async Task SignMessageAsync()
    {
        _loadingSign = true;
        _signError = null;
        _signStatus = null;
        _verifyError = null;
        _verifyStatus = null;
        _copyError = null;
        _copyStatus = null;

        if (string.IsNullOrWhiteSpace(_signFrom) || string.IsNullOrWhiteSpace(_signTo) || string.IsNullOrWhiteSpace(_signBody))
        {
            _signError = "from, to, and body are required.";
            _loadingSign = false;
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient("hip-api");
            var request = new SignMessageRequestDto(
                _signFrom.Trim(),
                _signTo.Trim(),
                _signBody,
                null,
                string.IsNullOrWhiteSpace(_signKeyId) ? null : _signKeyId.Trim());

            using var response = await client.PostAsJsonAsync("/api/messages/sign", request);
            response.EnsureSuccessStatusCode();

            var result = await response.Content.ReadFromJsonAsync<SignMessageResultDto>();
            if (result is null)
            {
                _signError = "No data returned.";
                return;
            }

            if (!result.Success)
            {
                _signError = $"Sign failed: {result.Reason}";
                return;
            }

            _lastSignedMessage = result.Message;
            _lastSignedMessageJson = JsonSerializer.Serialize(result.Message, new JsonSerializerOptions { WriteIndented = true });
            _signStatus = $"Signed successfully (reason: {result.Reason}).";
        }
        catch (Exception ex)
        {
            _signError = ex.Message;
        }
        finally
        {
            _loadingSign = false;
        }
    }

    private async Task VerifyLastSignedMessageAsync()
    {
        _loadingVerify = true;
        _verifyError = null;
        _verifyStatus = null;

        if (_lastSignedMessage is null)
        {
            _verifyError = "No signed message available yet. Click Sign first.";
            _loadingVerify = false;
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient("hip-api");
            using var response = await client.PostAsJsonAsync("/api/messages/verify", _lastSignedMessage);
            response.EnsureSuccessStatusCode();

            var result = await response.Content.ReadFromJsonAsync<VerifyMessageResultDto>();
            if (result is null)
            {
                _verifyError = "No data returned.";
                return;
            }

            _verifyStatus = result.IsValid
                ? $"Verify success ({result.Reason})."
                : $"Verify failed ({result.Reason}).";
        }
        catch (Exception ex)
        {
            _verifyError = ex.Message;
        }
        finally
        {
            _loadingVerify = false;
        }
    }

    private async Task CopyLastSignedJsonAsync()
    {
        _copyError = null;
        _copyStatus = null;

        if (string.IsNullOrWhiteSpace(_lastSignedMessageJson))
        {
            _copyError = "No signed payload available yet.";
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _lastSignedMessageJson);
            _copyStatus = "Signed payload JSON copied to clipboard.";
        }
        catch (Exception ex)
        {
            _copyError = $"Copy failed: {ex.Message}";
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopAuditAutoRefreshAsync();
    }

    private sealed record ServiceStatusDto(string ServiceName, string AssemblyVersion, DateTimeOffset UtcTimestamp);
    private sealed record CryptoConfigDto(
        string Provider,
        string? PrivateKeyStorePath,
        string? PublicKeyStorePath,
        string KeyId,
        string? PrivateKeyPath,
        string? PublicKeyPath,
        bool PrivateKeyExists,
        bool PublicKeyExists);
    private sealed record SecurityStatusDto(long ReplayDetected, long MessageExpired, long PolicyBlocked, DateTimeOffset UtcTimestamp);
    private sealed record SecurityEventDto(string Reason, string IdentityId, string? MessageId, double? ClockSkewSeconds, string? Classification, DateTimeOffset UtcTimestamp);
    private sealed record AuditEventDto(string Id, DateTimeOffset CreatedAtUtc, string EventType, string Subject, string Source, string Detail);
    private sealed record IdentityDto(string Id, string PublicKeyRef);
