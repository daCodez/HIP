@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="app-frame">
    <header class="topbar">
        <div class="topbar-left">
            <button class="menu-toggle" @onclick="ToggleNav" title="Toggle navigation">☰</button>
            <div class="topbar-title">HIP Admin</div>
        </div>
        <div class="topbar-right">
            <div class="user-chip" title="Logged in user">
                <span class="user-avatar">E</span>
                <span>Eric</span>
            </div>
        </div>
    </header>

    <div class="shell @(_navCollapsed ? "collapsed" : string.Empty)">
        <aside class="sidebar">
            <NavMenu />
        </aside>

        <main class="main">
            <div class="breadcrumb-bar">
                @foreach (var crumb in GetBreadcrumbs())
                {
                    <span class="crumb">@crumb</span>
                }
            </div>
            @Body
        </main>
    </div>
</div>

@code {
    private bool _navCollapsed;

    private void ToggleNav() => _navCollapsed = !_navCollapsed;

    private IEnumerable<string> GetBreadcrumbs()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri);
        if (string.IsNullOrWhiteSpace(path))
        {
            return new[] { "Dashboard", "Overview" };
        }

        var parts = path.Split('/', StringSplitOptions.RemoveEmptyEntries)
            .Select(p => char.ToUpperInvariant(p[0]) + p[1..]);

        return new[] { "Dashboard" }.Concat(parts);
    }
}
