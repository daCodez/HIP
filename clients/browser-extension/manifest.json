{
  "manifest_version": 3,
  "name": "HIP Browser Protection",
  "description": "Human Identity Protocol website and link trust checks.",
  "version": "0.1.8",
  "action": {
    "default_title": "HIP",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "src/riskBadgeRenderer.js",
        "src/safetyPageRouter.js",
        "src/browserScanAssessment.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "icons": {
    "16": "assets/icons/hip-16.svg",
    "32": "assets/icons/hip-32.svg",
    "48": "assets/icons/hip-48.svg",
    "128": "assets/icons/hip-128.svg"
  }
}
